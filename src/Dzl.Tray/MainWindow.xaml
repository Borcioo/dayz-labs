<ui:FluentWindow x:Class="Dzl.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dzl.Tray"
        xmlns:vm="clr-namespace:Dzl.Tray.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="dzl — DayZ Dev Launcher"
        MinWidth="1100" MinHeight="720"
        Width="1240" Height="800"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- title bar -->
      <RowDefinition Height="Auto" />  <!-- top action bar -->
      <RowDefinition Height="*" />     <!-- nav + content -->
      <RowDefinition Height="Auto" />  <!-- bottom status bar -->
    </Grid.RowDefinitions>
    <Grid.Resources>
      <local:StatusDotConverter x:Key="StatusDotConverter" />
      <local:BoolToOpacityConverter x:Key="BoolToOpacity" />
      <BooleanToVisibilityConverter x:Key="BoolToVis" />
      <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
      <local:StringEqualsConverter x:Key="StringEquals" />
      <local:StringEqualsVisibilityConverter x:Key="StringEqualsVis" />
      <local:StringMatchVisibilityConverter x:Key="StringMatchVis" />

      <!-- ===== Nav rail (plain-WPF ListBox; deterministic page switching) ===== -->
      <!-- A transparent ListBox whose items are pill-shaped rows with an icon + label.
           IsSelected drives an accent-tinted background; IsMouseOver a subtle hover.
           Used by both NavTop and NavBottom so they look like one continuous rail. -->
      <Style x:Key="NavListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      </Style>

      <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ListBoxItem">
              <Border x:Name="Bd" CornerRadius="6" Padding="12,8" Margin="4,2"
                      Background="Transparent">
                <ContentPresenter VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#332D7DD2" />
                  <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                  <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Read-only monospace, dark, no-wrap log pane (script/rpt/adm/client). -->
      <Style x:Key="LogTextBox" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="IsReadOnlyCaretVisible" Value="False" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
      </Style>

      <!-- Segmented-control-style radio for the Logs view-mode selector. Looks like a flat
           pill that fills with accent when checked. RadioButtons in one GroupName behave
           as a mutually-exclusive segment group. -->
      <Style x:Key="LogsViewSegment" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="GroupName" Value="LogsView" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="RadioButton">
              <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                      Background="Transparent">
                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#332D7DD2" />
                  <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                  <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- One log pane: card with header (icon + Title + dimmed FileName + open/clear) and a
           mono read-only TextBox body. Reused by all four Logs view modes (grid/list/tabs/
           focus); the TextChanged autoscroll keeps the tail pinned to the bottom everywhere. -->
      <DataTemplate x:Key="LogPaneTemplate">
        <!-- Plain Border (not ui:Card): a Border is a decorator whose child always fills it,
             so the pane stretches to its container. ui:Card sizes to content / won't stretch. -->
        <Border Margin="3" Padding="12" CornerRadius="8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                               Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                           Padding="6" Margin="0,0,6,0"
                           Command="{Binding DataContext.OpenLogFolderCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                           CommandParameter="{Binding}" />
                <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                           Padding="6"
                           Command="{Binding DataContext.ClearLogCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                           CommandParameter="{Binding}" />
              </StackPanel>
            </Grid>
            <TextBox Grid.Row="1" Text="{Binding Text, Mode=OneWay}"
                     TextChanged="OnLogTextChanged"
                     Style="{StaticResource LogTextBox}" />
          </Grid>
        </Border>
      </DataTemplate>

      <!-- Small read-only mono output area for Tools (pack/paa/unbinarize results). -->
      <Style x:Key="ToolOutputBox" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
      </Style>

      <!-- Settings field label. -->
      <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      </Style>

      <!-- Dark Fluent-friendly DataGrid style: the stock WPF DataGrid renders light/grey,
           so we restyle row height, gridlines, header and selection to match the theme. -->
      <Style x:Key="DarkDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="Transparent" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="RowHeight" Value="32" />
        <Setter Property="ColumnHeaderHeight" Value="34" />
        <Setter Property="CanUserResizeRows" Value="False" />
      </Style>

      <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
      </Style>

      <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Style.Triggers>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
          </Trigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="DataGridCell">
              <Border Background="{TemplateBinding Background}" Padding="8,0">
                <ContentPresenter VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Grid.Resources>

    <!-- ============ TITLE BAR ============ -->
    <ui:TitleBar Grid.Row="0" Title="dzl — DayZ Dev Launcher" Margin="0">
      <ui:TitleBar.Icon>
        <ui:SymbolIcon Symbol="Gauge24" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>

    <!-- ============ TOP ACTION BAR ============ -->
    <Border Grid.Row="1" Padding="16,8"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />  <!-- app name -->
          <ColumnDefinition Width="Auto" />  <!-- mode toggle -->
          <ColumnDefinition Width="Auto" />  <!-- profile -->
          <ColumnDefinition Width="*" />     <!-- spacer -->
          <ColumnDefinition Width="Auto" />  <!-- status pills -->
        </Grid.ColumnDefinitions>

        <!-- App name -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
          <ui:SymbolIcon Symbol="Gauge24" FontSize="20" Margin="0,0,8,0"
                         Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
          <TextBlock Text="dzl" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Mode toggle: debug | normal -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
          <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <ui:ToggleSwitch IsChecked="{Binding IsNormalMode, Mode=OneWay}"
                           Click="OnModeToggleClick"
                           OffContent="debug" OnContent="normal"
                           VerticalAlignment="Center" />
          <local:InfoTip Text="{x:Static local:HelpText.Mode}" />
        </StackPanel>

        <!-- Server quick switcher (manage on the Servers page) -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Server" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <ComboBox Width="180" VerticalAlignment="Center"
                    ToolTip="Switch active server instance (manage on the Servers page)"
                    ItemsSource="{Binding Presets}"
                    SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                    SelectionChanged="OnProfileSelectionChanged" />
        </StackPanel>

        <!-- Status pills -->
        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
          <!-- SERVER pill -->
          <Border CornerRadius="14" Padding="12,5" Margin="0,0,10,0"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding ServerUp, Converter={StaticResource StatusDotConverter}}" />
              <TextBlock Text="SERVER" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding ServerStatus}" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </Border>
          <!-- CLIENT pill -->
          <Border CornerRadius="14" Padding="12,5" Margin="0,0,10,0"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding ClientUp, Converter={StaticResource StatusDotConverter}}" />
              <TextBlock Text="CLIENT" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding ClientStatus}" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </Border>
          <!-- MCP / automation server pill: reflects whether the named-pipe host (driving the
               dzl CLI + Claude MCP integration) is actually running this session. -->
          <Border CornerRadius="14" Padding="12,5"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                  ToolTip="Automation server (lets the dzl CLI and the Claude MCP integration control this app). Toggle in Settings → Automation; applies on next launch.">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding AutomationOn, Converter={StaticResource StatusDotConverter}}" />
              <TextBlock Text="MCP" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding AutomationStatus}" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <local:InfoTip Text="{x:Static local:HelpText.Mcp}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ============ NAVIGATION + CONTENT ============ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />  <!-- left nav rail -->
        <ColumnDefinition Width="*" />     <!-- content -->
      </Grid.ColumnDefinitions>

      <!-- Left rail. Plain-WPF ListBox-based nav: deterministic page switching via
           SelectionChanged (the Wpf.Ui NavigationView is page-navigation oriented and
           swallowed clicks when used as a bare rail). Top sections + pinned Settings. -->
      <Border Grid.Column="0" Width="220"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}"
              Background="{DynamicResource ControlFillColorDefaultBrush}">
        <DockPanel LastChildFill="True">
          <!-- Pinned Settings at the bottom -->
          <ListBox x:Name="NavBottom" DockPanel.Dock="Bottom"
                   Style="{StaticResource NavListBox}"
                   ItemContainerStyle="{StaticResource NavListBoxItem}"
                   Margin="0,0,0,8"
                   SelectionChanged="OnNavChanged">
            <ListBoxItem Tag="settings">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Settings" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
          </ListBox>

          <!-- Main sections -->
          <ListBox x:Name="NavTop"
                   Style="{StaticResource NavListBox}"
                   ItemContainerStyle="{StaticResource NavListBoxItem}"
                   Margin="0,8,0,0"
                   VerticalAlignment="Top"
                   SelectionChanged="OnNavChanged">
            <ListBoxItem Tag="dashboard">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Gauge24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="mods">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Apps24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Mods" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="mymods">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="My Mods" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="servers">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Server24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Servers" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="bases">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Layer24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Bases" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="economy">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Money24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Economy" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="logs">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="TextBulletListLtr24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Logs" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="tools">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Toolbox24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Tools" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <!-- Setup: not a page — selecting it opens the Setup Wizard (modal), then the rail
                 selection is restored to the previously-shown page (OnNavChanged). -->
            <ListBoxItem Tag="setup">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Wand24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Setup" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <!-- MCP setup guide: only shown when the automation server is running (ShowMcpTab). -->
            <ListBoxItem Tag="mcp" Visibility="{Binding ShowMcpTab, Converter={StaticResource BoolToVis}}">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="PlugConnected24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="MCP" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Content host: five panels, one visible at a time (toggled in OnNavChanged → ShowPage). -->
      <Grid Grid.Column="1" Margin="16">

          <!-- ===== DASHBOARD =====
               Two target-scoped columns: LEFT = everything SERVER, RIGHT = everything CLIENT.
               Each column stacks control card → launch command → active mods → edit shortcuts. -->
          <Grid x:Name="PageDashboard">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />  <!-- summary strip -->
              <RowDefinition Height="*" />     <!-- two columns -->
            </Grid.RowDefinitions>

            <!-- Compact summary strip: mode / port / active profile -->
            <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="16,12">
              <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,32,0">
                  <TextBlock Text="MODE" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding Mode}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                  <TextBlock Text="PORT" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding Port}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="ACTIVE PROFILE" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding ActivePreset}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </StackPanel>
            </ui:Card>

            <!-- Two columns (server | client). Each column is a row-grid that fills the page
                 height; the Active mods card takes the * row and scrolls internally. -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="16" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT: SERVER ===== -->
                <Grid Grid.Column="0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- control card -->
                    <RowDefinition Height="Auto" />  <!-- launch command -->
                    <RowDefinition Height="*" />     <!-- active mods (grows) -->
                    <RowDefinition Height="Auto" />  <!-- shortcuts -->
                  </Grid.RowDefinitions>
                  <!-- Control card -->
                  <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="16">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Server24" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Server" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="9" Height="9" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding ServerUp, Converter={StaticResource StatusDotConverter}}" />
                            <TextBlock Text="{Binding ServerStatus}" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Start" Appearance="Success" Icon="{ui:SymbolIcon Play24}"
                                   MinWidth="90" Margin="0,0,8,0" Command="{Binding StartServerCommand}" />
                        <ui:Button Content="Stop" Appearance="Danger" Icon="{ui:SymbolIcon Stop24}"
                                   MinWidth="90" Margin="0,0,8,0" Command="{Binding StopServerCommand}" />
                        <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}"
                                   MinWidth="90" Command="{Binding RestartServerCommand}" />
                      </StackPanel>
                    </StackPanel>
                  </ui:Card>

                  <!-- Launch command card -->
                  <ui:Card Grid.Row="1" Margin="0,0,0,12" Padding="16">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Launch command" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <local:InfoTip Text="{x:Static local:HelpText.Mode}" />
                      </StackPanel>
                      <Border CornerRadius="4" Padding="10"
                              Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                          <TextBox Text="{Binding ServerArgv, Mode=OneWay}" IsReadOnly="True"
                                   BorderThickness="0" Background="Transparent"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   TextWrapping="Wrap" />
                        </ScrollViewer>
                      </Border>
                    </StackPanel>
                  </ui:Card>

                  <!-- Active mods (Border, not ui:Card: Card sizes to content; Border fills the * row) -->
                  <Border Grid.Row="2" Margin="0,0,0,12" Padding="16" CornerRadius="8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                      </Grid.RowDefinitions>
                      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Active mods" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ServerModsCount, StringFormat=' ({0})'}" FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <local:InfoTip Text="{x:Static local:HelpText.ModSide}" />
                      </StackPanel>
                      <Border Grid.Row="1" CornerRadius="4" Padding="4"
                              Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                          <TextBlock Text="(none enabled)" Margin="8,6" FontSize="12"
                                     Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding ServerModsCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                          <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ServerMods}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding}" Margin="8,3" FontSize="13"
                                             TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </Grid>
                      </Border>
                    </Grid>
                  </Border>

                  <!-- Shortcuts -->
                  <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <ui:Button Content="Edit mods" Icon="{ui:SymbolIcon Apps24}"
                               Margin="0,0,8,0" Click="OnEditMods" />
                    <ui:Button Content="Edit params" Icon="{ui:SymbolIcon Settings24}"
                               Tag="server" Click="OnEditParams" />
                  </StackPanel>
                </Grid>

                <!-- ===== RIGHT: CLIENT ===== -->
                <Grid Grid.Column="2">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- control card -->
                    <RowDefinition Height="Auto" />  <!-- launch command -->
                    <RowDefinition Height="*" />     <!-- active mods (grows) -->
                    <RowDefinition Height="Auto" />  <!-- shortcuts -->
                  </Grid.RowDefinitions>
                  <!-- Control card -->
                  <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="16">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Client" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="9" Height="9" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding ClientUp, Converter={StaticResource StatusDotConverter}}" />
                            <TextBlock Text="{Binding ClientStatus}" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Start" Appearance="Success" Icon="{ui:SymbolIcon Play24}"
                                   MinWidth="90" Margin="0,0,8,0" Command="{Binding StartClientCommand}" />
                        <ui:Button Content="Stop" Appearance="Danger" Icon="{ui:SymbolIcon Stop24}"
                                   MinWidth="90" Margin="0,0,8,0" Command="{Binding StopClientCommand}" />
                        <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}"
                                   MinWidth="90" Command="{Binding RestartClientCommand}" />
                      </StackPanel>
                    </StackPanel>
                  </ui:Card>

                  <!-- Launch command card -->
                  <ui:Card Grid.Row="1" Margin="0,0,0,12" Padding="16">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Launch command" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <local:InfoTip Text="{x:Static local:HelpText.Mode}" />
                      </StackPanel>
                      <Border CornerRadius="4" Padding="10"
                              Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                          <TextBox Text="{Binding ClientArgv, Mode=OneWay}" IsReadOnly="True"
                                   BorderThickness="0" Background="Transparent"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   TextWrapping="Wrap" />
                        </ScrollViewer>
                      </Border>
                    </StackPanel>
                  </ui:Card>

                  <!-- Active mods (Border, not ui:Card: Card sizes to content; Border fills the * row) -->
                  <Border Grid.Row="2" Margin="0,0,0,12" Padding="16" CornerRadius="8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                      </Grid.RowDefinitions>
                      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Active mods" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ClientModsCount, StringFormat=' ({0})'}" FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <local:InfoTip Text="{x:Static local:HelpText.ModSide}" />
                      </StackPanel>
                      <Border Grid.Row="1" CornerRadius="4" Padding="4"
                              Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                          <TextBlock Text="(none enabled)" Margin="8,6" FontSize="12"
                                     Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding ClientModsCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                          <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ClientMods}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding}" Margin="8,3" FontSize="13"
                                             TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </Grid>
                      </Border>
                    </Grid>
                  </Border>

                  <!-- Shortcuts -->
                  <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <ui:Button Content="Edit mods" Icon="{ui:SymbolIcon Apps24}"
                               Margin="0,0,8,0" Click="OnEditMods" />
                    <ui:Button Content="Edit params" Icon="{ui:SymbolIcon Settings24}"
                               Tag="client" Click="OnEditParams" />
                  </StackPanel>
                </Grid>
              </Grid>
          </Grid>

          <!-- ===== MODS (library) ===== -->
          <Grid x:Name="PageMods" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />  <!-- header + search -->
              <RowDefinition Height="*" />     <!-- content -->
            </Grid.RowDefinitions>

            <!-- Header + search -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Mods" FontSize="20" FontWeight="SemiBold" />
                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Your mod library — what's discovered on this machine. Enable &amp; order mods per server on the Servers page." />
              </StackPanel>
              <ui:TextBox Grid.Column="1" Width="260" VerticalAlignment="Center"
                          PlaceholderText="filter mods…"
                          Icon="{ui:SymbolIcon Search24}"
                          Text="{Binding ModFilter, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- Steam Workshop (SP5) — full browser in its own window -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <TextBlock Text="Steam Workshop" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                 Text="Browse + search the Workshop, subscribe (Steam) or download (steamcmd), and see your subscribed mods — in a dedicated window. Keys/steamcmd in Settings → Steam." />
                    </StackPanel>
                    <ui:Button Grid.Column="1" Content="Open Workshop" Appearance="Primary"
                               Icon="{ui:SymbolIcon Search24}" VerticalAlignment="Center" Click="OnOpenWorkshop" />
                  </Grid>
                </ui:Card>

                <!-- Discovered library -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Discovered mods" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ModsSummary}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                      </StackPanel>
                      <ui:Button Grid.Column="1" Content="Rescan" Icon="{ui:SymbolIcon ArrowSync24}" Command="{Binding RescanCommand}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ModsView}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,6" Padding="10" CornerRadius="6"
                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Path}" FontSize="11" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                              </StackPanel>
                              <Border Grid.Column="1" CornerRadius="9" Padding="8,2" Margin="0,0,8,0" Background="#5A1F1F"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding Missing, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="missing" FontSize="11" FontWeight="SemiBold" Foreground="#FF6B6B" />
                              </Border>
                              <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger"
                                         ToolTip="Remove this stale entry from the active server's run-list"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding Missing, Converter={StaticResource BoolToVis}}"
                                         Command="{Binding DataContext.RemoveModCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                         CommandParameter="{Binding}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(no mods discovered — set your scan-roots in Settings, then Rescan)" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Mods.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== MY MODS (source projects) ===== -->
          <Grid x:Name="PageMyMods" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
              <TextBlock Text="My Mods" FontSize="20" FontWeight="SemiBold" />
              <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Run Text="Source projects under " /><Run Text="{Binding ProjectsRoot, Mode=OneWay}" FontWeight="SemiBold" />
              </TextBlock>
              <!-- P: status — building needs the work drive mounted -->
              <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0"
                         Fill="{Binding WorkDriveMounted, Converter={StaticResource StatusDotConverter}}" />
                <TextBlock Text="{Binding WorkDriveStatus}" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,8,0" />
                <ui:Button Content="Mount P:" Padding="8,2" FontSize="12" Click="OnMountWorkDrive"
                           Visibility="{Binding WorkDriveMounted, Converter={StaticResource InverseBoolToVis}}" />
              </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- Warning: P: not mounted → building is blocked -->
                <Border Margin="0,0,0,12" Padding="12" CornerRadius="6"
                        Background="#3A2A0F" BorderBrush="#7A5A1F" BorderThickness="1"
                        Visibility="{Binding WorkDriveMounted, Converter={StaticResource InverseBoolToVis}}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="18" Margin="0,0,10,0"
                                   VerticalAlignment="Center" Foreground="#F0C04A" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#F0D9A8"
                               Text="P: work drive is not mounted — building is disabled. Binarize resolves vanilla data and includes against P:. Mount it to build." />
                    <ui:Button Grid.Column="2" Content="Mount P:" Appearance="Primary" VerticalAlignment="Center"
                               Margin="12,0,0,0" Click="OnMountWorkDrive" />
                  </Grid>
                </Border>

                <!-- New mod -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="New mod" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="NewModNameBox" Grid.Column="0" Margin="0,0,4,0"
                                  PlaceholderText="ModName (letters, digits, _)" />
                      <ui:TextBox x:Name="NewModAuthorBox" Grid.Column="1" Margin="4,0,4,0"
                                  PlaceholderText="author" />
                      <ui:Button x:Name="NewModButton" Grid.Column="2" Content="Create" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Add24}" Click="OnCreateMod" />
                    </Grid>
                    <TextBlock x:Name="NewModStatus" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </ui:Card>

                <!-- Import existing -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Import existing mod folder" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="ImportPathBox" Grid.Column="0" PlaceholderText="path to existing mod source…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="dir:ImportPathBox" Click="OnBrowseInto" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="ImportNameBox" Grid.Column="0"
                                  PlaceholderText="name (optional — defaults to folder name)" />
                      <ui:Button Grid.Column="1" Content="Import" Appearance="Primary"
                                 Icon="{ui:SymbolIcon ArrowImport24}" Margin="8,0,0,0" Click="OnImportMod" />
                    </Grid>
                    <TextBlock x:Name="ImportStatus" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </ui:Card>

                <!-- Projects list -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Projects" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <ui:Button Grid.Column="1" Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefreshMyMods" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ModProjects}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,8" Padding="12" CornerRadius="6"
                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Path}" FontSize="11" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                  <Run Text="git:" /><Run Text=" " /><Run Text="{Binding Git, Mode=OneWay}" />
                                </TextBlock>
                              </StackPanel>
                              <Border Grid.Column="1" CornerRadius="9" Padding="8,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Background" Value="#5A1F1F" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding Linked}" Value="True">
                                        <Setter Property="Background" Value="#1F4D2E" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Text" Value="unlinked" />
                                      <Setter Property="Foreground" Value="#FF6B6B" />
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding Linked}" Value="True">
                                          <Setter Property="Text" Value="linked" />
                                          <Setter Property="Foreground" Value="#7CE3A1" />
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                              </Border>
                              <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Primary: Build. Everything else under the ⋯ menu. -->
                                <ui:Button Content="Build" Appearance="Primary" Icon="{ui:SymbolIcon Box24}"
                                           ToolTip="Build → PBO and add to the active server's run-list (needs P: mounted)"
                                           Tag="{Binding Name}" Click="OnBuildMod" Margin="0,0,8,0"
                                           IsEnabled="{Binding DataContext.WorkDriveMounted, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                <ui:DropDownButton Icon="{ui:SymbolIcon MoreHorizontal24}" ToolTip="More actions">
                                  <ui:DropDownButton.Flyout>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                      <MenuItem Header="Open folder" Tag="{Binding Path}" Click="OnOpenModFolder">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <MenuItem Header="Open in editor" Tag="{Binding Path}" Click="OnOpenInEditor">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Code24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <Separator />
                                      <MenuItem Header="Link (P:)" Tag="{Binding Name}" Click="OnQuickJunction">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Link24" /></MenuItem.Icon>
                                        <MenuItem.Style>
                                          <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding Linked}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </MenuItem.Style>
                                      </MenuItem>
                                      <MenuItem Header="Unlink (P:)" Tag="{Binding Name}" Click="OnUnlinkMod">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="LinkDismiss24" /></MenuItem.Icon>
                                        <MenuItem.Style>
                                          <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding Linked}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </MenuItem.Style>
                                      </MenuItem>
                                      <Separator />
                                      <MenuItem Header="Publish to GitHub" Tag="{Binding Name}" Click="OnPublishRepo">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Branch24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <MenuItem Header="Create release" Tag="{Binding Name}" Click="OnReleaseRepo">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Tag24" /></MenuItem.Icon>
                                      </MenuItem>
                                    </ContextMenu>
                                  </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(no mod projects yet — create or import one above)" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding ModProjects.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>
                </ui:Card>

                <!-- Build log -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <ui:Card.Style>
                    <Style TargetType="ui:Card">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding BuildLog}" Value="">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ui:Card.Style>
                  <StackPanel>
                    <TextBlock Text="Output log" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding BuildLog, Mode=OneWay}" Style="{StaticResource LogTextBox}"
                             Height="200" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== SERVERS (instances) ===== -->
          <Grid x:Name="PageServers" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
              <TextBlock Text="Servers" FontSize="20" FontWeight="SemiBold" />
              <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Run Text="Each server instance is its own config — its own serverDZ.cfg, profiles, port, params and mod loadout. Select one to make it active and edit it below." />
              </TextBlock>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- New server -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="New server" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="NewServerNameBox" Grid.Column="0" Margin="0,0,8,0"
                                  PlaceholderText="instance name (e.g. pvp, hardcore)" />
                      <ComboBox x:Name="NewServerMapBox" Grid.Column="1" Width="120" Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                ToolTip="Map for vanilla instances. A base already fixes its own map, so this is locked when a base is selected."
                                ItemsSource="{Binding Maps}" SelectedIndex="0" />
                      <ComboBox x:Name="NewServerBaseBox" Grid.Column="2" Width="170" Margin="0,0,8,0"
                                VerticalAlignment="Center" ToolTip="Create from a base/template (brings its own map), or the DayZ install"
                                ItemsSource="{Binding BaseChoices}" SelectedIndex="0"
                                SelectionChanged="OnNewServerBaseChanged" />
                      <ui:TextBox x:Name="NewServerPortBox" Grid.Column="3" Width="80" Margin="0,0,8,0"
                                  PlaceholderText="port (auto)" />
                      <ui:Button x:Name="NewServerButton" Grid.Column="4" Content="Create" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Add24}" Click="OnCreateServer" />
                    </Grid>
                    <TextBlock x:Name="NewServerStatus" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </ui:Card>

                <!-- Instances list -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Instances" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <ui:Button Grid.Column="1" Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefreshServers" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Servers}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,8" Padding="12" CornerRadius="6"
                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <!-- active marker -->
                              <TextBlock Grid.Column="0" Text="●" Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"
                                         Foreground="{DynamicResource SystemAccentColorSecondaryBrush}">
                                <TextBlock.Visibility>
                                  <MultiBinding Converter="{StaticResource StringMatchVis}">
                                    <Binding Path="Name" />
                                    <Binding Path="DataContext.ActivePreset"
                                             RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                  </MultiBinding>
                                </TextBlock.Visibility>
                              </TextBlock>
                              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Dir}" FontSize="11" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                              </StackPanel>
                              <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Primary: Use (activate). Everything else under the ⋯ menu. -->
                                <ui:Button Content="Use" Appearance="Primary" Icon="{ui:SymbolIcon Checkmark24}"
                                           ToolTip="Make this the active server instance"
                                           Tag="{Binding Name}" Click="OnUseServer" Margin="0,0,8,0" />
                                <ui:DropDownButton Icon="{ui:SymbolIcon MoreHorizontal24}" ToolTip="More actions">
                                  <ui:DropDownButton.Flyout>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                      <MenuItem Header="Settings…" Tag="{Binding Name}" Click="OnOpenServerSettings">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Settings24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <MenuItem Header="Mods…" Tag="{Binding Name}" Click="OnOpenServerMods">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Apps24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <Separator />
                                      <MenuItem Header="Open folder" Tag="{Binding Dir}" Click="OnOpenServerFolder">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <MenuItem Header="Open in editor" Tag="{Binding Dir}" Click="OnOpenInEditor">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Code24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <Separator />
                                      <MenuItem Header="Wipe persistence" Tag="{Binding Dir}" Click="OnWipeServerPersistence">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Broom24" /></MenuItem.Icon>
                                      </MenuItem>
                                      <MenuItem Header="Delete instance" Tag="{Binding Name}" Click="OnDeleteServer">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Delete24" /></MenuItem.Icon>
                                      </MenuItem>
                                    </ContextMenu>
                                  </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(no server instances yet — create one above)" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Servers.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== BASES (templates) ===== -->
          <Grid x:Name="PageBases" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
              <TextBlock Text="Bases" FontSize="20" FontWeight="SemiBold" />
              <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                         Text="Reusable server templates — serverDZ.cfg + mpmissions you can build once and create new instances from (instead of the raw DayZ install). Snapshot the install (versioned) or make your own." />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- New base -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="New base" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="NewBaseNameBox" Grid.Column="0" Margin="0,0,8,0"
                                  PlaceholderText="base name (letters, digits, _)" />
                      <ComboBox x:Name="NewBaseMapBox" Grid.Column="1" Width="120" Margin="0,0,8,0"
                                VerticalAlignment="Center" ItemsSource="{Binding Maps}" SelectedIndex="0" />
                      <ui:Button Grid.Column="2" Content="From DayZ install" Appearance="Primary"
                                 Icon="{ui:SymbolIcon ArrowDownload24}" Margin="0,0,8,0" Click="OnCreateBaseFromInstall" />
                      <ui:Button Grid.Column="3" Content="Empty" Icon="{ui:SymbolIcon DocumentAdd24}" Click="OnCreateEmptyBase" />
                    </Grid>
                    <TextBlock x:Name="NewBaseStatus" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </ui:Card>

                <!-- Bases list -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Bases" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <ui:Button Grid.Column="1" Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefreshBases" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Bases}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,8" Padding="12" CornerRadius="6"
                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                  <Run Text="{Binding Source, Mode=OneWay}" /><Run Text="  " /><Run Text="{Binding Mission, Mode=OneWay}" /><Run Text="  " /><Run Text="{Binding DayzVersion, Mode=OneWay}" />
                                </TextBlock>
                              </StackPanel>
                              <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open base folder"
                                         Tag="{Binding Name}" Click="OnOpenBaseFolder" VerticalAlignment="Center" Margin="0,0,8,0" />
                              <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger" ToolTip="Delete base"
                                         Tag="{Binding Name}" Click="OnDeleteBase" VerticalAlignment="Center" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(no bases yet — create one above)" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Bases.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== ECONOMY (types.xml editor) ===== -->
          <Grid x:Name="PageEconomy" Visibility="Collapsed">
            <Grid.InputBindings>
              <KeyBinding Modifiers="Control" Key="Z" Command="{Binding UndoTypesCommand}" />
              <KeyBinding Modifiers="Control" Key="Y" Command="{Binding RedoTypesCommand}" />
            </Grid.InputBindings>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header + actions -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
              <TextBlock Text="Economy — types.xml" FontSize="20" FontWeight="SemiBold" />
              <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                         Text="{Binding TypesFile}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Toolbar: filter + undo/redo + add/remove/save/backups -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:TextBox x:Name="TypesFilterBox" Width="200" PlaceholderText="filter name…" Margin="0,0,8,0"
                            Text="{Binding TypesFilter, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox Width="150" Margin="0,0,8,0" VerticalAlignment="Center"
                          ItemsSource="{Binding TypeCategories}" SelectedItem="{Binding TypesCategoryFilter}"
                          ToolTip="Filter by category (blank = all)" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon ArrowUndo24}" ToolTip="Undo (Ctrl+Z)" Margin="0,0,4,0"
                           Command="{Binding UndoTypesCommand}" />
                <ui:Button Icon="{ui:SymbolIcon ArrowRedo24}" ToolTip="Redo (Ctrl+Y)" Margin="0,0,8,0"
                           Command="{Binding RedoTypesCommand}" />
                <ui:Button Content="Add" Icon="{ui:SymbolIcon Add24}" Margin="0,0,4,0" Click="OnAddType" />
                <ui:Button Content="Remove" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger" Margin="0,0,8,0" Click="OnRemoveTypes" />
                <ui:Button Content="Reload" Icon="{ui:SymbolIcon ArrowSync24}" Margin="0,0,4,0" Click="OnReloadTypes" />
                <ui:DropDownButton Content="Backups" Icon="{ui:SymbolIcon History24}" Margin="0,0,4,0">
                  <ui:DropDownButton.Flyout>
                    <ContextMenu x:Name="TypesBackupsMenu" />
                  </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
                <ui:Button Content="Save" Appearance="Primary" Icon="{ui:SymbolIcon Save24}" Click="OnSaveTypes" />
              </StackPanel>
            </Grid>

            <!-- Grid -->
            <DataGrid x:Name="TypesGrid" Grid.Row="2" ItemsSource="{Binding TypesView}"
                      AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      BeginningEdit="OnTypesBeginEdit" CellEditEnding="OnTypesCellEditEnding">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Nominal" Binding="{Binding Nominal}" Width="70" />
                <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="60" />
                <DataGridTextColumn Header="Lifetime" Binding="{Binding Lifetime}" Width="90" />
                <DataGridTextColumn Header="Restock" Binding="{Binding Restock}" Width="80" />
                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="60" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                <DataGridTextColumn Header="Usage" Binding="{Binding Usage}" Width="*" />
                <DataGridTextColumn Header="Tiers (value)" Binding="{Binding Value}" Width="*" />
              </DataGrid.Columns>
            </DataGrid>

            <!-- Batch bar + status -->
            <Grid Grid.Row="3" Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Batch on selected:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" />
                <ComboBox x:Name="BatchFieldBox" Width="100" Margin="0,0,8,0" VerticalAlignment="Center" SelectedIndex="0">
                  <ComboBoxItem Content="nominal" /><ComboBoxItem Content="min" />
                  <ComboBoxItem Content="lifetime" /><ComboBoxItem Content="restock" /><ComboBoxItem Content="cost" />
                </ComboBox>
                <ui:TextBox x:Name="BatchValueBox" Width="80" PlaceholderText="value" Margin="0,0,8,0" />
                <ui:Button Content="Set" Margin="0,0,4,0" Click="OnBatchSet" />
                <ui:Button Content="× Multiply" Click="OnBatchMultiply"
                           ToolTip="Multiply nominal/min by the value on selected rows" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding TypesStatus}" VerticalAlignment="Center"
                         HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Grid>
          </Grid>

          <!-- ===== LOGS ===== -->
          <Grid x:Name="PageLogs" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar: title, view-mode segmented control, log selector -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Logs" FontSize="20" FontWeight="SemiBold" />
                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                  <Run Text="server: " /><Run Text="{Binding ActivePreset, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
              </StackPanel>

              <!-- View-mode segmented control (grid/list/tabs/focus) -->
              <Border Grid.Column="1" HorizontalAlignment="Left" Margin="20,0,0,0"
                      CornerRadius="8" Padding="3"
                      Background="{DynamicResource ControlFillColorDefaultBrush}"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <StackPanel Orientation="Horizontal">
                  <RadioButton Style="{StaticResource LogsViewSegment}"
                               IsChecked="{Binding LogsViewMode, Converter={StaticResource StringEquals}, ConverterParameter=grid, Mode=OneWay}"
                               Command="{Binding SetLogsViewCommand}" CommandParameter="grid">
                    <StackPanel Orientation="Horizontal">
                      <ui:SymbolIcon Symbol="Grid24" FontSize="14" Margin="0,0,6,0" />
                      <TextBlock Text="Grid" />
                    </StackPanel>
                  </RadioButton>
                  <RadioButton Style="{StaticResource LogsViewSegment}"
                               IsChecked="{Binding LogsViewMode, Converter={StaticResource StringEquals}, ConverterParameter=list, Mode=OneWay}"
                               Command="{Binding SetLogsViewCommand}" CommandParameter="list">
                    <StackPanel Orientation="Horizontal">
                      <ui:SymbolIcon Symbol="AppsList24" FontSize="14" Margin="0,0,6,0" />
                      <TextBlock Text="List" />
                    </StackPanel>
                  </RadioButton>
                  <RadioButton Style="{StaticResource LogsViewSegment}"
                               IsChecked="{Binding LogsViewMode, Converter={StaticResource StringEquals}, ConverterParameter=tabs, Mode=OneWay}"
                               Command="{Binding SetLogsViewCommand}" CommandParameter="tabs">
                    <StackPanel Orientation="Horizontal">
                      <ui:SymbolIcon Symbol="TabDesktop24" FontSize="14" Margin="0,0,6,0" />
                      <TextBlock Text="Tabs" />
                    </StackPanel>
                  </RadioButton>
                  <RadioButton Style="{StaticResource LogsViewSegment}"
                               IsChecked="{Binding LogsViewMode, Converter={StaticResource StringEquals}, ConverterParameter=focus, Mode=OneWay}"
                               Command="{Binding SetLogsViewCommand}" CommandParameter="focus">
                    <StackPanel Orientation="Horizontal">
                      <ui:SymbolIcon Symbol="Maximize24" FontSize="14" Margin="0,0,6,0" />
                      <TextBlock Text="Focus" />
                    </StackPanel>
                  </RadioButton>
                </StackPanel>
              </Border>

              <!-- Log selector (drives Focus mode; quick-jump elsewhere) -->
              <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox MinWidth="120"
                          ItemsSource="{Binding LogPanes}"
                          DisplayMemberPath="Title"
                          SelectedItem="{Binding SelectedLogPane, Mode=TwoWay}" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
              <!-- GRID: explicit 2x2. ContentControls with *ContentAlignment=Stretch so each
                   pane fills its cell (ItemsControl+UniformGrid wouldn't stretch the cards;
                   the default ContentControl content alignment is Left/Top). Reorder lives in List. -->
              <Grid Visibility="{Binding LogsViewMode, Converter={StaticResource StringEqualsVis}, ConverterParameter=grid}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ContentControl Grid.Row="0" Grid.Column="0" Content="{Binding LogPanes[0]}"
                                ContentTemplate="{StaticResource LogPaneTemplate}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding LogPanes[1]}"
                                ContentTemplate="{StaticResource LogPaneTemplate}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                <ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding LogPanes[2]}"
                                ContentTemplate="{StaticResource LogPaneTemplate}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding LogPanes[3]}"
                                ContentTemplate="{StaticResource LogPaneTemplate}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
              </Grid>

              <!-- LIST: four height-sharing panes that exactly fill the page (NO outer scroll).
                   Expanded rows take an equal Star share of the remaining height; collapsed rows
                   shrink to their header (Auto). Toggling an expander recomputes the row heights
                   in code-behind (OnLogExpanderToggled → UpdateLogListRowHeights), so the still-
                   expanded panes grow to fill. Each body TextBox scrolls internally (LogTextBox
                   has VerticalScrollBarVisibility=Auto) and has no MinHeight, so it shrinks to its
                   bounded Star row and the inner scrollbar engages. Drag-reorder is intentionally
                   dropped here (explicit grid) — the fit-to-window layout takes precedence. -->
              <Grid x:Name="LogsListGrid"
                    Visibility="{Binding LogsViewMode, Converter={StaticResource StringEqualsVis}, ConverterParameter=list}">
                <Grid.RowDefinitions>
                  <RowDefinition x:Name="LogListRow0" Height="*" />
                  <RowDefinition x:Name="LogListRow1" Height="*" />
                  <RowDefinition x:Name="LogListRow2" Height="*" />
                  <RowDefinition x:Name="LogListRow3" Height="*" />
                </Grid.RowDefinitions>

                <ui:CardExpander x:Name="LogExp0" Grid.Row="0" DataContext="{Binding LogPanes[0]}"
                                 IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                 Expanded="OnLogExpanderToggled" Collapsed="OnLogExpanderToggled"
                                 Margin="0,0,0,8" VerticalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                  <ui:CardExpander.Header>
                    <Grid Margin="0,0,8,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                   Padding="6" Margin="0,0,6,0"
                                   Command="{Binding DataContext.OpenLogFolderCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                   Padding="6"
                                   Command="{Binding DataContext.ClearLogCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                      </StackPanel>
                    </Grid>
                  </ui:CardExpander.Header>
                  <Grid>
                    <TextBox Text="{Binding Text, Mode=OneWay}"
                             TextChanged="OnLogTextChanged"
                             Style="{StaticResource LogTextBox}" />
                  </Grid>
                </ui:CardExpander>

                <ui:CardExpander x:Name="LogExp1" Grid.Row="1" DataContext="{Binding LogPanes[1]}"
                                 IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                 Expanded="OnLogExpanderToggled" Collapsed="OnLogExpanderToggled"
                                 Margin="0,0,0,8" VerticalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                  <ui:CardExpander.Header>
                    <Grid Margin="0,0,8,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                   Padding="6" Margin="0,0,6,0"
                                   Command="{Binding DataContext.OpenLogFolderCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                   Padding="6"
                                   Command="{Binding DataContext.ClearLogCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                      </StackPanel>
                    </Grid>
                  </ui:CardExpander.Header>
                  <Grid>
                    <TextBox Text="{Binding Text, Mode=OneWay}"
                             TextChanged="OnLogTextChanged"
                             Style="{StaticResource LogTextBox}" />
                  </Grid>
                </ui:CardExpander>

                <ui:CardExpander x:Name="LogExp2" Grid.Row="2" DataContext="{Binding LogPanes[2]}"
                                 IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                 Expanded="OnLogExpanderToggled" Collapsed="OnLogExpanderToggled"
                                 Margin="0,0,0,8" VerticalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                  <ui:CardExpander.Header>
                    <Grid Margin="0,0,8,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                   Padding="6" Margin="0,0,6,0"
                                   Command="{Binding DataContext.OpenLogFolderCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                   Padding="6"
                                   Command="{Binding DataContext.ClearLogCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                      </StackPanel>
                    </Grid>
                  </ui:CardExpander.Header>
                  <Grid>
                    <TextBox Text="{Binding Text, Mode=OneWay}"
                             TextChanged="OnLogTextChanged"
                             Style="{StaticResource LogTextBox}" />
                  </Grid>
                </ui:CardExpander>

                <ui:CardExpander x:Name="LogExp3" Grid.Row="3" DataContext="{Binding LogPanes[3]}"
                                 IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                 Expanded="OnLogExpanderToggled" Collapsed="OnLogExpanderToggled"
                                 Margin="0,0,0,8" VerticalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                  <ui:CardExpander.Header>
                    <Grid Margin="0,0,8,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                   Padding="6" Margin="0,0,6,0"
                                   Command="{Binding DataContext.OpenLogFolderCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                   Padding="6"
                                   Command="{Binding DataContext.ClearLogCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                   CommandParameter="{Binding}" />
                      </StackPanel>
                    </Grid>
                  </ui:CardExpander.Header>
                  <Grid>
                    <TextBox Text="{Binding Text, Mode=OneWay}"
                             TextChanged="OnLogTextChanged"
                             Style="{StaticResource LogTextBox}" />
                  </Grid>
                </ui:CardExpander>
              </Grid>

              <!-- TABS: one tab per pane -->
              <TabControl ItemsSource="{Binding LogPanes}"
                          Background="Transparent" BorderThickness="0"
                          ContentTemplate="{StaticResource LogPaneTemplate}"
                          Visibility="{Binding LogsViewMode, Converter={StaticResource StringEqualsVis}, ConverterParameter=tabs}">
                <TabControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                  </DataTemplate>
                </TabControl.ItemTemplate>
              </TabControl>

              <!-- FOCUS: one big pane chosen by the selector -->
              <ContentControl Content="{Binding SelectedLogPane}"
                              ContentTemplate="{StaticResource LogPaneTemplate}"
                              HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                              Visibility="{Binding LogsViewMode, Converter={StaticResource StringEqualsVis}, ConverterParameter=focus}" />
            </Grid>
          </Grid>

          <!-- ===== TOOLS ===== -->
          <Grid x:Name="PageTools" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Tools" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
              <ui:Button Grid.Column="1" Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                         Click="OnRefreshTools" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- DayZ Tools catalog -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="DayZ Tools" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Tools}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Width="190" Height="58" Margin="0,0,8,8" Padding="12,8"
                                  HorizontalContentAlignment="Left"
                                  IsEnabled="{Binding Exists}"
                                  Opacity="{Binding Exists, Converter={StaticResource BoolToOpacity}}"
                                  Click="OnLaunchTool" Tag="{Binding}"
                                  ToolTip="{Binding ExePath}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                              <ui:SymbolIcon Symbol="Open24" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                              <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Kind}" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                              </StackPanel>
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ui:Card>

                <!-- Work drive -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                      <TextBlock Text="Work drive" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <local:InfoTip Text="{x:Static local:HelpText.WorkDrive}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                               Fill="{Binding WorkDriveMounted, Converter={StaticResource StatusDotConverter}}" />
                      <TextBlock Text="{Binding WorkDriveStatus}" VerticalAlignment="Center" Margin="0,0,16,0" />
                      <ui:Button Content="Mount" Appearance="Primary" Icon="{ui:SymbolIcon PlugConnected24}"
                                 Margin="0,0,8,0" Click="OnMountWorkDrive" />
                      <ui:Button Content="Unmount" Icon="{ui:SymbolIcon PlugDisconnected24}"
                                 Margin="0,0,8,0" Click="OnUnmountWorkDrive" />
                      <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefreshWorkDrive" />
                    </StackPanel>
                  </StackPanel>
                </ui:Card>

                <!-- Pack PBO -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Pack PBO" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PackSrcBox" Grid.Column="0" PlaceholderText="source folder…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="packsrc" Click="OnBrowseFolderInto" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PackDstBox" Grid.Column="0" PlaceholderText="output folder…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="packdst" Click="OnBrowseFolderInto" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PackPrefixBox" Grid.Column="0" Margin="0,0,4,0" PlaceholderText="prefix (optional)" />
                      <ui:TextBox x:Name="PackSignBox" Grid.Column="1" Margin="4,0,0,0" PlaceholderText="sign key path (optional)" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <ui:Button x:Name="PackButton" Content="Pack" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Box24}" Click="OnPackPbo" />
                      <TextBlock x:Name="PackToolMissing" Text="Addon Builder not found"
                                 VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"
                                 Foreground="#FF6B6B" />
                    </StackPanel>
                    <TextBox x:Name="PackOutput" Height="110" Style="{StaticResource ToolOutputBox}" />
                  </StackPanel>
                </ui:Card>

                <!-- Batch PAA -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                      <TextBlock Text="Batch PAA" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <local:InfoTip Text="{x:Static local:HelpText.GameData}" />
                    </StackPanel>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PaaDirBox" Grid.Column="0" PlaceholderText="image folder (png/tga)…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="paadir" Click="OnBrowseFolderInto" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <CheckBox x:Name="PaaRecursive" Content="Recursive" VerticalAlignment="Center" Margin="0,0,16,0" />
                      <ui:Button x:Name="PaaButton" Content="Convert" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Image24}" Click="OnConvertPaa" />
                      <TextBlock x:Name="PaaToolMissing" Text="ImageToPAA not found"
                                 VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"
                                 Foreground="#FF6B6B" />
                    </StackPanel>
                    <TextBox x:Name="PaaOutput" Height="110" Style="{StaticResource ToolOutputBox}" />
                  </StackPanel>
                </ui:Card>

                <!-- Unbinarize -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Unbinarize config.bin" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="BinFileBox" Grid.Column="0" PlaceholderText="config.bin file…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon DocumentSearch24}"
                                 Margin="8,0,0,0" Click="OnBrowseBinFile" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <ui:Button x:Name="UnbinButton" Content="Unbinarize" Appearance="Primary"
                                 Icon="{ui:SymbolIcon DocumentArrowDown24}" Click="OnUnbinarize" />
                      <TextBlock x:Name="UnbinToolMissing" Text="CfgConvert not found"
                                 VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"
                                 Foreground="#FF6B6B" />
                    </StackPanel>
                    <TextBox x:Name="UnbinOutput" Height="90" Style="{StaticResource ToolOutputBox}" />
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== SETTINGS ===== -->
          <Grid x:Name="PageSettings" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- Re-run the first-run environment wizard -->
                <ui:Button Content="Run setup wizard…" Icon="{ui:SymbolIcon Wand24}"
                           Appearance="Primary" Margin="0,0,0,12"
                           HorizontalAlignment="Left" Click="OnRunSetupWizard" />

                <!-- Settings are machine-global. Per-server settings (port, mission, mods, params)
                     live on the Servers page, under each server instance. -->

                <!-- Accounts -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Accounts" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="GitHub" FontWeight="SemiBold" VerticalAlignment="Center" Width="64" />
                      <TextBlock Grid.Column="1" Text="{Binding GhAccount}" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                      <ui:Button Grid.Column="2" Content="Login" Icon="{ui:SymbolIcon Person24}"
                                 Margin="0,0,8,0" Click="OnGitHubLogin"
                                 ToolTip="Runs 'gh auth login --web' in a terminal — browser OAuth, no keys to type" />
                      <ui:Button Grid.Column="3" Content="Logout" Click="OnGitHubLogout" />
                    </Grid>
                    <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="GitHub uses the gh CLI's browser OAuth — no token to paste. Publish/Release reuse this login." />

                    <Separator Margin="0,12,0,12" />

                    <TextBlock Text="Steam" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="No OAuth available. Workshop publish/download reuse your running Steam client (Publisher.exe / steamcmd) — no key needed. A Steam Web API key is only required for the Workshop search (SP5) and must be created on steamcommunity.com/dev/apikey; it can't be obtained via OAuth." />
                  </StackPanel>
                </ui:Card>

                <!-- Paths -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Paths" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <ui:Button Grid.Column="1" Content="Auto-detect" Icon="{ui:SymbolIcon ArrowSync24}"
                                 Click="OnDetectPaths" ToolTip="Find DayZ + DayZ Tools from your Steam libraries" />
                    </Grid>

                    <TextBlock Text="DayZ install" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgDayzPath" Grid.Column="0" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgDayzPath" Click="OnBrowseInto" />
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="DayZ Tools" Style="{StaticResource FieldLabel}" />
                      <local:InfoTip Text="{x:Static local:HelpText.WorkDrive}" />
                    </StackPanel>
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgDayzToolsPath" Grid.Column="0" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgDayzToolsPath" Click="OnBrowseInto" />
                    </Grid>

                    <TextBlock Text="Projects root (mod sources + server instances)" Style="{StaticResource FieldLabel}" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgProjectsRoot" Grid.Column="0"
                                  PlaceholderText="blank = %USERPROFILE%\DayZProjects" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgProjectsRoot" Click="OnBrowseInto" />
                    </Grid>
                  </StackPanel>
                </ui:Card>

                <!-- Executables -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Executables" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Server exe (debug)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgExeDebug" Margin="0,0,0,10" />
                        <TextBlock Text="Server exe (normal)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgExeNormal" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Client exe (debug)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgClientExeDebug" Margin="0,0,0,10" />
                        <TextBlock Text="Client exe (normal)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgClientExeNormal" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ui:Card>

                <!-- Scan roots -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Mod scan roots (one path per line)"
                                   FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <local:InfoTip Text="{x:Static local:HelpText.ScanRoots}" />
                      </StackPanel>
                      <ui:Button Grid.Column="1" Content="Add folder…" Icon="{ui:SymbolIcon FolderAdd24}"
                                 Click="OnAddScanRoot" />
                    </Grid>
                    <TextBox x:Name="CfgScanRoots" Height="90" AcceptsReturn="True"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" />
                  </StackPanel>
                </ui:Card>

                <!-- Automation -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                      <TextBlock Text="Automation" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <local:InfoTip Text="{x:Static local:HelpText.Automation}" />
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="CfgEnableAutomationServer"
                                     Content="Enable automation server (MCP / CLI control)" />
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                               Text="Lets the dzl CLI and the Claude MCP integration start/stop/inspect this server. Off = no background pipe. Takes effect on next launch." />
                  </StackPanel>
                </ui:Card>

                <!-- Work drive (P:) -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Work drive (P:)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                               Fill="{Binding WorkDriveMounted, Converter={StaticResource StatusDotConverter}}" />
                      <TextBlock Grid.Column="1" Text="{Binding WorkDriveStatus}" VerticalAlignment="Center" />
                      <ui:Button Grid.Column="2" Content="Mount" Margin="0,0,8,0" Click="OnMountWorkDrive" />
                      <ui:Button Grid.Column="3" Content="Unmount" Click="OnUnmountWorkDrive" />
                    </Grid>

                    <TextBlock Text="Work drive source folder (the always-live folder P: maps to)"
                               Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgWorkDriveSource" Grid.Column="0"
                                  PlaceholderText="blank = auto (from DayZ Tools settings.ini)" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgWorkDriveSource" Click="OnBrowseInto" />
                    </Grid>
                    <TextBlock FontSize="11" Opacity="0.7" Margin="0,0,0,8">
                      <Run Text="Resolved: " /><Run Text="{Binding ResolvedWorkDriveSource, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>

                    <ui:ToggleSwitch x:Name="CfgAutomountWorkDrive" Content="Mount P: automatically when dzl starts" />
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                               Text="P: is the DayZ Tools work drive — required to build mods (binarize resolves vanilla data + includes against P:). It can unmount between sessions; the bottom bar shows its live state." />
                  </StackPanel>
                </ui:Card>

                <!-- Signing -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Signing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Signing key name (one key signs all your mods)" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgSigningKey" Grid.Column="0"
                                  PlaceholderText="blank = your author handle" />
                      <ui:Button Grid.Column="1" Content="Generate key" Margin="8,0,0,0" Click="OnGenerateKey" />
                    </Grid>
                    <TextBlock FontSize="11" Opacity="0.7" Margin="0,0,0,10">
                      <Run Text="Resolved key: " /><Run Text="{Binding ResolvedSigningKey, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Text="Keys folder (.biprivatekey / .bikey)" Style="{StaticResource FieldLabel}" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgKeysDir" Grid.Column="0"
                                  PlaceholderText="blank = &lt;ProjectsRoot&gt;\keys" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgKeysDir" Click="OnBrowseInto" />
                    </Grid>
                    <TextBlock FontSize="11" Opacity="0.7" Margin="0,2,0,0">
                      <Run Text="Resolved folder: " /><Run Text="{Binding ResolvedKeysDir, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock x:Name="SigningStatus" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                               Text="The private key never ships/commits; the public .bikey is copied into each signed mod's keys\ folder so servers can whitelist it. Generate once, then enable 'Sign' when building." />
                  </StackPanel>
                </ui:Card>

                <!-- Editor -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Code editor" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Editor launcher (opens mod + server folders via 'Open in editor')" Style="{StaticResource FieldLabel}" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgEditorPath" Grid.Column="0"
                                  PlaceholderText="e.g. cursor / code, or a full path to the editor exe" />
                      <ui:Button Grid.Column="1" Content="Detect" Icon="{ui:SymbolIcon ArrowSync24}" Margin="8,0,0,0" Click="OnDetectEditor" />
                      <ui:Button Grid.Column="2" Content="📁" Margin="8,0,0,0" Tag="file:CfgEditorPath" Click="OnBrowseInto" />
                    </Grid>
                    <TextBlock x:Name="EditorStatus" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                  </StackPanel>
                </ui:Card>

                <!-- Steam (Workshop) -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Steam (Workshop)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Style="{StaticResource FieldLabel}">
                      <Run Text="Steam Web API key (Workshop search — get one at " /><Hyperlink
                          NavigateUri="https://steamcommunity.com/dev/apikey"
                          RequestNavigate="OnNavigateLink">steamcommunity.com/dev/apikey</Hyperlink><Run Text=")" />
                    </TextBlock>
                    <ui:TextBox x:Name="CfgSteamApiKey" Margin="0,0,0,10" PlaceholderText="blank = search disabled" />
                    <TextBlock Text="steamcmd.exe (Workshop download)" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,4">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgSteamCmdPath" Grid.Column="0" PlaceholderText="path to steamcmd.exe (or click Install)" />
                      <ui:Button Grid.Column="1" Content="Install" Icon="{ui:SymbolIcon ArrowDownload24}" Margin="8,0,0,0"
                                 Click="OnInstallSteamCmd" ToolTip="Download + set up steamcmd automatically" />
                      <ui:Button Grid.Column="2" Content="📁" Margin="8,0,0,0" Tag="file:CfgSteamCmdPath" Click="OnBrowseInto" />
                    </Grid>
                    <TextBlock x:Name="SteamCmdStatus" FontSize="11" Margin="0,0,0,10"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="Steam login (for owned/DayZ items; blank = anonymous)" Style="{StaticResource FieldLabel}" />
                    <ui:TextBox x:Name="CfgSteamLogin" PlaceholderText="steam username (password / Guard entered in the steamcmd console)" />
                  </StackPanel>
                </ui:Card>

                <!-- Save config -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                  <ui:Button Content="Save config" Appearance="Primary" Icon="{ui:SymbolIcon Save24}"
                             Click="OnSaveConfig" />
                  <ui:Button Content="Revert" Icon="{ui:SymbolIcon ArrowUndo24}" Margin="8,0,0,0"
                             Click="OnRevertConfig" />
                  <TextBlock x:Name="ConfigError" VerticalAlignment="Center" Margin="12,0,0,0"
                             Foreground="#FF6B6B" Visibility="Collapsed" />
                </StackPanel>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== MCP =====
               Setup guide for wiring Claude Code to the dzl stdio MCP server. Only reachable
               when the automation server is running (the nav item binds ShowMcpTab). -->
          <Grid x:Name="PageMcp" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
              <TextBlock Text="MCP integration" FontSize="20" FontWeight="SemiBold" />
              <TextBlock TextWrapping="Wrap" FontSize="12"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                         Text="Let Claude Code drive dzl in natural language — start/stop the server, read logs, switch profiles, pack PBOs and more." />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,14,0">

                <!-- Register in Claude Code -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Register in Claude Code" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.Column="0" CornerRadius="4" Padding="10"
                              Background="{DynamicResource ControlFillColorDefaultBrush}"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                        <TextBox Text="{Binding McpRegisterCommand, Mode=OneWay}" IsReadOnly="True"
                                 BorderThickness="0" Background="Transparent"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                 TextWrapping="Wrap" VerticalAlignment="Center" />
                      </Border>
                      <ui:Button Grid.Column="1" Content="Copy" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Copy24}" Margin="8,0,0,0"
                                 VerticalAlignment="Center"
                                 Command="{Binding CopyMcpCommandCommand}" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                               Text="Run this in a terminal, then restart Claude Code. The Dzl.Mcp project must be built (or published) first." />
                  </StackPanel>
                </ui:Card>

                <!-- Tools -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Tools" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock FontSize="12" Margin="0,0,0,10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Actions Claude can call once dzl is registered." />
                    <ItemsControl ItemsSource="{Binding McpTools}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" Margin="0,2"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="13" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ui:Card>

                <!-- Note -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info24" FontSize="18" Margin="0,2,10,0"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" MaxWidth="640"
                               HorizontalAlignment="Left"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Enable the automation server (Settings → Automation) so actions from Claude show live in this window. MCP also works without it (it drives the launcher through the shared config/state)." />
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

      </Grid>
    </Grid>

    <!-- ===== Bottom status bar (app-wide): live P: work-drive state + quick mount ===== -->
    <Border Grid.Row="3" Padding="12,4" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            Background="{DynamicResource ControlFillColorDefaultBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0"
                 Fill="{Binding WorkDriveMounted, Converter={StaticResource StatusDotConverter}}" />
        <TextBlock Grid.Column="1" Text="{Binding WorkDriveStatus}" VerticalAlignment="Center"
                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ui:Button Grid.Column="3" Content="Mount P:" Padding="8,2" FontSize="12"
                   Click="OnMountWorkDrive"
                   Visibility="{Binding WorkDriveMounted, Converter={StaticResource InverseBoolToVis}}" />
      </Grid>
    </Border>
  </Grid>
</ui:FluentWindow>
