<ui:FluentWindow x:Class="Dzl.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dzl.Tray"
        xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
        xmlns:views="clr-namespace:Dzl.Tray.Views"
        xmlns:vm="clr-namespace:Dzl.Tray.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="DayZ Labs (DZL)"
        MinWidth="1100" MinHeight="720"
        Width="1240" Height="800"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- title bar -->
      <RowDefinition Height="Auto" />  <!-- top action bar -->
      <RowDefinition Height="*" />     <!-- nav + content -->
      <RowDefinition Height="Auto" />  <!-- bottom status bar -->
    </Grid.RowDefinitions>
    <Grid.Resources>
      <!-- Shared converters (BoolToVis/InverseBoolToVis/BoolToOpacity/StringEquals*/NotNullToVis/
           NullToVis/StatusDotConverter/FlagBrush) now live in App.xaml's merged Resources/Converters.xaml
           at app scope, so they resolve here and in every UserControl. -->

      <!-- ===== Nav rail (plain-WPF ListBox; deterministic page switching) ===== -->
      <!-- A transparent ListBox whose items are pill-shaped rows with an icon + label.
           IsSelected drives an accent-tinted background; IsMouseOver a subtle hover.
           Used by both NavTop and NavBottom so they look like one continuous rail. -->
      <Style x:Key="NavListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      </Style>

      <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ListBoxItem">
              <Border x:Name="Bd" CornerRadius="6" Padding="12,8" Margin="4,2"
                      Background="Transparent">
                <ContentPresenter VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#332D7DD2" />
                  <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                  <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Settings field label. -->
      <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      </Style>

    </Grid.Resources>

    <!-- ============ TITLE BAR ============ -->
    <ui:TitleBar Grid.Row="0" Title="DayZ Labs (DZL)" Height="30" Margin="0">
      <ui:TitleBar.Icon>
        <ui:SymbolIcon Symbol="Gauge24" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>

    <!-- ============ TOP ACTION BAR ============ -->
    <Border Grid.Row="1" Padding="16,8"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />  <!-- mode toggle -->
          <ColumnDefinition Width="Auto" />  <!-- profile -->
          <ColumnDefinition Width="*" />     <!-- spacer -->
          <ColumnDefinition Width="Auto" />  <!-- status pills -->
        </Grid.ColumnDefinitions>

        <!-- Mode toggle: debug | normal (the app icon/name live in the title bar above) -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
          <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <ui:ToggleSwitch IsChecked="{Binding IsNormalMode, Mode=OneWay}"
                           Click="OnModeToggleClick"
                           OffContent="debug" OnContent="normal"
                           VerticalAlignment="Center" />
          <local:InfoTip Text="{x:Static local:HelpText.Mode}" />
        </StackPanel>

        <!-- Server quick switcher (manage on the Servers page) -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Server" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <ComboBox Width="180" VerticalAlignment="Center"
                    ToolTip="Switch active server instance (manage on the Servers page)"
                    ItemsSource="{Binding Presets}"
                    SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                    SelectionChanged="OnProfileSelectionChanged" />
        </StackPanel>

        <!-- Status pills: SERVER/CLIENT/MCP + P:/GitHub/Steam — the same control renders the
             status footer at the bottom, so both bars always show the same state. -->
        <ctl:StatusPills Grid.Column="3" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- ============ NAVIGATION + CONTENT ============ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />  <!-- left nav rail -->
        <ColumnDefinition Width="*" />     <!-- content -->
      </Grid.ColumnDefinitions>

      <!-- Left rail. Plain-WPF ListBox-based nav: deterministic page switching via
           SelectionChanged (the Wpf.Ui NavigationView is page-navigation oriented and
           swallowed clicks when used as a bare rail). Top sections + pinned Settings. -->
      <Border Grid.Column="0" Width="176"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}"
              Background="{DynamicResource ControlFillColorDefaultBrush}">
        <DockPanel LastChildFill="True">
          <!-- System group, pinned at the bottom: Setup (wizard), MCP (conditional), Settings. -->
          <ListBox x:Name="NavBottom" DockPanel.Dock="Bottom"
                   Style="{StaticResource NavListBox}"
                   ItemContainerStyle="{StaticResource NavListBoxItem}"
                   Margin="0,0,0,8"
                   SelectionChanged="OnNavChanged">
            <!-- Setup: not a page — selecting it opens the Setup Wizard (modal), then the rail
                 selection is restored to the previously-shown page (OnNavChanged). -->
            <ListBoxItem Tag="setup">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Wand24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Setup" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <!-- MCP setup guide: only shown when the automation server is running (ShowMcpTab). -->
            <ListBoxItem Tag="mcp" Visibility="{Binding ShowMcpTab, Converter={StaticResource BoolToVis}}">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="PlugConnected24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="MCP" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="settings">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="Settings" VerticalAlignment="Center" />
              </StackPanel>
            </ListBoxItem>
          </ListBox>

          <!-- Grouped sections: GENERAL (modding) vs SERVER (a server instance's content). -->
          <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <StackPanel>
              <TextBlock Text="GENERAL" FontSize="11" FontWeight="SemiBold" Opacity="0.55" Margin="14,2,0,4" />
              <ListBox x:Name="NavGeneral"
                       Style="{StaticResource NavListBox}"
                       ItemContainerStyle="{StaticResource NavListBoxItem}"
                       SelectionChanged="OnNavChanged">
                <ListBoxItem Tag="dashboard">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Gauge24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="mods">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Apps24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Mods" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="mymods">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="My Mods" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="tools">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Toolbox24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Tools" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
              </ListBox>

              <TextBlock Text="SERVER" FontSize="11" FontWeight="SemiBold" Opacity="0.55" Margin="14,14,0,4" />
              <ListBox x:Name="NavServer"
                       Style="{StaticResource NavListBox}"
                       ItemContainerStyle="{StaticResource NavListBoxItem}"
                       SelectionChanged="OnNavChanged">
                <ListBoxItem Tag="servers">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Server24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Servers" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="bases">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Layer24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Bases" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="economy">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Money24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Economy" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="logs">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="TextBulletListLtr24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Logs" VerticalAlignment="Center" />
                  </StackPanel>
                </ListBoxItem>
              </ListBox>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- Content host: five panels, one visible at a time (toggled in OnNavChanged → ShowPage). -->
      <Grid Grid.Column="1" Margin="16">

          <!-- ===== DASHBOARD =====
               Two target-scoped columns: LEFT = everything SERVER, RIGHT = everything CLIENT.
               Each column stacks control card → launch command → active mods → edit shortcuts. -->
          <views:DashboardView x:Name="PageDashboard" />

          <!-- ===== MODS (library) ===== -->
          <views:ModsView x:Name="PageMods" Visibility="Collapsed" />

          <!-- ===== MY MODS (source projects) ===== -->
          <views:MyModsView x:Name="PageMyMods" Visibility="Collapsed" />

          <!-- ===== SERVERS (instances) ===== -->
          <views:ServersView x:Name="PageServers" Visibility="Collapsed" />

          <!-- ===== BASES (templates) ===== -->
          <views:BasesView x:Name="PageBases" Visibility="Collapsed" />

          <!-- ===== LOGS ===== -->
          <views:LogsView x:Name="PageLogs" Visibility="Collapsed" />

          <!-- ===== TOOLS ===== -->
          <views:ToolsView x:Name="PageTools" Visibility="Collapsed" />

          <!-- ===== SETTINGS ===== -->
          <views:SettingsView x:Name="PageSettings" Visibility="Collapsed" />

          <!-- ===== MCP =====
               Setup guide for wiring Claude Code to the dzl stdio MCP server. Only reachable
               when the automation server is running (the nav item binds ShowMcpTab). -->
          <views:McpView x:Name="PageMcp" Visibility="Collapsed" />

      </Grid>
    </Grid>

    <!-- ===== Bottom status bar (app-wide): live P: work-drive state + quick mount ===== -->
    <Border Grid.Row="3" Padding="12,4" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            Background="{DynamicResource ControlFillColorDefaultBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ctl:StatusPills Grid.Column="0" Compact="True" VerticalAlignment="Center" />
        <ctl:ScreenshotButton Grid.Column="1" HorizontalAlignment="Right"
                              VerticalAlignment="Center" Margin="0,0,8,0" />
        <ui:Button Grid.Column="3" Content="Mount P:" Padding="8,2" FontSize="12"
                   Click="OnMountWorkDrive"
                   Visibility="{Binding WorkDriveMounted, Converter={StaticResource InverseBoolToVis}}" />
      </Grid>
    </Border>
  </Grid>
</ui:FluentWindow>
