<ui:FluentWindow x:Class="Dzl.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dzl.Tray"
        xmlns:vm="clr-namespace:Dzl.Tray.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="dzl — DayZ Dev Launcher"
        MinWidth="1100" MinHeight="720"
        Width="1240" Height="800"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- title bar -->
      <RowDefinition Height="Auto" />  <!-- top action bar -->
      <RowDefinition Height="*" />     <!-- nav + content -->
    </Grid.RowDefinitions>
    <Grid.Resources>
      <local:StatusDotConverter x:Key="StatusDotConverter" />
      <local:BoolToOpacityConverter x:Key="BoolToOpacity" />
      <BooleanToVisibilityConverter x:Key="BoolToVis" />

      <!-- Read-only monospace, dark, no-wrap log pane (script/rpt/adm/client). -->
      <Style x:Key="LogTextBox" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="IsReadOnlyCaretVisible" Value="False" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
      </Style>

      <!-- Small read-only mono output area for Tools (pack/paa/unbinarize results). -->
      <Style x:Key="ToolOutputBox" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
      </Style>

      <!-- Settings field label. -->
      <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      </Style>

      <!-- Dark Fluent-friendly DataGrid style: the stock WPF DataGrid renders light/grey,
           so we restyle row height, gridlines, header and selection to match the theme. -->
      <Style x:Key="DarkDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="Transparent" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="RowHeight" Value="32" />
        <Setter Property="ColumnHeaderHeight" Value="34" />
        <Setter Property="CanUserResizeRows" Value="False" />
      </Style>

      <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
      </Style>

      <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Style.Triggers>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
          </Trigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="DataGridCell">
              <Border Background="{TemplateBinding Background}" Padding="8,0">
                <ContentPresenter VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Grid.Resources>

    <!-- ============ TITLE BAR ============ -->
    <ui:TitleBar Grid.Row="0" Title="dzl — DayZ Dev Launcher" Margin="0">
      <ui:TitleBar.Icon>
        <ui:SymbolIcon Symbol="Gauge24" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>

    <!-- ============ TOP ACTION BAR ============ -->
    <Border Grid.Row="1" Padding="16,8"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />  <!-- app name -->
          <ColumnDefinition Width="Auto" />  <!-- mode toggle -->
          <ColumnDefinition Width="Auto" />  <!-- profile -->
          <ColumnDefinition Width="*" />     <!-- spacer -->
          <ColumnDefinition Width="Auto" />  <!-- status pills -->
        </Grid.ColumnDefinitions>

        <!-- App name -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
          <ui:SymbolIcon Symbol="Gauge24" FontSize="20" Margin="0,0,8,0"
                         Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
          <TextBlock Text="dzl" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Mode toggle: debug | normal -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
          <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <ui:ToggleSwitch IsChecked="{Binding IsNormalMode, Mode=OneWay}"
                           Click="OnModeToggleClick"
                           OffContent="debug" OnContent="normal"
                           VerticalAlignment="Center" />
        </StackPanel>

        <!-- Profile selector -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Profile" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <ComboBox Width="160" VerticalAlignment="Center"
                    ItemsSource="{Binding Presets}"
                    SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                    SelectionChanged="OnProfileSelectionChanged" />
          <ui:TextBox Width="130" Margin="8,0,0,0" VerticalAlignment="Center"
                      PlaceholderText="new name…"
                      Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="New preset name (blank = overwrite active)" />
          <ui:Button Margin="8,0,0,0" VerticalAlignment="Center"
                     Content="Save" Icon="{ui:SymbolIcon Save24}"
                     Command="{Binding SavePresetCommand}" />
        </StackPanel>

        <!-- Status pills -->
        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
          <!-- SERVER pill -->
          <Border CornerRadius="14" Padding="12,5" Margin="0,0,10,0"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding ServerUp, Converter={StaticResource StatusDotConverter}}" />
              <TextBlock Text="SERVER" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding ServerStatus}" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </Border>
          <!-- CLIENT pill -->
          <Border CornerRadius="14" Padding="12,5"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding ClientUp, Converter={StaticResource StatusDotConverter}}" />
              <TextBlock Text="CLIENT" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding ClientStatus}" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ============ NAVIGATION + CONTENT ============ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />  <!-- left nav rail -->
        <ColumnDefinition Width="*" />     <!-- content -->
      </Grid.ColumnDefinitions>

      <!-- Left rail. We drive content ourselves via panel-visibility swap (robust; no Page/DI plumbing). -->
      <ui:NavigationView x:Name="Nav" Grid.Column="0"
                         PaneDisplayMode="Left"
                         IsBackButtonVisible="Collapsed"
                         IsPaneToggleVisible="True"
                         OpenPaneLength="200"
                         SelectionChanged="OnNavSelectionChanged">
        <ui:NavigationView.MenuItems>
          <ui:NavigationViewItem Content="Dashboard" Tag="dashboard">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Gauge24" /></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Mods" Tag="mods">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Apps24" /></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Logs" Tag="logs">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="TextBulletListLtr24" /></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem Content="Tools" Tag="tools">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Toolbox24" /></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>
        <ui:NavigationView.FooterMenuItems>
          <ui:NavigationViewItem Content="Settings" Tag="settings">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Settings24" /></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.FooterMenuItems>
      </ui:NavigationView>

      <!-- Content host: five panels, one visible at a time (toggled in OnNavSelectionChanged). -->
      <Grid Grid.Column="1" Margin="16">

          <!-- ===== DASHBOARD ===== -->
          <Grid x:Name="PageDashboard">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Summary strip -->
            <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="16,12">
              <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,32,0">
                  <TextBlock Text="MODE" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding Mode}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                  <TextBlock Text="PORT" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding Port}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="ACTIVE PROFILE" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding ActivePreset}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </StackPanel>
            </ui:Card>

            <!-- Server + Client control cards -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- SERVER card -->
              <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="16">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ui:SymbolIcon Symbol="Server24" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Server" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                      <TextBlock Text="{Binding ServerStatus}" FontSize="11"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Start" Appearance="Success" Icon="{ui:SymbolIcon Play24}"
                               MinWidth="90" Margin="0,0,8,0" Command="{Binding StartServerCommand}" />
                    <ui:Button Content="Stop" Appearance="Danger" Icon="{ui:SymbolIcon Stop24}"
                               MinWidth="90" Margin="0,0,8,0" Command="{Binding StopServerCommand}" />
                    <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}"
                               MinWidth="90" Command="{Binding RestartServerCommand}" />
                  </StackPanel>
                </StackPanel>
              </ui:Card>

              <!-- CLIENT card -->
              <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="16">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ui:SymbolIcon Symbol="Desktop24" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Client" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                      <TextBlock Text="{Binding ClientStatus}" FontSize="11"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Start" Appearance="Success" Icon="{ui:SymbolIcon Play24}"
                               MinWidth="90" Margin="0,0,8,0" Command="{Binding StartClientCommand}" />
                    <ui:Button Content="Stop" Appearance="Danger" Icon="{ui:SymbolIcon Stop24}"
                               MinWidth="90" Margin="0,0,8,0" Command="{Binding StopClientCommand}" />
                    <ui:Button Content="Restart" Icon="{ui:SymbolIcon ArrowClockwise24}"
                               MinWidth="90" Command="{Binding RestartClientCommand}" />
                  </StackPanel>
                </StackPanel>
              </ui:Card>
            </Grid>

            <!-- Launch command preview -->
            <ui:Card Grid.Row="2" Padding="16">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Launch command" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                <TextBlock Grid.Row="1" Text="SERVER" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Border Grid.Row="2" CornerRadius="4" Padding="10" Margin="0,0,0,12"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                  <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                    <TextBox Text="{Binding ServerArgv, Mode=OneWay}" IsReadOnly="True"
                             BorderThickness="0" Background="Transparent"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12"
                             TextWrapping="Wrap" />
                  </ScrollViewer>
                </Border>

                <TextBlock Grid.Row="3" Text="CLIENT" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Border Grid.Row="4" CornerRadius="4" Padding="10"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                  <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                    <TextBox Text="{Binding ClientArgv, Mode=OneWay}" IsReadOnly="True"
                             BorderThickness="0" Background="Transparent"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12"
                             TextWrapping="Wrap" />
                  </ScrollViewer>
                </Border>
              </Grid>
            </ui:Card>
          </Grid>

          <!-- ===== MODS ===== -->
          <Grid x:Name="PageMods" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />  <!-- header + search -->
              <RowDefinition Height="Auto" />  <!-- toolbar -->
              <RowDefinition Height="*" />     <!-- grid -->
            </Grid.RowDefinitions>

            <!-- Header + search -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Mods" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ModsSummary}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              </StackPanel>
              <ui:TextBox Grid.Column="1" Width="260" VerticalAlignment="Center"
                          PlaceholderText="filter mods…"
                          Icon="{ui:SymbolIcon Search24}"
                          Text="{Binding ModFilter, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
              <ui:Button Content="Rescan" Icon="{ui:SymbolIcon ArrowSync24}"
                         Margin="0,0,8,0" Command="{Binding RescanCommand}" />
              <Border Width="1" Margin="4,2,12,2" Background="{DynamicResource ControlElevationBorderBrush}" />
              <ui:Button Icon="{ui:SymbolIcon ArrowUpload24}" ToolTip="Move to top"
                         Margin="0,0,8,0" Command="{Binding ToTopCommand}" />
              <ui:Button Icon="{ui:SymbolIcon ArrowUp24}" ToolTip="Move up"
                         Margin="0,0,8,0" Command="{Binding MoveUpCommand}" />
              <ui:Button Icon="{ui:SymbolIcon ArrowDown24}" ToolTip="Move down"
                         Margin="0,0,8,0" Command="{Binding MoveDownCommand}" />
              <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" ToolTip="Move to bottom"
                         Command="{Binding ToBottomCommand}" />
            </StackPanel>

            <!-- DataGrid -->
            <Border Grid.Row="2" CornerRadius="6" BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
              <DataGrid x:Name="ModsGrid"
                        Style="{StaticResource DarkDataGrid}"
                        ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                        RowStyle="{StaticResource DarkDataGridRow}"
                        CellStyle="{StaticResource DarkDataGridCell}"
                        ItemsSource="{Binding ModsView}"
                        SelectedItem="{Binding SelectedMod, Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        SelectionMode="Single"
                        SelectionUnit="FullRow"
                        IsReadOnly="False"
                        dd:DragDrop.IsDragSource="True"
                        dd:DragDrop.IsDropTarget="True"
                        dd:DragDrop.DropHandler="{Binding ModsDropHandler}">
                <DataGrid.Columns>
                  <!-- Enabled -->
                  <DataGridCheckBoxColumn Header="On" Width="44"
                                          Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  <!-- Load order # -->
                  <DataGridTextColumn Header="#" Width="40" IsReadOnly="True"
                                      Binding="{Binding Order}" />
                  <!-- Name (prominent) -->
                  <DataGridTextColumn Header="Name" Width="*" IsReadOnly="True"
                                      Binding="{Binding Name}">
                    <DataGridTextColumn.ElementStyle>
                      <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="FontWeight" Value="Medium" />
                      </Style>
                    </DataGridTextColumn.ElementStyle>
                  </DataGridTextColumn>
                  <!-- Side (inline edit) -->
                  <DataGridTemplateColumn Header="Side" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <ComboBox ItemsSource="{x:Static vm:MainViewModel.Sides}"
                                  SelectedItem="{Binding Side, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  BorderThickness="0" Background="Transparent"
                                  VerticalAlignment="Center" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- Path (dimmed) -->
                  <DataGridTextColumn Header="Path" Width="2*" IsReadOnly="True"
                                      Binding="{Binding Path}">
                    <DataGridTextColumn.ElementStyle>
                      <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                        <Setter Property="FontSize" Value="12" />
                      </Style>
                    </DataGridTextColumn.ElementStyle>
                  </DataGridTextColumn>
                  <!-- Missing badge -->
                  <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Border CornerRadius="9" Padding="8,2" Background="#5A1F1F"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Visibility="{Binding Missing, Converter={StaticResource BoolToVis}}">
                          <TextBlock Text="missing" FontSize="11" FontWeight="SemiBold"
                                     Foreground="#FF6B6B" />
                        </Border>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Border>
          </Grid>

          <!-- ===== LOGS ===== -->
          <Grid x:Name="PageLogs" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Logs" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <!-- 2×2 grid of live log panes -->
            <Grid Grid.Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- SCRIPT -->
              <ui:Card Grid.Row="0" Grid.Column="0" Margin="0,0,6,6" Padding="12">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                     Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                      <TextBlock Text="script" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <TextBlock Text="{Binding ScriptLogPath}" FontSize="11" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                 Padding="6" Margin="0,0,6,0" Tag="script" Click="OnOpenLogFolder" />
                      <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                 Padding="6" Tag="script" Click="OnClearLogView" />
                    </StackPanel>
                  </Grid>
                  <TextBox Grid.Row="1" x:Name="ScriptLogBox" Text="{Binding ScriptLog, Mode=OneWay}"
                           TextChanged="OnLogTextChanged"
                           Style="{StaticResource LogTextBox}" />
                </Grid>
              </ui:Card>

              <!-- RPT -->
              <ui:Card Grid.Row="0" Grid.Column="1" Margin="6,0,0,6" Padding="12">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                     Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                      <TextBlock Text="rpt" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <TextBlock Text="{Binding RptLogPath}" FontSize="11" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                 Padding="6" Margin="0,0,6,0" Tag="rpt" Click="OnOpenLogFolder" />
                      <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                 Padding="6" Tag="rpt" Click="OnClearLogView" />
                    </StackPanel>
                  </Grid>
                  <TextBox Grid.Row="1" x:Name="RptLogBox" Text="{Binding RptLog, Mode=OneWay}"
                           TextChanged="OnLogTextChanged"
                           Style="{StaticResource LogTextBox}" />
                </Grid>
              </ui:Card>

              <!-- ADM -->
              <ui:Card Grid.Row="1" Grid.Column="0" Margin="0,6,6,0" Padding="12">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                     Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                      <TextBlock Text="adm" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <TextBlock Text="{Binding AdmLogPath}" FontSize="11" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                 Padding="6" Margin="0,0,6,0" Tag="adm" Click="OnOpenLogFolder" />
                      <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                 Padding="6" Tag="adm" Click="OnClearLogView" />
                    </StackPanel>
                  </Grid>
                  <TextBox Grid.Row="1" x:Name="AdmLogBox" Text="{Binding AdmLog, Mode=OneWay}"
                           TextChanged="OnLogTextChanged"
                           Style="{StaticResource LogTextBox}" />
                </Grid>
              </ui:Card>

              <!-- CLIENT -->
              <ui:Card Grid.Row="1" Grid.Column="1" Margin="6,6,0,0" Padding="12">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                      <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,8,0"
                                     Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                      <TextBlock Text="client" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <TextBlock Text="{Binding ClientLogPath}" FontSize="11" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" ToolTip="Open log folder"
                                 Padding="6" Margin="0,0,6,0" Tag="client" Click="OnOpenLogFolder" />
                      <ui:Button Icon="{ui:SymbolIcon Eraser24}" ToolTip="Clear view"
                                 Padding="6" Tag="client" Click="OnClearLogView" />
                    </StackPanel>
                  </Grid>
                  <TextBox Grid.Row="1" x:Name="ClientLogBox" Text="{Binding ClientLog, Mode=OneWay}"
                           TextChanged="OnLogTextChanged"
                           Style="{StaticResource LogTextBox}" />
                </Grid>
              </ui:Card>
            </Grid>
          </Grid>

          <!-- ===== TOOLS ===== -->
          <Grid x:Name="PageTools" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Tools" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
              <ui:Button Grid.Column="1" Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                         Click="OnRefreshTools" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel>

                <!-- DayZ Tools catalog -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="DayZ Tools" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Tools}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Width="190" Height="58" Margin="0,0,8,8" Padding="12,8"
                                  HorizontalContentAlignment="Left"
                                  IsEnabled="{Binding Exists}"
                                  Opacity="{Binding Exists, Converter={StaticResource BoolToOpacity}}"
                                  Click="OnLaunchTool" Tag="{Binding}"
                                  ToolTip="{Binding ExePath}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                              <ui:SymbolIcon Symbol="Open24" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                              <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Kind}" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                              </StackPanel>
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ui:Card>

                <!-- Work drive -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Work drive" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                      <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                               Fill="{Binding WorkDriveMounted, Converter={StaticResource StatusDotConverter}}" />
                      <TextBlock Text="{Binding WorkDriveStatus}" VerticalAlignment="Center" Margin="0,0,16,0" />
                      <ui:Button Content="Mount" Appearance="Primary" Icon="{ui:SymbolIcon PlugConnected24}"
                                 Margin="0,0,8,0" Click="OnMountWorkDrive" />
                      <ui:Button Content="Unmount" Icon="{ui:SymbolIcon PlugDisconnected24}"
                                 Margin="0,0,8,0" Click="OnUnmountWorkDrive" />
                      <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefreshWorkDrive" />
                    </StackPanel>
                  </StackPanel>
                </ui:Card>

                <!-- Pack PBO -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Pack PBO" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PackSrcBox" Grid.Column="0" PlaceholderText="source folder…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="packsrc" Click="OnBrowseFolderInto" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PackDstBox" Grid.Column="0" PlaceholderText="output folder…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="packdst" Click="OnBrowseFolderInto" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PackPrefixBox" Grid.Column="0" Margin="0,0,4,0" PlaceholderText="prefix (optional)" />
                      <ui:TextBox x:Name="PackSignBox" Grid.Column="1" Margin="4,0,0,0" PlaceholderText="sign key path (optional)" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <ui:Button x:Name="PackButton" Content="Pack" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Box24}" Click="OnPackPbo" />
                      <TextBlock x:Name="PackToolMissing" Text="Addon Builder not found"
                                 VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"
                                 Foreground="#FF6B6B" />
                    </StackPanel>
                    <TextBox x:Name="PackOutput" Height="110" Style="{StaticResource ToolOutputBox}" />
                  </StackPanel>
                </ui:Card>

                <!-- Batch PAA -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Batch PAA" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="PaaDirBox" Grid.Column="0" PlaceholderText="image folder (png/tga)…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}"
                                 Margin="8,0,0,0" Tag="paadir" Click="OnBrowseFolderInto" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <CheckBox x:Name="PaaRecursive" Content="Recursive" VerticalAlignment="Center" Margin="0,0,16,0" />
                      <ui:Button x:Name="PaaButton" Content="Convert" Appearance="Primary"
                                 Icon="{ui:SymbolIcon Image24}" Click="OnConvertPaa" />
                      <TextBlock x:Name="PaaToolMissing" Text="ImageToPAA not found"
                                 VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"
                                 Foreground="#FF6B6B" />
                    </StackPanel>
                    <TextBox x:Name="PaaOutput" Height="110" Style="{StaticResource ToolOutputBox}" />
                  </StackPanel>
                </ui:Card>

                <!-- Unbinarize -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Unbinarize config.bin" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="BinFileBox" Grid.Column="0" PlaceholderText="config.bin file…" />
                      <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon DocumentSearch24}"
                                 Margin="8,0,0,0" Click="OnBrowseBinFile" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <ui:Button x:Name="UnbinButton" Content="Unbinarize" Appearance="Primary"
                                 Icon="{ui:SymbolIcon DocumentArrowDown24}" Click="OnUnbinarize" />
                      <TextBlock x:Name="UnbinToolMissing" Text="CfgConvert not found"
                                 VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"
                                 Foreground="#FF6B6B" />
                    </StackPanel>
                    <TextBox x:Name="UnbinOutput" Height="90" Style="{StaticResource ToolOutputBox}" />
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ===== SETTINGS ===== -->
          <Grid x:Name="PageSettings" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel>

                <!-- Paths -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Paths" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <TextBlock Text="DayZ install" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgDayzPath" Grid.Column="0" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgDayzPath" Click="OnBrowseInto" />
                    </Grid>

                    <TextBlock Text="DayZ Tools" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgDayzToolsPath" Grid.Column="0" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgDayzToolsPath" Click="OnBrowseInto" />
                    </Grid>

                    <TextBlock Text="Server profiles" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgProfilesPath" Grid.Column="0" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgProfilesPath" Click="OnBrowseInto" />
                    </Grid>

                    <TextBlock Text="Client profiles" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ui:TextBox x:Name="CfgClientProfilesPath" Grid.Column="0" />
                      <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="dir:CfgClientProfilesPath" Click="OnBrowseInto" />
                    </Grid>
                  </StackPanel>
                </ui:Card>

                <!-- Executables -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Executables" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Server exe (debug)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgExeDebug" Margin="0,0,0,10" />
                        <TextBlock Text="Server exe (normal)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgExeNormal" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Client exe (debug)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgClientExeDebug" Margin="0,0,0,10" />
                        <TextBlock Text="Client exe (normal)" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgClientExeNormal" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ui:Card>

                <!-- Server / connection -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Server &amp; connection" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Port" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgPort" Margin="0,0,0,10" />
                        <TextBlock Text="Mission" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgMission" Margin="0,0,0,10" />
                        <TextBlock Text="Config name" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgConfigName" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Player name" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgPlayerName" Margin="0,0,0,10" />
                        <TextBlock Text="Connect IP" Style="{StaticResource FieldLabel}" />
                        <ui:TextBox x:Name="CfgConnectIp" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ui:Card>

                <!-- Scan roots -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                  <StackPanel>
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Mod scan roots (one path per line)"
                                 FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <ui:Button Grid.Column="1" Content="Add folder…" Icon="{ui:SymbolIcon FolderAdd24}"
                                 Click="OnAddScanRoot" />
                    </Grid>
                    <TextBox x:Name="CfgScanRoots" Height="90" AcceptsReturn="True"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" />
                  </StackPanel>
                </ui:Card>

                <!-- Save config -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                  <ui:Button Content="Save config" Appearance="Primary" Icon="{ui:SymbolIcon Save24}"
                             Click="OnSaveConfig" />
                  <ui:Button Content="Revert" Icon="{ui:SymbolIcon ArrowUndo24}" Margin="8,0,0,0"
                             Click="OnRevertConfig" />
                  <TextBlock x:Name="ConfigError" VerticalAlignment="Center" Margin="12,0,0,0"
                             Foreground="#FF6B6B" Visibility="Collapsed" />
                </StackPanel>

                <!-- Launch params -->
                <ui:Card Margin="0,0,0,4" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Launch params" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                      <TextBlock Text="Target" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <ComboBox x:Name="ParamTarget" Width="120" SelectedIndex="0"
                                SelectionChanged="OnParamSlotChanged">
                        <ComboBoxItem Content="server" />
                        <ComboBoxItem Content="client" />
                      </ComboBox>
                      <TextBlock Text="Mode" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="16,0,8,0" />
                      <ComboBox x:Name="ParamMode" Width="120" SelectedIndex="0"
                                SelectionChanged="OnParamSlotChanged">
                        <ComboBoxItem Content="debug" />
                        <ComboBoxItem Content="normal" />
                      </ComboBox>
                    </StackPanel>
                    <TextBlock Text="One flag per line" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="ParamsEditor" Height="120" AcceptsReturn="True"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal">
                      <ui:Button Content="Save params" Appearance="Primary" Icon="{ui:SymbolIcon Save24}"
                                 Click="OnSaveParams" />
                      <ui:Button Content="Reset to defaults" Icon="{ui:SymbolIcon ArrowReset24}" Margin="8,0,0,0"
                                 Click="OnResetParams" />
                    </StackPanel>
                  </StackPanel>
                </ui:Card>

              </StackPanel>
            </ScrollViewer>
          </Grid>

      </Grid>
    </Grid>
  </Grid>
</ui:FluentWindow>
