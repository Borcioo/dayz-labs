<ui:FluentWindow x:Class="Dzl.Tray.BuildWindow"
        xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Build" Width="860" Height="700" MinWidth="640" MinHeight="520"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen">

  <Grid Margin="16,8,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- title -->
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- findings -->
      <RowDefinition Height="Auto" />  <!-- findings summary -->
      <RowDefinition Height="*" />     <!-- build log -->
      <RowDefinition Height="Auto" />  <!-- footer -->
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" x:Name="TitleBarCtl" Title="Build" ShowMaximize="False" ShowMinimize="False" Margin="0,0,0,8">
      <ui:TitleBar.TrailingContent>
        <ctl:ScreenshotButton VerticalAlignment="Stretch" />
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <!-- Toolbar -->
    <Grid Grid.Row="1" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <ui:Button Grid.Column="0" x:Name="PreflightBtn" Content="Preflight" Icon="{ui:SymbolIcon DocumentSearch24}"
                 ToolTip="Validate configs, references, paths and scripts without building" Margin="0,0,8,0" Click="OnPreflight" />
      <ui:Button Grid.Column="1" x:Name="BuildBtn" Content="Build" Appearance="Primary" Icon="{ui:SymbolIcon Box24}"
                 ToolTip="Preflight gate → AddonBuilder → verify → atomic publish" Click="OnBuild" />
      <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
        <CheckBox x:Name="CleanChk" Content="clean" ToolTip="Wipe AddonBuilder output first (-clear)" Margin="0,0,10,0" />
        <CheckBox x:Name="BinarizeChk" Content="binarize" IsChecked="True" ToolTip="Off = pack only (-packonly)" Margin="0,0,10,0" />
        <CheckBox x:Name="SignChk" Content="sign" ToolTip="Sign with your key + ship the .bikey" Margin="0,0,10,0" />
        <CheckBox x:Name="ForceChk" Content="force" ToolTip="Ignore the skip-unchanged cache" />
      </StackPanel>
    </Grid>

    <!-- Findings -->
    <Border Grid.Row="2" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
      <Grid>
        <TextBlock x:Name="FindingsHint" Text="Run Preflight to validate the mod before building."
                   Margin="12" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <ListBox x:Name="FindingsList" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="70" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="4" Padding="6,1" Margin="0,0,8,0"
                        VerticalAlignment="Top" Background="{Binding BadgeBg}">
                  <TextBlock Text="{Binding Severity}" FontSize="11" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Foreground="{Binding BadgeFg}" />
                </Border>
                <TextBlock Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center">
                  <Run Text="{Binding Rule, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="  " /><Run Text="{Binding Message, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Grid.Column="2" Text="{Binding Location}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <!-- Findings summary -->
    <TextBlock Grid.Row="3" x:Name="SummaryText" Margin="2,8,2,8" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

    <!-- Build log -->
    <Border Grid.Row="4" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
      <ui:TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                  FontFamily="Consolas" FontSize="11" BorderThickness="0"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
    </Border>

    <!-- Footer -->
    <Grid Grid.Row="5" Margin="0,10,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
      <ui:Button Grid.Column="1" Content="Open report" Icon="{ui:SymbolIcon Open24}" x:Name="ReportBtn"
                 IsEnabled="False" ToolTip="Open the saved preflight report (.txt)" Click="OnOpenReport" />
    </Grid>
  </Grid>
</ui:FluentWindow>
