<UserControl x:Class="Dzl.Tray.Controls.EventsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
  <!-- DataContext = EventsVm. Edits db/events.xml: master list of CE events (left) + scalar/flag/
       string/children detail of the selected event (right). Every edit routes through the VM →
       EventsService (snapshot + write, never throws). Per-tab undo/redo snapshots the whole file.
       A UserControl does NOT inherit the host window's resources at realize time — declare local
       styles here; only DynamicResource theme brushes (resolved late) are safe to reference. -->
  <UserControl.Resources>
    <Style x:Key="EvSectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="EvFieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style x:Key="EvHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- master + detail -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Save/Reload/Undo/Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="640" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read db/events.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Master (left) + detail (right) -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="300" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="3*" MinWidth="380" />
      </Grid.ColumnDefinitions>

      <!-- ===== Master: event list ===== -->
      <Border Grid.Column="0" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- title -->
            <RowDefinition Height="Auto" />   <!-- filter -->
            <RowDefinition Height="*" />      <!-- grid -->
            <RowDefinition Height="Auto" />   <!-- add row -->
            <RowDefinition Height="Auto" />   <!-- actions -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Events" Style="{StaticResource EvSectionHeader}" Margin="0,0,0,6" />

          <!-- Filter -->
          <ui:TextBox Grid.Row="1" Margin="0,0,0,6" FontSize="12" PlaceholderText="filter by name"
                      Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />

          <DataGrid Grid.Row="2" x:Name="EventGrid"
                    ItemsSource="{Binding Events}"
                    SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="True" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    RowBackground="Transparent" AlternatingRowBackground="Transparent">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="Nominal" Binding="{Binding Nominal}" Width="60" />
              <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="50" />
              <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="50" />
              <DataGridTextColumn Header="Lifetime" Binding="{Binding Lifetime}" Width="70" />
              <DataGridCheckBoxColumn Header="Active" Binding="{Binding Active}" Width="55" />
              <DataGridTextColumn Header="#child" Binding="{Binding ChildrenCount}" Width="50" />
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add event -->
          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new event name"
                        Text="{Binding NewEventName, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="OnAddEventKeyDown" />
            <ui:Button Grid.Column="1" Content="Add" Click="OnAddEventClick" />
          </Grid>

          <!-- Rename / Remove -->
          <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
            <ui:Button Content="Rename" Margin="0,0,4,0" FontSize="12" Click="OnRenameEventClick"
                       ToolTip="Rename the selected event" />
            <ui:Button Content="Remove" FontSize="12" Click="OnRemoveEventClick"
                       ToolTip="Remove the selected event and its children" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- ===== Detail: scalars + flags + children for the selected event ===== -->
      <Border Grid.Column="2" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <TextBlock Style="{StaticResource EvSectionHeader}" Margin="0,0,0,8"
                       Text="Event detail" />

            <!-- Scalars: two columns -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="90" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0 -->
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Nominal" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="0" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailNominal, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="nominal" />
              <TextBlock Grid.Row="0" Grid.Column="3" Text="SafeRadius" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="0" Grid.Column="4" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailSafeRadius, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="saferadius" />

              <!-- Row 1 -->
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="1" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailMin, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="min" />
              <TextBlock Grid.Row="1" Grid.Column="3" Text="DistanceRadius" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="1" Grid.Column="4" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailDistanceRadius, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="distanceradius" />

              <!-- Row 2 -->
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Max" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="2" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailMax, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="max" />
              <TextBlock Grid.Row="2" Grid.Column="3" Text="CleanupRadius" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="2" Grid.Column="4" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailCleanupRadius, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="cleanupradius" />

              <!-- Row 3 -->
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Lifetime" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="3" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                          Text="{Binding DetailLifetime, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="lifetime" />

              <!-- Row 4 -->
              <TextBlock Grid.Row="4" Grid.Column="0" Text="Restock" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,4" />
              <ui:TextBox Grid.Row="4" Grid.Column="1" FontSize="12"
                          Text="{Binding DetailRestock, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnScalarLostFocus" Tag="restock" />
            </Grid>

            <!-- String fields: Position + Limit -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="120" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="Position" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,0" />
              <ui:TextBox Grid.Column="1" FontSize="12"
                          Text="{Binding DetailPosition, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnPositionLostFocus" />

              <TextBlock Grid.Column="3" Text="Limit" Style="{StaticResource EvFieldLabel}" Margin="0,0,6,0" />
              <ui:TextBox Grid.Column="4" FontSize="12"
                          Text="{Binding DetailLimit, UpdateSourceTrigger=PropertyChanged}"
                          LostFocus="OnLimitLostFocus" />
            </Grid>

            <!-- Flags + Active -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <CheckBox Content="Active" IsChecked="{Binding DetailActive, Mode=TwoWay}"
                        Margin="0,0,16,0" Checked="OnActiveChanged" Unchecked="OnActiveChanged" />
              <CheckBox Content="Deletable" IsChecked="{Binding DetailDeletable, Mode=TwoWay}"
                        Margin="0,0,16,0" Checked="OnFlagChanged" Unchecked="OnFlagChanged" Tag="deletable" />
              <CheckBox Content="Init Random" IsChecked="{Binding DetailInitRandom, Mode=TwoWay}"
                        Margin="0,0,16,0" Checked="OnFlagChanged" Unchecked="OnFlagChanged" Tag="init_random" />
              <CheckBox Content="Remove Damaged" IsChecked="{Binding DetailRemoveDamaged, Mode=TwoWay}"
                        Checked="OnFlagChanged" Unchecked="OnFlagChanged" Tag="remove_damaged" />
            </StackPanel>

            <!-- Children grid -->
            <TextBlock Style="{StaticResource EvSectionHeader}" Margin="0,0,0,6" Text="Children" />

            <DataGrid x:Name="ChildGrid" MaxHeight="220"
                      ItemsSource="{Binding Children}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      IsReadOnly="False" SelectionMode="Single"
                      Background="Transparent" BorderThickness="0"
                      EnableRowVirtualization="True"
                      RowBackground="Transparent" AlternatingRowBackground="Transparent"
                      CellEditEnding="OnChildCellEditEnding">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Type" Binding="{Binding Type, UpdateSourceTrigger=LostFocus}" Width="*" />
                <DataGridTextColumn Header="Min"  Binding="{Binding MinText, UpdateSourceTrigger=LostFocus}" Width="55" />
                <DataGridTextColumn Header="Max"  Binding="{Binding MaxText, UpdateSourceTrigger=LostFocus}" Width="55" />
                <DataGridTextColumn Header="LootMin" Binding="{Binding LootMinText, UpdateSourceTrigger=LostFocus}" Width="65" />
                <DataGridTextColumn Header="LootMax" Binding="{Binding LootMaxText, UpdateSourceTrigger=LostFocus}" Width="65" />
                <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ui:Button Content="Remove" FontSize="11" Padding="6,2"
                                 Click="OnRemoveChildClick" Tag="{Binding}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

            <!-- Add child row -->
            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12"
                          PlaceholderText="child type (e.g. Animal_VulpesVulpes)"
                          Text="{Binding NewChildType, UpdateSourceTrigger=PropertyChanged}"
                          KeyDown="OnAddChildKeyDown" />
              <ui:TextBox Grid.Column="1" Margin="0,0,4,0" FontSize="12" ToolTip="min"
                          Text="{Binding NewChildMin, UpdateSourceTrigger=PropertyChanged}"
                          KeyDown="OnAddChildKeyDown" />
              <ui:TextBox Grid.Column="2" Margin="0,0,4,0" FontSize="12" ToolTip="max"
                          Text="{Binding NewChildMax, UpdateSourceTrigger=PropertyChanged}"
                          KeyDown="OnAddChildKeyDown" />
              <ui:TextBox Grid.Column="3" Margin="0,0,4,0" FontSize="12" ToolTip="lootmin"
                          Text="{Binding NewChildLootMin, UpdateSourceTrigger=PropertyChanged}"
                          KeyDown="OnAddChildKeyDown" />
              <ui:TextBox Grid.Column="4" Margin="0,0,4,0" FontSize="12" ToolTip="lootmax"
                          Text="{Binding NewChildLootMax, UpdateSourceTrigger=PropertyChanged}"
                          KeyDown="OnAddChildKeyDown" />
              <ui:Button Grid.Column="5" Content="Add child" Click="OnAddChildClick" />
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                    Background="Transparent" />
    </Grid>

    <!-- Status -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
