<UserControl x:Class="Dzl.Tray.Controls.EventsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:Dzl.Tray"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = EventsVm. Edits db/events.xml: master list of CE events (left) + scalar/flag/
       string/children detail of the selected event (right). Every edit routes through the VM →
       EventsService (snapshot + write, never throws). Per-tab undo/redo snapshots the whole file.
       A UserControl does NOT inherit the host window's resources at realize time — declare local
       styles here; only DynamicResource theme brushes (resolved late) are safe to reference. -->
  <UserControl.Resources>
    <conv:WidthToColumnsConverter x:Key="WidthToColumns" />
    <conv:ZeroCountToVisibilityConverter x:Key="ZeroToVis" />
    <Style x:Key="EvSectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="EvFieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style x:Key="EvHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>

    <!-- A grouped section card (matches the Spawnable Types editor's look). -->
    <Style x:Key="EvCard" TargetType="Border">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- A small "Info" glyph that carries an explanatory tooltip (for non-expert users). -->
    <Style x:Key="EvInfo" TargetType="ui:SymbolIcon">
      <Setter Property="Symbol" Value="Info24" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Margin" Value="6,0,0,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>

    <!-- One labelled numeric field (label stacked above the box). Used inside the property cards. -->
    <Style x:Key="EvNumLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,0,0,2" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <!-- BasedOn is REQUIRED: a local Style on a ui:* control without it discards the Fluent template,
         leaving a bare classic (white) TextBox — builds clean, only visible at runtime. -->
    <Style x:Key="EvNumBox" TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
      <Setter Property="FontSize" Value="12" />
      <!-- Every scalar field is a non-negative integer; reject non-digit keystrokes/pastes at the source. -->
      <Setter Property="ctl:NumericBehavior.IntegerOnly" Value="True" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- master + detail -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Save/Reload/Undo/Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="640" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ctl:GlossaryButton Title="Events" Entries="{x:Static help:Glossary.Events}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read db/events.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Master (left) + detail (right) -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="300" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="3*" MinWidth="380" />
      </Grid.ColumnDefinitions>

      <!-- ===== Master: event list ===== -->
      <Border Grid.Column="0" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- title -->
            <RowDefinition Height="Auto" />   <!-- filter -->
            <RowDefinition Height="*" />      <!-- grid -->
            <RowDefinition Height="Auto" />   <!-- add row -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Events" Style="{StaticResource EvSectionHeader}" Margin="0,0,0,6" />

          <!-- Filter -->
          <ui:TextBox Grid.Row="1" Margin="0,0,0,6" FontSize="12" PlaceholderText="filter by name"
                      Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />

          <DataGrid Grid.Row="2" x:Name="EventGrid"
                    ItemsSource="{Binding Events}"
                    SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                    Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="True" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="Nominal" Binding="{Binding Nominal}" Width="60" />
              <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="50" />
              <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="50" />
              <DataGridTextColumn Header="Lifetime" Binding="{Binding Lifetime}" Width="70" />
              <!-- Compact flags: active letters highlighted (A D I R) — same idea as the Types grid. -->
              <DataGridTemplateColumn Header="Flags" Width="Auto" MinWidth="74" IsReadOnly="True" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="A" FontSize="11" FontWeight="SemiBold" Margin="0,0,4,0" ToolTip="Active"
                                 Foreground="{Binding Active, Converter={StaticResource FlagBrush}}" />
                      <TextBlock Text="D" FontSize="11" FontWeight="SemiBold" Margin="0,0,4,0" ToolTip="Deletable"
                                 Foreground="{Binding Deletable, Converter={StaticResource FlagBrush}}" />
                      <TextBlock Text="I" FontSize="11" FontWeight="SemiBold" Margin="0,0,4,0" ToolTip="Init Random"
                                 Foreground="{Binding InitRandom, Converter={StaticResource FlagBrush}}" />
                      <TextBlock Text="R" FontSize="11" FontWeight="SemiBold" ToolTip="Remove Damaged"
                                 Foreground="{Binding RemoveDamaged, Converter={StaticResource FlagBrush}}" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="#child" Binding="{Binding ChildrenCount}" Width="50" />
              <!-- Per-row remove — consistent with the other CE tabs (icon action in the table). -->
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                               ToolTip="Remove this event and its children" Click="OnRowRemoveClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add event -->
          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new event name"
                        Text="{Binding NewEventName, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="OnAddEventKeyDown" />
            <ui:Button Grid.Column="1" Content="Add" Click="OnAddEventClick" />
          </Grid>
        </Grid>
      </Border>

      <!-- ===== Detail: scalars + flags + children for the selected event ===== -->
      <Border Grid.Column="2" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <!-- Header: inline rename of the selected event (Enter or the button commits — no modal). -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="Event name" Style="{StaticResource EvHint}" Margin="0,0,0,2" />
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Margin="0,0,6,0" FontSize="15" VerticalAlignment="Center"
                            IsEnabled="{Binding HasSelection}"
                            PlaceholderText="select an event from the list"
                            Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                            KeyDown="OnRenameKeyDown"
                            ToolTip="Rename the selected event (press Enter or click Rename to apply)" />
                <ui:Button Grid.Column="1" Content="Rename" IsEnabled="{Binding HasSelection}"
                           Click="OnRenameClick" />
              </Grid>
            </StackPanel>

            <!-- Spawn amounts + Timing: side by side on a wide pane, stacked when narrow -->
            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource WidthToColumns}}">
              <StackPanel Margin="0,0,5,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                  <TextBlock Text="Spawn amounts" Style="{StaticResource EvSectionHeader}" VerticalAlignment="Center" />
                  <ui:SymbolIcon Style="{StaticResource EvInfo}"
                                 ToolTip="Nominal = how many map LOCATIONS can host this event (the pool of spawn points), not a count of entities. Min/Max = active-spawn bounds: drops to Min → spawn more, hits Max → stop. So Nominal can exceed Max — they count different things." />
                </StackPanel>
                <Border Style="{StaticResource EvCard}">
                  <UniformGrid Columns="3">
                    <StackPanel Margin="0,0,8,0">
                      <TextBlock Text="Nominal" Style="{StaticResource EvNumLabel}" />
                      <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="nominal"
                                  Text="{Binding DetailNominal, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                      <TextBlock Text="Min" Style="{StaticResource EvNumLabel}" />
                      <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="min"
                                  Text="{Binding DetailMin, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="Max" Style="{StaticResource EvNumLabel}" />
                      <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="max"
                                  Text="{Binding DetailMax, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                  </UniformGrid>
                </Border>
              </StackPanel>

              <StackPanel Margin="5,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                  <TextBlock Text="Timing" Style="{StaticResource EvSectionHeader}" VerticalAlignment="Center" />
                  <ui:SymbolIcon Style="{StaticResource EvInfo}"
                                 ToolTip="Seconds. Lifetime = how long a spawn lives before despawning when no player is near; Restock = delay between individual respawns while refilling toward Nominal/Max." />
                </StackPanel>
                <Border Style="{StaticResource EvCard}">
                  <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,0">
                      <TextBlock Text="Lifetime" Style="{StaticResource EvNumLabel}" />
                      <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="lifetime"
                                  Text="{Binding DetailLifetime, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="Restock" Style="{StaticResource EvNumLabel}" />
                      <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="restock"
                                  Text="{Binding DetailRestock, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                  </UniformGrid>
                </Border>
              </StackPanel>
            </UniformGrid>

            <!-- Spacing radii -->
            <StackPanel Margin="0,0,0,10">
              <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Spacing radii" Style="{StaticResource EvSectionHeader}" VerticalAlignment="Center" />
                <ui:SymbolIcon Style="{StaticResource EvInfo}"
                               ToolTip="Metres. SafeRadius = won't spawn this close to a player (0 = may spawn on top of one); DistanceRadius = minimum gap between two of these events; CleanupRadius = how far every player must move before the despawn (Lifetime) timer starts." />
              </StackPanel>
              <Border Style="{StaticResource EvCard}">
                <UniformGrid Columns="3">
                  <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="SafeRadius" Style="{StaticResource EvNumLabel}" />
                    <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="saferadius"
                                Text="{Binding DetailSafeRadius, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>
                  <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="DistanceRadius" Style="{StaticResource EvNumLabel}" />
                    <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="distanceradius"
                                Text="{Binding DetailDistanceRadius, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="CleanupRadius" Style="{StaticResource EvNumLabel}" />
                    <ui:TextBox Style="{StaticResource EvNumBox}" LostFocus="OnScalarLostFocus" Tag="cleanupradius"
                                Text="{Binding DetailCleanupRadius, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>
                </UniformGrid>
              </Border>
            </StackPanel>

            <!-- Placement + Flags: side by side on a wide pane -->
            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource WidthToColumns}}">
              <StackPanel Margin="0,0,5,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                  <TextBlock Text="Placement" Style="{StaticResource EvSectionHeader}" VerticalAlignment="Center" />
                  <ui:SymbolIcon Style="{StaticResource EvInfo}"
                                 ToolTip="Position = where it spawns: fixed (coordinates from cfgeventspawns.xml) or player (near players). Limit = which Min/Max governs the count: child (child entries' min/max), parent (the event's own), custom (animal-territories file), or mixed." />
                </StackPanel>
                <Border Style="{StaticResource EvCard}">
                  <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,0">
                      <TextBlock Text="Position" Style="{StaticResource EvNumLabel}" />
                      <ComboBox FontSize="12" IsEditable="True"
                                Text="{Binding DetailPosition, UpdateSourceTrigger=PropertyChanged}"
                                LostFocus="OnPositionLostFocus"
                                ToolTip="fixed = spawn at the event's listed coordinates; player = spawn around players. Free text allowed.">
                        <ComboBoxItem Content="fixed" />
                        <ComboBoxItem Content="player" />
                      </ComboBox>
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="Limit" Style="{StaticResource EvNumLabel}" />
                      <ComboBox FontSize="12" IsEditable="True"
                                Text="{Binding DetailLimit, UpdateSourceTrigger=PropertyChanged}"
                                LostFocus="OnLimitLostFocus"
                                ToolTip="How the nominal limit is applied: custom / child / parent / mixed. Free text allowed.">
                        <ComboBoxItem Content="custom" />
                        <ComboBoxItem Content="child" />
                        <ComboBoxItem Content="parent" />
                        <ComboBoxItem Content="mixed" />
                      </ComboBox>
                    </StackPanel>
                  </UniformGrid>
                </Border>
              </StackPanel>

              <StackPanel Margin="5,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                  <TextBlock Text="Flags" Style="{StaticResource EvSectionHeader}" VerticalAlignment="Center" />
                  <ui:SymbolIcon Style="{StaticResource EvInfo}"
                                 ToolTip="On/off switches stored as event attributes." />
                </StackPanel>
                <Border Style="{StaticResource EvCard}">
                  <UniformGrid Columns="2">
                    <CheckBox Content="Active" Margin="0,0,0,6" IsChecked="{Binding DetailActive, Mode=TwoWay}"
                              Checked="OnActiveChanged" Unchecked="OnActiveChanged"
                              ToolTip="active=&quot;1&quot; — the event runs. Off parks it without deleting." />
                    <CheckBox Content="Deletable" Margin="0,0,0,6" IsChecked="{Binding DetailDeletable, Mode=TwoWay}"
                              Checked="OnFlagChanged" Unchecked="OnFlagChanged" Tag="deletable"
                              ToolTip="deletable — instances may be removed by the cleanup pass." />
                    <CheckBox Content="Init Random" IsChecked="{Binding DetailInitRandom, Mode=TwoWay}"
                              Checked="OnFlagChanged" Unchecked="OnFlagChanged" Tag="init_random"
                              ToolTip="init_random — randomise initial spawns on server start." />
                    <CheckBox Content="Remove Damaged" IsChecked="{Binding DetailRemoveDamaged, Mode=TwoWay}"
                              Checked="OnFlagChanged" Unchecked="OnFlagChanged" Tag="remove_damaged"
                              ToolTip="remove_damaged — clean up instances once they take damage." />
                  </UniformGrid>
                </Border>
              </StackPanel>
            </UniformGrid>

            <!-- Children -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <TextBlock Text="Children" Style="{StaticResource EvSectionHeader}" VerticalAlignment="Center" />
              <ui:SymbolIcon Style="{StaticResource EvInfo}"
                             ToolTip="The classnames this event spawns. Child Min/Max has two meanings: if Max=0, Min is a spawn WEIGHT (% split between children — convention: weights sum to 100); if Max&gt;0, Min/Max are a literal COUNT range spawned per child (e.g. vehicles 3-5). Loot min/max = loot slots filled on each spawn." />
              <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource EvHint}"
                         Text="{Binding Children.Count, StringFormat='· {0} added'}" />
            </StackPanel>
            <Border Style="{StaticResource EvCard}">
              <StackPanel>
                <TextBlock Text="No children yet — add one below." Style="{StaticResource EvHint}" Margin="0,0,0,4"
                           Visibility="{Binding Children.Count, Converter={StaticResource ZeroToVis}}" />

                <DataGrid x:Name="ChildGrid" MaxHeight="240"
                          ItemsSource="{Binding Children}"
                          Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          IsReadOnly="False" SelectionMode="Single"
                          Background="Transparent" BorderThickness="0"
                          EnableRowVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}"
                          CellEditEnding="OnChildCellEditEnding">
                  <!-- Numeric cells get an editing TextBox restricted to digits (the Type cell stays free text). -->
                  <DataGrid.Resources>
                    <Style x:Key="NumCellEdit" TargetType="TextBox">
                      <Setter Property="ctl:NumericBehavior.IntegerOnly" Value="True" />
                    </Style>
                  </DataGrid.Resources>
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type, UpdateSourceTrigger=LostFocus}" Width="*" />
                    <DataGridTextColumn Header="Min"  Binding="{Binding MinText, UpdateSourceTrigger=LostFocus}" Width="60"
                                        EditingElementStyle="{StaticResource NumCellEdit}" />
                    <DataGridTextColumn Header="Max"  Binding="{Binding MaxText, UpdateSourceTrigger=LostFocus}" Width="60"
                                        EditingElementStyle="{StaticResource NumCellEdit}" />
                    <DataGridTextColumn Header="Loot min" Binding="{Binding LootMinText, UpdateSourceTrigger=LostFocus}" Width="75"
                                        EditingElementStyle="{StaticResource NumCellEdit}" />
                    <DataGridTextColumn Header="Loot max" Binding="{Binding LootMaxText, UpdateSourceTrigger=LostFocus}" Width="75"
                                        EditingElementStyle="{StaticResource NumCellEdit}" />
                    <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                                     ToolTip="Remove this child" Click="OnRemoveChildClick" Tag="{Binding}" />
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>

                <!-- Divider + labelled add-child row (so the number boxes aren't a mystery) -->
                <Border Height="1" Margin="0,10,0,10" Background="{DynamicResource ControlElevationBorderBrush}" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Child type" Style="{StaticResource EvNumLabel}" Margin="0,0,4,2" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="Min" Style="{StaticResource EvNumLabel}" Margin="0,0,4,2" />
                  <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" Style="{StaticResource EvNumLabel}" Margin="0,0,4,2" />
                  <TextBlock Grid.Row="0" Grid.Column="3" Text="Loot min" Style="{StaticResource EvNumLabel}" Margin="0,0,4,2" />
                  <TextBlock Grid.Row="0" Grid.Column="4" Text="Loot max" Style="{StaticResource EvNumLabel}" Margin="0,0,4,2" />
                  <ui:TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,4,0" FontSize="12"
                              PlaceholderText="e.g. Animal_VulpesVulpes"
                              Text="{Binding NewChildType, UpdateSourceTrigger=PropertyChanged}"
                              KeyDown="OnAddChildKeyDown" />
                  <ui:TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,4,0" FontSize="12"
                              ctl:NumericBehavior.IntegerOnly="True"
                              Text="{Binding NewChildMin, UpdateSourceTrigger=PropertyChanged}"
                              KeyDown="OnAddChildKeyDown" />
                  <ui:TextBox Grid.Row="1" Grid.Column="2" Margin="0,0,4,0" FontSize="12"
                              ctl:NumericBehavior.IntegerOnly="True"
                              Text="{Binding NewChildMax, UpdateSourceTrigger=PropertyChanged}"
                              KeyDown="OnAddChildKeyDown" />
                  <ui:TextBox Grid.Row="1" Grid.Column="3" Margin="0,0,4,0" FontSize="12"
                              ctl:NumericBehavior.IntegerOnly="True"
                              Text="{Binding NewChildLootMin, UpdateSourceTrigger=PropertyChanged}"
                              KeyDown="OnAddChildKeyDown" />
                  <ui:TextBox Grid.Row="1" Grid.Column="4" Margin="0,0,4,0" FontSize="12"
                              ctl:NumericBehavior.IntegerOnly="True"
                              Text="{Binding NewChildLootMax, UpdateSourceTrigger=PropertyChanged}"
                              KeyDown="OnAddChildKeyDown" />
                  <ui:Button Grid.Row="1" Grid.Column="5" Content="Add child" Click="OnAddChildClick" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                    Background="Transparent" />
    </Grid>

    <!-- Status -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
