<UserControl x:Class="Dzl.Tray.Controls.MessagesEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = MessagesVm. Edits db/messages.xml: the server message scheduler. Routes through the VM →
       MessagesService (snapshot + write). Local styles only; app-scope InverseBoolToVis + theme brushes are safe. -->
  <UserControl.Resources>
    <Style x:Key="MsHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="MsLbl" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="420" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ui:Button Content="Add message" Icon="{ui:SymbolIcon Add24}" Margin="0,0,6,0" Click="OnAddClick" />
        <ctl:GlossaryButton Title="Messages" Entries="{x:Static help:Glossary.Messages}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick" ToolTip="Re-read db/messages.xml (discards undo)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo"><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo"><ui:SymbolIcon Symbol="ArrowRedo24" /></ui:Button>
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Style="{StaticResource MsHint}" Margin="2,0,0,8"
                   Text="Server broadcasts &amp; scheduled restart/shutdown. delay = minutes before first show, repeat = minutes between repeats (0 = once), deadline &gt; 0 = countdown, shutdown = stop the server when it ends. Placeholders: #name (server), #tmin (minutes left)." />

        <TextBlock Style="{StaticResource MsHint}" Margin="2,0,0,0"
                   Visibility="{Binding HasMessages, Converter={StaticResource InverseBoolToVis}}"
                   Text="No scheduled messages. Click &quot;Add message&quot;." />

        <ItemsControl ItemsSource="{Binding Messages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,8"
                      Background="{DynamicResource ControlFillColorDefaultBrush}"
                      BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                <StackPanel>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Margin="0,0,6,0" FontSize="13" PlaceholderText="message text (e.g. #name restarts in #tmin min)"
                                Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                LostFocus="OnFieldLostFocus" KeyDown="OnTextKeyDown" />
                    <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                               ToolTip="Remove this message" Click="OnRemoveClick" Tag="{Binding}" />
                  </Grid>
                  <WrapPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                      <TextBlock Text="delay" Style="{StaticResource MsLbl}" />
                      <ui:TextBox Width="56" FontSize="12" Text="{Binding DelayText, UpdateSourceTrigger=PropertyChanged}" LostFocus="OnFieldLostFocus" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                      <TextBlock Text="repeat" Style="{StaticResource MsLbl}" />
                      <ui:TextBox Width="56" FontSize="12" Text="{Binding RepeatText, UpdateSourceTrigger=PropertyChanged}" LostFocus="OnFieldLostFocus" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                      <TextBlock Text="deadline" Style="{StaticResource MsLbl}" />
                      <ui:TextBox Width="56" FontSize="12" Text="{Binding DeadlineText, UpdateSourceTrigger=PropertyChanged}" LostFocus="OnFieldLostFocus" />
                    </StackPanel>
                    <ui:ToggleSwitch Content="on connect" Margin="0,0,16,4" IsChecked="{Binding OnConnect, Mode=TwoWay}" />
                    <ui:ToggleSwitch Content="shutdown" Margin="0,0,0,4" IsChecked="{Binding Shutdown, Mode=TwoWay}" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,8,0,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
