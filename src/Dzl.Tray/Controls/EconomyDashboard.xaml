<UserControl x:Class="Dzl.Tray.Controls.EconomyDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=ctl:CeDashboardVm}">
  <!-- Economy dashboard: per-file stat tiles + an aggregated validation report. DataContext = CeDashboardVm. -->
  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- header -->
      <RowDefinition Height="Auto" />  <!-- stat tiles -->
      <RowDefinition Height="*" />     <!-- validation report -->
    </Grid.RowDefinitions>

    <!-- Header: mission context + actions -->
    <Grid Grid.Row="0" Margin="0,0,14,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" VerticalAlignment="Center">
        <TextBlock Text="Overview" FontSize="18" FontWeight="SemiBold" />
        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
          <TextBlock Text="{Binding MissionDir}" FontSize="12" TextTrimming="CharacterEllipsis"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Visibility="{Binding HasMission, Converter={StaticResource BoolToVis}}" />
          <TextBlock Text="No mission resolved for the active server."
                     FontSize="12" Foreground="#F0C04A"
                     Visibility="{Binding HasMission, Converter={StaticResource InverseBoolToVis}}" />
        </StackPanel>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:Button Content="Open mission folder" Icon="{ui:SymbolIcon FolderOpen24}" Margin="0,0,8,0"
                   Command="{Binding OpenMissionFolderCommand}"
                   Visibility="{Binding HasMission, Converter={StaticResource BoolToVis}}" />
        <ui:Button Content="Run full validation" Icon="{ui:SymbolIcon ClipboardCheckmark24}" Appearance="Primary"
                   Command="{Binding RunFullValidationCommand}" IsEnabled="{Binding CanValidate}" />
      </StackPanel>
    </Grid>

    <!-- Stat tiles -->
    <ItemsControl Grid.Row="1" ItemsSource="{Binding Stats}" Margin="0,0,14,12">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Width="180" Margin="0,0,10,10" Padding="14,12" CornerRadius="8" Cursor="Hand"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                  Opacity="{Binding Missing, Converter={StaticResource BoolToOpacity}, ConverterParameter=0.55}">
            <Border.InputBindings>
              <MouseBinding MouseAction="LeftClick"
                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Kind}" />
            </Border.InputBindings>
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <!-- Issue badge from the last full validation: red if any errors, else amber; hidden when 0. -->
                <Border Grid.Column="1" CornerRadius="9" Padding="6,1" VerticalAlignment="Center">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="#3A2A0F" />
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                          <Setter Property="Background" Value="#5A1F1F" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Issues}" Value="0">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding Issues}" FontSize="10" FontWeight="SemiBold">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#F0C04A" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasErrors}" Value="True">
                            <Setter Property="Foreground" Value="#FF6B6B" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Border>
              </Grid>
              <TextBlock Text="{Binding Value}" FontSize="26" FontWeight="SemiBold" Margin="0,2,0,0" />
              <TextBlock Text="{Binding Detail}" FontSize="11" TextTrimming="CharacterEllipsis"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Validation report -->
    <Border Grid.Row="2" Margin="0,0,14,0" Padding="16" CornerRadius="8"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Summary -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
          <TextBlock Text="Validation" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Summary}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Progress -->
        <ProgressBar Grid.Row="1" Height="4" Margin="0,0,0,8" Maximum="100" Value="{Binding Progress}"
                     Visibility="{Binding IsValidating, Converter={StaticResource BoolToVis}}" />

        <!-- Findings -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding Findings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,4" Padding="8,5" CornerRadius="4" Cursor="Hand"
                          Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <Border.InputBindings>
                      <MouseBinding MouseAction="LeftClick"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Kind}" />
                    </Border.InputBindings>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontWeight="Bold" Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#7FB0FF" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Severity}" Value="Error">
                                <Setter Property="Foreground" Value="#FF6B6B" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                <Setter Property="Foreground" Value="#F0C04A" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock Grid.Column="1" Text="{Binding Message}" TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <Run Text="{Binding Entry, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding File, Mode=OneWay}" />
                      </TextBlock>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="Click “Run full validation” to check every CE file and its cross-references."
                       FontSize="12" Margin="2,4,0,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Findings.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>
