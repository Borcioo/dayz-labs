<UserControl x:Class="Dzl.Tray.Controls.RandomPresetsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
  <!-- DataContext = RandomPresetsVm. Edits cfgrandompresets.xml: master list of cargo/attachments presets
       (left) + the item grid of the selected preset (right). Every edit routes through the VM →
       RandomPresetsService (snapshot + write, never throws). Per-tab undo/redo snapshots the whole file.
       A UserControl does NOT inherit the host window's resources at realize time — declare local styles
       here; only DynamicResource theme brushes (resolved late) are safe to reference. -->
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <Style x:Key="RpSectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="RpHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- master + detail -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Save/Reload/Undo/Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="640" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read cfgrandompresets.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Master (left) + detail (right) -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="320" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="3*" MinWidth="320" />
      </Grid.ColumnDefinitions>

      <!-- ===== Master: preset list ===== -->
      <Border Grid.Column="0" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title -->
            <RowDefinition Height="Auto" />  <!-- filter -->
            <RowDefinition Height="*" />     <!-- grid -->
            <RowDefinition Height="Auto" />  <!-- add row -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Presets" Style="{StaticResource RpSectionHeader}" Margin="0,0,0,6" />

          <!-- Filter -->
          <ui:TextBox Grid.Row="1" Margin="0,0,0,6" FontSize="12" PlaceholderText="filter by name"
                      Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />

          <DataGrid Grid.Row="2" x:Name="PresetGrid"
                    ItemsSource="{Binding Presets}"
                    SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="False" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    RowBackground="Transparent" AlternatingRowBackground="Transparent"
                    CellEditEnding="OnPresetCellEditEnding">
            <!-- No custom RowStyle on purpose: WPF-UI's DataGrid style drives the selected-row accent bar
                 via its own RowStyle setter, and an explicit RowStyle here overrides it (the accent vanishes).
                 The disabled (commented-out) state is shown per-cell instead — struck through + dimmed name. -->
            <DataGrid.Columns>
              <DataGridTextColumn Header="Kind" Binding="{Binding KindLabel}" IsReadOnly="True" Width="Auto">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                        <Setter Property="Opacity" Value="0.5" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True"
                                  Width="*" MinWidth="120">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                        <Setter Property="Opacity" Value="0.5" />
                        <Setter Property="TextDecorations" Value="Strikethrough" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Chance"
                                  Binding="{Binding ChanceText, UpdateSourceTrigger=LostFocus}"
                                  Width="80" MinWidth="60" />
              <DataGridTextColumn Header="#items" Binding="{Binding ItemCount}" IsReadOnly="True"
                                  Width="60" CanUserResize="False" />
              <!-- Per-row lint badge (amber when the preset has findings) -->
              <DataGridTemplateColumn Header="" Width="40" CanUserResize="False" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding LintGlyph}" Foreground="#F0C04A" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               ToolTip="{Binding LintTooltip}"
                               Visibility="{Binding HasLint, Converter={StaticResource BoolToVis}}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <!-- Per-row quick actions (fixed width so the buttons never get squeezed) -->
              <DataGridTemplateColumn Header="" Width="124" CanUserResize="False" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <ui:Button Content="{Binding ToggleLabel}" Padding="6,2" Margin="0,0,3,0" FontSize="11"
                                 MinWidth="34" Appearance="Secondary"
                                 ToolTip="{Binding ToggleTooltip}" Click="OnRowToggleDisabledClick" />
                      <ui:Button Icon="{ui:SymbolIcon Rename24}" Padding="5" Margin="0,0,3,0" FontSize="12"
                                 Appearance="Secondary" ToolTip="Rename this preset" Click="OnRowRenamePresetClick" />
                      <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12"
                                 Appearance="Danger" ToolTip="Remove this preset" Click="OnRowRemovePresetClick" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add preset -->
          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new preset name"
                        Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" />
            <ui:TextBox Grid.Column="1" Width="56" Margin="0,0,4,0" FontSize="12"
                        ToolTip="chance 0..1"
                        Text="{Binding NewPresetChance, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="2" MinWidth="110" Margin="0,0,4,0" VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="OnNewKindChanged" ToolTip="preset kind"
                      x:Name="NewKindCombo">
              <ComboBoxItem Content="cargo" />
              <ComboBoxItem Content="attachments" />
            </ComboBox>
            <ui:Button Grid.Column="3" Content="Add" Click="OnAddPresetClick" />
          </Grid>

        </Grid>
      </Border>

      <!-- ===== Detail: items of the selected preset ===== -->
      <Border Grid.Column="2" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- edit card -->
            <RowDefinition Height="Auto" />  <!-- title -->
            <RowDefinition Height="*" />     <!-- item grid -->
            <RowDefinition Height="Auto" />  <!-- add item row -->
            <RowDefinition Height="Auto" />  <!-- validation findings -->
          </Grid.RowDefinitions>

          <!-- ===== Edit preset: rename + change kind (cargo/attachments) ===== -->
          <Border Grid.Row="0" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                  Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="Edit preset" Style="{StaticResource RpSectionHeader}" Margin="0,0,0,6" />
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="preset name"
                            Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                            KeyDown="OnEditNameKeyDown" />
                <ComboBox Grid.Column="1" MinWidth="120" Margin="0,0,4,0" VerticalAlignment="Center"
                          SelectedIndex="{Binding EditKindIndex}" ToolTip="preset kind (cargo / attachments)">
                  <ComboBoxItem Content="cargo" />
                  <ComboBoxItem Content="attachments" />
                </ComboBox>
                <ui:Button Grid.Column="2" Content="Rename" Click="OnApplyRenameClick"
                           ToolTip="Apply the new name" />
              </Grid>
            </StackPanel>
          </Border>

          <TextBlock Grid.Row="1" Margin="0,0,0,6" Style="{StaticResource RpSectionHeader}"
                     Text="Items in the selected preset" />

          <DataGrid Grid.Row="2" x:Name="ItemGrid"
                    ItemsSource="{Binding Items}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="False" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    RowBackground="Transparent" AlternatingRowBackground="Transparent"
                    CellEditEnding="OnItemCellEditEnding">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Item name"
                                  Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                  Width="*" MinWidth="120" />
              <DataGridTextColumn Header="Chance"
                                  Binding="{Binding ChanceText, UpdateSourceTrigger=LostFocus}"
                                  Width="80" MinWidth="60" />
              <DataGridTemplateColumn Header="" Width="84" CanUserResize="False" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Content="Remove" FontSize="11" Padding="6,2" HorizontalAlignment="Center"
                               Click="OnRemoveItemClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add item -->
          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Editable autocomplete: substring-search item classnames from types.xml (free text still
                 allowed — preset items may reference classes outside the economy). We filter ItemSuggestions
                 in the VM, so the combo's own text-search is off. -->
            <ComboBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" x:Name="ItemNameCombo"
                      IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                      ItemsSource="{Binding ItemSuggestions}"
                      Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Type to search item classnames (from types.xml) — free text allowed"
                      KeyUp="OnItemComboKeyUp" SelectionChanged="OnItemComboSelectionChanged" />
            <ui:TextBox Grid.Column="1" Width="64" Margin="0,0,4,0" FontSize="12"
                        ToolTip="chance 0..1"
                        Text="{Binding NewItemChance, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="OnAddItemKeyDown" />
            <ui:Button Grid.Column="2" Content="Add item" Click="OnAddItemClick" />
          </Grid>

          <!-- ===== Per-page validation (chance ranges + unused presets) ===== -->
          <Border Grid.Row="4" Margin="0,10,0,0" CornerRadius="6" Padding="8" MaxHeight="180"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Findings.Count}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <ui:SymbolIcon Symbol="Warning24" Foreground="#F0C04A" Margin="0,0,6,0" />
                <TextBlock Text="Validation" Style="{StaticResource RpSectionHeader}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Findings.Count, StringFormat=' ({0})'}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              </StackPanel>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Findings}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,3" Background="Transparent" Cursor="Hand"
                            ToolTip="Jump to this preset in the list"
                            MouseLeftButtonUp="OnFindingClick">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontWeight="Bold" Margin="0,0,8,0"
                                   VerticalAlignment="Top">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="#7FB0FF" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Severity}" Value="Error">
                                  <Setter Property="Foreground" Value="#FF6B6B" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                  <Setter Property="Foreground" Value="#F0C04A" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12"
                                   VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                    Background="Transparent" />
    </Grid>

    <!-- Status -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
