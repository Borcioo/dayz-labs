<UserControl x:Class="Dzl.Tray.Controls.RandomPresetsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
  <!-- DataContext = RandomPresetsVm. Edits cfgrandompresets.xml: master list of cargo/attachments presets
       (left) + the item grid of the selected preset (right). Every edit routes through the VM →
       RandomPresetsService (snapshot + write, never throws). Per-tab undo/redo snapshots the whole file.
       A UserControl does NOT inherit the host window's resources at realize time — declare local styles
       here; only DynamicResource theme brushes (resolved late) are safe to reference. -->
  <UserControl.Resources>
    <Style x:Key="RpSectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="RpHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- master + detail -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Save/Reload/Undo/Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="640" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read cfgrandompresets.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Master (left) + detail (right) -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="320" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="3*" MinWidth="320" />
      </Grid.ColumnDefinitions>

      <!-- ===== Master: preset list ===== -->
      <Border Grid.Column="0" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title -->
            <RowDefinition Height="Auto" />  <!-- filter -->
            <RowDefinition Height="*" />     <!-- grid -->
            <RowDefinition Height="Auto" />  <!-- add row -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Presets" Style="{StaticResource RpSectionHeader}" Margin="0,0,0,6" />

          <!-- Filter -->
          <ui:TextBox Grid.Row="1" Margin="0,0,0,6" FontSize="12" PlaceholderText="filter by name"
                      Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />

          <DataGrid Grid.Row="2" x:Name="PresetGrid"
                    ItemsSource="{Binding Presets}"
                    SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="False" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    RowBackground="Transparent" AlternatingRowBackground="Transparent"
                    CellEditEnding="OnPresetCellEditEnding">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Kind" Binding="{Binding KindLabel}" IsReadOnly="True" Width="Auto" />
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*" />
              <DataGridTextColumn Header="Chance"
                                  Binding="{Binding ChanceText, UpdateSourceTrigger=LostFocus}"
                                  Width="80" />
              <DataGridTextColumn Header="#items" Binding="{Binding ItemCount}" IsReadOnly="True" Width="60" />
              <!-- Per-row quick actions -->
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <ui:Button Icon="{ui:SymbolIcon Rename24}" Padding="5" Margin="0,0,3,0" FontSize="12"
                                 Appearance="Secondary" ToolTip="Rename this preset" Click="OnRowRenamePresetClick" />
                      <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12"
                                 Appearance="Danger" ToolTip="Remove this preset" Click="OnRowRemovePresetClick" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add preset -->
          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new preset name"
                        Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" />
            <ui:TextBox Grid.Column="1" Width="56" Margin="0,0,4,0" FontSize="12"
                        ToolTip="chance 0..1"
                        Text="{Binding NewPresetChance, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="2" MinWidth="110" Margin="0,0,4,0" VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="OnNewKindChanged" ToolTip="preset kind"
                      x:Name="NewKindCombo">
              <ComboBoxItem Content="cargo" />
              <ComboBoxItem Content="attachments" />
            </ComboBox>
            <ui:Button Grid.Column="3" Content="Add" Click="OnAddPresetClick" />
          </Grid>

        </Grid>
      </Border>

      <!-- ===== Detail: items of the selected preset ===== -->
      <Border Grid.Column="2" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title -->
            <RowDefinition Height="*" />     <!-- item grid -->
            <RowDefinition Height="Auto" />  <!-- add item row -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Margin="0,0,0,6" Style="{StaticResource RpSectionHeader}"
                     Text="Items in the selected preset" />

          <DataGrid Grid.Row="1" x:Name="ItemGrid"
                    ItemsSource="{Binding Items}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="False" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    RowBackground="Transparent" AlternatingRowBackground="Transparent"
                    CellEditEnding="OnItemCellEditEnding">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Item name"
                                  Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Width="*" />
              <DataGridTextColumn Header="Chance"
                                  Binding="{Binding ChanceText, UpdateSourceTrigger=LostFocus}" Width="90" />
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Content="Remove" FontSize="11" Padding="6,2"
                               Click="OnRemoveItemClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add item -->
          <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12"
                        PlaceholderText="item classname (e.g. TunaCan)"
                        Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="OnAddItemKeyDown" />
            <ui:TextBox Grid.Column="1" Width="64" Margin="0,0,4,0" FontSize="12"
                        ToolTip="chance 0..1"
                        Text="{Binding NewItemChance, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="OnAddItemKeyDown" />
            <ui:Button Grid.Column="2" Content="Add item" Click="OnAddItemClick" />
          </Grid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                    Background="Transparent" />
    </Grid>

    <!-- Status -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
