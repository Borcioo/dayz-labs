<UserControl x:Class="Dzl.Tray.Controls.GlobalsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = GlobalsVm. Edits db/globals.xml: flat list of simulation vars (name, type, value).
       Every edit routes through the VM → GlobalsService (snapshot + write, never throws). Per-tab
       undo/redo snapshots the whole file. A UserControl does NOT inherit the host window's resources at
       realize time — declare local styles here; only DynamicResource theme brushes (resolved late) are
       safe to reference. -->
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="GlBoolToVis" />
    <Style x:Key="GlSectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="GlHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
    <Style x:Key="GlFieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,0,0,2" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style x:Key="GlCard" TargetType="Border">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="GlInfo" TargetType="ui:SymbolIcon">
      <Setter Property="Symbol" Value="Info24" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Margin" Value="6,0,0,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- master + detail -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Reload / Undo / Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="640" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <!-- Filter -->
        <ui:TextBox Width="180" Margin="0,0,8,0" FontSize="12"
                    PlaceholderText="filter vars…"
                    Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
        <ctl:GlossaryButton Title="Globals" Entries="{x:Static help:Glossary.Globals}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read globals.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Master (var list + add row) + detail (edit the selected var) — same shape as the other CE tabs. -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="340" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="1*" MinWidth="260" />
      </Grid.ColumnDefinitions>

      <!-- ===== Master: variable list ===== -->
      <Border Grid.Column="0" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title -->
            <RowDefinition Height="*" />     <!-- grid -->
            <RowDefinition Height="Auto" />  <!-- add var -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Simulation variables" Style="{StaticResource GlSectionHeader}" Margin="0,0,0,6" />

          <DataGrid Grid.Row="1" x:Name="VarsGrid"
                    ItemsSource="{Binding Rows}"
                    SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                    Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                    IsReadOnly="True" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0"
                    EnableRowVirtualization="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="160">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="ToolTip" Value="{Binding Tooltip}" />
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="Auto" MinWidth="56" />
              <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="Auto" MinWidth="80" />
              <!-- Per-row action: standard engine vars reset to default (not deletable); custom keys can be removed. -->
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <ui:Button Icon="{ui:SymbolIcon ArrowReset24}" Padding="5" FontSize="12"
                                 Visibility="{Binding IsKnown, Converter={StaticResource GlBoolToVis}}"
                                 ToolTip="Reset this variable to its engine default" Click="OnResetRowClick" Tag="{Binding}" />
                      <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                                 Visibility="{Binding IsCustom, Converter={StaticResource GlBoolToVis}}"
                                 ToolTip="Remove this custom variable" Click="OnRemoveRowClick" Tag="{Binding}" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Add a standard variable. globals.xml is a closed engine vocabulary, so you can't invent vars —
               only surface a documented one that isn't present yet (seeded with its engine default + type).
               When every standard var is already present the picker is empty + disabled. -->
          <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Add standard variable" VerticalAlignment="Center" Margin="0,0,8,0"
                       Style="{StaticResource GlHint}" />
            <ComboBox Grid.Column="1" Margin="0,0,6,0" FontSize="12"
                      ItemsSource="{Binding MissingKnown}" SelectedItem="{Binding SelectedMissing, Mode=TwoWay}"
                      IsEnabled="{Binding HasMissingKnown}"
                      ToolTip="A documented engine global not present in the file — added with its default value and fixed type." />
            <ui:Button Grid.Column="2" Content="Add" Icon="{ui:SymbolIcon Add24}"
                       IsEnabled="{Binding HasMissingKnown}" Click="OnAddKnownClick" />
          </Grid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />

      <!-- ===== Detail: edit the selected variable ===== -->
      <Border Grid.Column="2" CornerRadius="8" Padding="10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <!-- Header: inline rename of the selected var (Enter or the button commits). -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="Variable name" Style="{StaticResource GlHint}" Margin="0,0,0,2" />
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Margin="0,0,6,0" FontSize="15" VerticalAlignment="Center"
                            IsEnabled="{Binding CanEditIdentity}"
                            PlaceholderText="select a variable from the list"
                            Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                            KeyDown="OnRenameKeyDown"
                            ToolTip="Rename the selected variable (press Enter or click Rename to apply)" />
                <ui:Button Grid.Column="1" Content="Rename" IsEnabled="{Binding CanEditIdentity}"
                           Click="OnRenameClick" />
              </Grid>
              <TextBlock Margin="0,4,0,0" Style="{StaticResource GlHint}" TextWrapping="Wrap"
                         Visibility="{Binding SelectedIsKnown, Converter={StaticResource GlBoolToVis}}"
                         Text="Standard engine variable — its name and type are fixed. Edit the value, or reset it to default." />
            </StackPanel>

            <!-- Value card -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <TextBlock Text="Value" Style="{StaticResource GlSectionHeader}" VerticalAlignment="Center" />
              <ui:SymbolIcon Style="{StaticResource GlInfo}"
                             ToolTip="Numeric value for this simulation variable. Its meaning depends on the variable (a count, seconds, a distance, a 0/1 flag…). Type sets how it's written: int = whole number, float = decimal." />
            </StackPanel>
            <Border Style="{StaticResource GlCard}">
              <StackPanel>
                <TextBlock Text="Type" Style="{StaticResource GlFieldLabel}" />
                <ComboBox Margin="0,0,0,10" FontSize="12" IsEnabled="{Binding CanEditIdentity}"
                          SelectedIndex="{Binding DetailType, Mode=TwoWay}"
                          SelectionChanged="OnDetailTypeChanged"
                          ToolTip="0 = integer, 1 = float (fixed for standard engine variables)">
                  <ComboBoxItem Content="int" />
                  <ComboBoxItem Content="float" />
                </ComboBox>
                <TextBlock Text="Value" Style="{StaticResource GlFieldLabel}" />
                <ui:TextBox FontSize="12" IsEnabled="{Binding HasSelection}"
                            ctl:NumericBehavior.FloatOnly="True"
                            PlaceholderText="value"
                            Text="{Binding DetailValue, UpdateSourceTrigger=PropertyChanged}"
                            LostFocus="OnDetailValueLostFocus" KeyDown="OnDetailValueKeyDown" />
                <TextBlock Margin="0,8,0,0" Style="{StaticResource GlHint}" TextWrapping="Wrap"
                           Text="{Binding SelectedRow.Description}" />
                <Grid Margin="0,8,0,0" Visibility="{Binding SelectedIsKnown, Converter={StaticResource GlBoolToVis}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource GlHint}"
                             Text="{Binding SelectedRow.DefaultValue, StringFormat='Engine default: {0}'}" />
                  <ui:Button Grid.Column="1" Content="Reset to default" FontSize="12" Padding="8,3"
                             Click="OnResetClick" ToolTip="Set this variable back to its engine default value" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status line -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
