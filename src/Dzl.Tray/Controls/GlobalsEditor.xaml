<UserControl x:Class="Dzl.Tray.Controls.GlobalsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
  <!-- DataContext = GlobalsVm. Edits db/globals.xml: flat list of simulation vars (name, type, value).
       Every edit routes through the VM → GlobalsService (snapshot + write, never throws). Per-tab
       undo/redo snapshots the whole file. A UserControl does NOT inherit the host window's resources at
       realize time — declare local styles here; only DynamicResource theme brushes (resolved late) are
       safe to reference. -->
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="GlBoolToVis" />
    <Style x:Key="GlSectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="GlHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- grid -->
      <RowDefinition Height="Auto" />  <!-- add-var row -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Reload / Undo / Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="640" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <!-- Filter -->
        <ui:TextBox Width="180" Margin="0,0,8,0" FontSize="12"
                    PlaceholderText="filter vars…"
                    Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read globals.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Vars DataGrid -->
    <Border Grid.Row="1" CornerRadius="8" Padding="10"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Simulation variables" Style="{StaticResource GlSectionHeader}" Margin="0,0,0,6" />

        <DataGrid Grid.Row="1" x:Name="VarsGrid"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  IsReadOnly="False" SelectionMode="Single"
                  Background="Transparent" BorderThickness="0"
                  EnableRowVirtualization="True"
                  RowBackground="Transparent" AlternatingRowBackground="Transparent"
                  CellEditEnding="OnCellEditEnding">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                Width="*" MinWidth="160" />
            <DataGridTemplateColumn Header="Type" Width="90">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Type}" VerticalAlignment="Center" Margin="4,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
              <DataGridTemplateColumn.CellEditingTemplate>
                <DataTemplate>
                  <ComboBox SelectedIndex="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center">
                    <ComboBoxItem Content="0 (int)" />
                    <ComboBoxItem Content="1 (float)" />
                  </ComboBox>
                </DataTemplate>
              </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Value"
                                Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                Width="160" />
            <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ui:Button Content="Remove" FontSize="11" Padding="6,2"
                             Click="OnRemoveRowClick" Tag="{Binding}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>

        <!-- Action row: Remove selected -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
          <TextBlock Style="{StaticResource GlHint}" VerticalAlignment="Center" Margin="0,0,8,0"
                     Text="Double-click a cell to edit inline. Name/Type/Value are all editable." />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Add-var form -->
    <Border Grid.Row="2" CornerRadius="8" Padding="10" Margin="0,8,0,0"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="90" />
          <ColumnDefinition Width="120" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ui:TextBox Grid.Column="0" Margin="0,0,6,0" FontSize="12"
                    PlaceholderText="new var name (e.g. ZombieMaxCount)"
                    Text="{Binding NewVarName, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnAddVarKeyDown" />
        <ComboBox Grid.Column="1" Margin="0,0,6,0" VerticalAlignment="Center"
                  ToolTip="type: 0 = integer, 1 = float"
                  SelectedIndex="{Binding NewVarType, Mode=TwoWay}">
          <ComboBoxItem Content="0 (int)" />
          <ComboBoxItem Content="1 (float)" />
        </ComboBox>
        <ui:TextBox Grid.Column="2" Margin="0,0,6,0" FontSize="12"
                    PlaceholderText="value"
                    Text="{Binding NewVarValue, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnAddVarKeyDown" />
        <ui:Button Grid.Column="3" Content="Add var" Click="OnAddVarClick">
          <ui:Button.Icon>
            <ui:SymbolIcon Symbol="Add24" />
          </ui:Button.Icon>
        </ui:Button>
      </Grid>
    </Border>

    <!-- Status line -->
    <TextBlock Grid.Row="3" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
