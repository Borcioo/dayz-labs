<UserControl x:Class="Dzl.Tray.Controls.CeCoreEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = CeCoreVm. Edits cfgeconomycore.xml: custom-file routing manifest, default knobs (grouped +
       validated) and a read-only root-class list. Every edit routes through the VM → CeCoreService (snapshot +
       write). A UserControl does NOT inherit host-window resources — local styles only; app-scope keys
       (InverseBoolToVis) + DynamicResource theme brushes are safe. -->
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="CcBoolToVis" />
    <Style x:Key="CcHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="CcCardTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="CcCard" TargetType="Border">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="CcInfo" TargetType="ui:SymbolIcon">
      <Setter Property="Symbol" Value="Info24" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="6,0,0,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
    <Style x:Key="NumEdit" TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
      <Setter Property="ctl:NumericBehavior.FloatOnly" Value="True" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="540" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ctl:GlossaryButton Title="CE Config" Entries="{x:Static help:Glossary.CeCore}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read cfgeconomycore.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo"><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo"><ui:SymbolIcon Symbol="ArrowRedo24" /></ui:Button>
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- ===== Custom CE files (routing) ===== -->
        <Border Style="{StaticResource CcCard}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Text="Custom CE files (routing)" Margin="6,0,0,0" Style="{StaticResource CcCardTitle}" />
              <ui:SymbolIcon Style="{StaticResource CcInfo}"
                             ToolTip="Registers custom CE files (types/spawnabletypes/events/…) from a mission subfolder. Files added in the other tabs only load once routed here." />
            </StackPanel>

            <TextBlock Style="{StaticResource CcHint}" Margin="0,0,0,8"
                       Visibility="{Binding HasFiles, Converter={StaticResource InverseBoolToVis}}"
                       Text="No custom files registered — the mission uses only the vanilla CE files." />

            <ItemsControl ItemsSource="{Binding Files}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Padding="0,5">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text="{Binding Folder, Mode=OneWay}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <Run Text=" / " Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <Run Text="{Binding Name, Mode=OneWay}" />
                      </TextBlock>
                      <Border Grid.Column="1" CornerRadius="9" Padding="7,1" Margin="8,0" VerticalAlignment="Center"
                              Background="{DynamicResource ControlFillColorSecondaryBrush}">
                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                      </Border>
                      <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                                 ToolTip="Unregister this file" Click="OnRemoveFileClick" Tag="{Binding}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add registration -->
            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="folder (e.g. ce/MyMod)"
                          Text="{Binding NewFileFolder, UpdateSourceTrigger=PropertyChanged}" />
              <ui:TextBox Grid.Column="1" Margin="0,0,4,0" FontSize="12" PlaceholderText="file (e.g. mymod_types.xml)"
                          Text="{Binding NewFileName, UpdateSourceTrigger=PropertyChanged}" />
              <ComboBox Grid.Column="2" Width="130" Margin="0,0,4,0" FontSize="12"
                        ItemsSource="{Binding FileTypes}" SelectedItem="{Binding NewFileType, Mode=TwoWay}"
                        ToolTip="CE file type" />
              <ui:Button Grid.Column="3" Content="Register" Icon="{ui:SymbolIcon Add24}" Click="OnAddFileClick" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- ===== Defaults (grouped) ===== -->
        <Border Style="{StaticResource CcCard}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <ui:SymbolIcon Symbol="Settings24" FontSize="16" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Text="Defaults" Margin="6,0,0,0" Style="{StaticResource CcCardTitle}" />
              <ui:SymbolIcon Style="{StaticResource CcInfo}"
                             ToolTip="Engine default knobs: dynamic infected zone sizing, CE logging toggles, and startup/persistence options." />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding DefaultGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding Header}" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,2"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" /><ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                              <TextBlock Text="{Binding Description}" Style="{StaticResource CcHint}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                             Visibility="{Binding IsBool, Converter={StaticResource CcBoolToVis}}"
                                             IsChecked="{Binding Flag, Mode=TwoWay}" />
                            <ui:TextBox Grid.Column="1" FontSize="12" VerticalAlignment="Center"
                                        Visibility="{Binding IsBool, Converter={StaticResource InverseBoolToVis}}"
                                        Style="{StaticResource NumEdit}"
                                        Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                        LostFocus="OnDefaultValueLostFocus" KeyDown="OnDefaultValueKeyDown" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add a documented default not present -->
            <Grid Margin="0,8,0,0" Visibility="{Binding HasMissingDefaults, Converter={StaticResource CcBoolToVis}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Add default" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource CcHint}" />
              <ComboBox Grid.Column="1" Margin="0,0,6,0" FontSize="12"
                        ItemsSource="{Binding MissingDefaults}" SelectedItem="{Binding SelectedMissingDefault, Mode=TwoWay}" />
              <ui:Button Grid.Column="2" Content="Add" Icon="{ui:SymbolIcon Add24}" Click="OnAddDefaultClick" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- ===== Root classes (read-only) ===== -->
        <Border Style="{StaticResource CcCard}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <ui:SymbolIcon Symbol="Apps24" FontSize="16" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Text="Root classes" Margin="6,0,0,0" Style="{StaticResource CcCardTitle}" />
              <ui:SymbolIcon Style="{StaticResource CcInfo}"
                             ToolTip="The base classes the CE manages (loot / character / car). Advanced — edit in the file directly if you must." />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding RootClasses}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Border CornerRadius="9" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            Visibility="{Binding HasAct, Converter={StaticResource CcBoolToVis}}">
                      <TextBlock Text="{Binding Act}" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,8,0,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
