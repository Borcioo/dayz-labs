<UserControl x:Class="Dzl.Tray.Controls.LogPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
  <!-- AvalonEdit-backed log body: gutter line numbers + token syntax colouring + search-match highlight
       + clickable file:line (stack-trace path → open in editor). Driven by the bound LogPaneVm. -->
  <avalon:TextEditor x:Name="Editor"
                     IsReadOnly="True" ShowLineNumbers="True" WordWrap="False"
                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                     Background="{DynamicResource ApplicationBackgroundBrush}"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                     Padding="6,4" />
</UserControl>
