<UserControl x:Class="Dzl.Tray.Controls.EconomyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:local="clr-namespace:Dzl.Tray">
  <!-- The whole Central Economy editor (Types + the other CE tabs). DataContext = MainViewModel.
       Hosted by EconomyWindow (modeless) so the editor gets a window of its own. -->
          <Grid>
            <Grid.InputBindings>
              <KeyBinding Modifiers="Control" Key="Z" Command="{Binding TypesEditor.UndoTypesCommand}" />
              <KeyBinding Modifiers="Control" Key="Y" Command="{Binding TypesEditor.RedoTypesCommand}" />
            </Grid.InputBindings>
            <!-- CE editor tab shell: one tab per CE file KIND. No page header — the window title
                 already says Economy. -->
            <TabControl x:Name="EconomyTabControl" BorderThickness="0" Background="Transparent" Padding="0"
                        SelectionChanged="OnEconomyTabSelectionChanged">
              <TabControl.Resources>
                <Style TargetType="TabItem">
                  <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                  <Setter Property="FontSize" Value="13" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="14,7" Margin="0,0,4,0" CornerRadius="4,4,0,0"
                                Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                          <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF" />
                          </Trigger>
                          <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1F2A3A" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#4FA3FF" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </TabControl.Resources>

              <!-- DataContext = MainViewModel.TypesEditor (a TypesEditorVm) — same sub-VM pattern as the
                   other CE tabs below. -->
              <TabItem Header="Types">
                <Grid x:Name="TypesTabRoot" Margin="0,12,0,0" DataContext="{Binding TypesEditor}">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- file selector + toolbar -->
                    <RowDefinition Height="Auto" />  <!-- filters -->
                    <RowDefinition Height="*" />     <!-- master + detail (right panel is contextual) -->
                    <RowDefinition Height="Auto" />  <!-- status -->
                  </Grid.RowDefinitions>

            <!-- One-row toolbar: file/source scope on the left, actions on the right.
                 The resolved file path lives in the status footer below the grid. -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="File:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox MinWidth="160" VerticalAlignment="Center" Margin="0,0,12,0"
                          ItemsSource="{Binding TypesFileOptions}"
                          DisplayMemberPath="Label" SelectedValuePath="Path"
                          SelectedValue="{Binding TypesFileFilter}"
                          ToolTip="Scope the grid to one CE file, or All for the union" />
                <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox MinWidth="110" VerticalAlignment="Center"
                          SelectedValuePath="Tag" SelectedValue="{Binding TypesSourceFilter}"
                          ToolTip="Vanilla / Mod / Custom origin">
                  <ComboBoxItem Content="All sources" Tag="" />
                  <ComboBoxItem Content="Vanilla" Tag="Vanilla" />
                  <ComboBoxItem Content="Mod" Tag="Mod" />
                  <ComboBoxItem Content="Custom" Tag="Custom" />
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton x:Name="FiltersToggle" Margin="0,0,8,0" Padding="10,5"
                              ToolTip="Show / hide the filter panel (the count shows active filters)">
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Filter24" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FiltersButtonLabel}" VerticalAlignment="Center" />
                  </StackPanel>
                </ToggleButton>
                <ui:Button Icon="{ui:SymbolIcon ArrowUndo24}" ToolTip="Undo (Ctrl+Z)" Margin="0,0,4,0"
                           Command="{Binding UndoTypesCommand}" />
                <ui:Button Icon="{ui:SymbolIcon ArrowRedo24}" ToolTip="Redo (Ctrl+Y)" Margin="0,0,8,0"
                           Command="{Binding RedoTypesCommand}" />
                <ui:Button Content="Add" Icon="{ui:SymbolIcon Add24}" Margin="0,0,4,0" Click="OnAddType" />
                <ui:Button Content="Duplicate" Icon="{ui:SymbolIcon Copy24}" Margin="0,0,4,0" Click="OnDuplicateType"
                           ToolTip="Copy the selected row's full field set under a new name" />
                <ui:Button Content="Remove" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger" Margin="0,0,8,0" Click="OnRemoveTypes" />
                <ui:Button Content="Reload" Icon="{ui:SymbolIcon ArrowSync24}" Margin="0,0,4,0" Click="OnReloadTypes" />
                <ui:DropDownButton Content="Backups" Icon="{ui:SymbolIcon History24}" Margin="0,0,4,0">
                  <ui:DropDownButton.Flyout>
                    <ContextMenu x:Name="TypesBackupsMenu" />
                  </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
                <ui:Button Content="Save" Appearance="Primary" Icon="{ui:SymbolIcon Save24}" Click="OnSaveTypes" />
              </StackPanel>
            </Grid>

            <!-- Advanced filters (every control labeled). Collapsed by default — toggled by the
                 Filters button in the toolbar, so small screens keep the vertical space. -->
            <Border Grid.Row="1" Margin="0,0,0,8" Padding="10,8" CornerRadius="6"
                    Visibility="{Binding IsChecked, ElementName=FiltersToggle, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
              <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ui:TextBox x:Name="TypesFilterBox" Width="150" PlaceholderText="filter name…"
                              Text="{Binding TypesFilter, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Category:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ComboBox MinWidth="130" VerticalAlignment="Center"
                            ItemsSource="{Binding TypeCategories}" SelectedItem="{Binding TypesCategoryFilter}"
                            ToolTip="Category (blank = all)" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Usage:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ComboBox MinWidth="140" VerticalAlignment="Center" IsEditable="True"
                            Text="{Binding TypesUsageFilter, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{Binding LimitsUsage}" ToolTip="Usage contains…" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Tier:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ComboBox MinWidth="110" VerticalAlignment="Center" IsEditable="True"
                            Text="{Binding TypesValueFilter, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{Binding LimitsValue}" ToolTip="Tier (value) contains…" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Tag:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ComboBox MinWidth="110" VerticalAlignment="Center" IsEditable="True"
                            Text="{Binding TypesTagFilter, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{Binding LimitsTag}" ToolTip="Tag contains…" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Flag:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ComboBox MinWidth="140" VerticalAlignment="Center"
                            SelectedValuePath="Tag" SelectedValue="{Binding TypesFlagFilter}"
                            ToolTip="Has flag set">
                    <ComboBoxItem Content="Any flag" Tag="" />
                    <ComboBoxItem Content="CountInCargo" Tag="cargo" />
                    <ComboBoxItem Content="CountInHoarder" Tag="hoarder" />
                    <ComboBoxItem Content="CountInMap" Tag="map" />
                    <ComboBoxItem Content="CountInPlayer" Tag="player" />
                    <ComboBoxItem Content="Crafted" Tag="crafted" />
                    <ComboBoxItem Content="Deloot" Tag="deloot" />
                  </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                  <TextBlock Text="Nominal:" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <ui:TextBox Width="64" PlaceholderText="≥" Margin="0,0,4,0"
                              Text="{Binding TypesNominalMin, UpdateSourceTrigger=PropertyChanged}" ToolTip="Nominal minimum" />
                  <ui:TextBox Width="64" PlaceholderText="≤"
                              Text="{Binding TypesNominalMax, UpdateSourceTrigger=PropertyChanged}" ToolTip="Nominal maximum" />
                </StackPanel>
                <ui:Button Content="Clear" Icon="{ui:SymbolIcon Eraser24}" Margin="0,0,0,4" Click="OnClearFilters"
                           ToolTip="Reset all filters" VerticalAlignment="Center" />
              </WrapPanel>
            </Border>

            <!-- Master (grid) + splitter + Detail panel (drag the splitter on small screens) -->
            <Grid Grid.Row="2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="360" MinWidth="260" />
              </Grid.ColumnDefinitions>

              <DataGrid x:Name="TypesGrid" Grid.Column="0" ItemsSource="{Binding TypesView}"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        Style="{StaticResource DarkDataGrid}"
                        ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                        RowStyle="{StaticResource DarkDataGridRow}"
                        CellStyle="{StaticResource DarkDataGridCell}"
                        AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"
                        CanUserSortColumns="True"
                        EnableRowVirtualization="True"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ScrollViewer.CanContentScroll="True"
                        SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                        SelectionChanged="OnTypesSelectionChanged"
                        GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                        BeginningEdit="OnTypesBeginEdit" CellEditEnding="OnTypesCellEditEnding">
                <DataGrid.Columns>
                  <!-- Checkbox selection (batch target) + header select-all over the filtered set.
                       Fixed width with the cell padding zeroed for this column so the (centered) checkbox is
                       never clipped — the default 8,0 cell padding ate the content width and cut the box. -->
                  <DataGridTemplateColumn Width="40" MinWidth="40" MaxWidth="40" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellStyle>
                      <Style TargetType="DataGridCell" BasedOn="{StaticResource DarkDataGridCell}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                      </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <!-- Header must zero the 10,0 padding from DarkDataGridColumnHeader + center, or the
                         three-state header checkbox is clipped and misaligned with the row checkboxes. -->
                    <DataGridTemplateColumn.HeaderStyle>
                      <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridColumnHeader}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                      </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <!-- The WPF-UI CheckBox style carries a large MinWidth (reserves room for content
                         text); these boxes have no content, so zero it and pin the control to its
                         22px glyph — otherwise any column narrower than ~44px clips the box. -->
                    <DataGridTemplateColumn.HeaderTemplate>
                      <DataTemplate>
                        <CheckBox HorizontalAlignment="Center" IsThreeState="True"
                                  MinWidth="0" Width="22" Padding="0"
                                  ToolTip="Select / deselect all rows passing the filter"
                                  IsChecked="{Binding DataContext.AllFilteredChecked, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}" />
                      </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                  MinWidth="0" Width="22" Padding="0"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- Lint indicator: ⚠ + count, tooltip lists this row's findings. Narrow on purpose —
                       it's empty for clean rows, so any extra width reads as a dead gap before Name. -->
                  <DataGridTemplateColumn Width="26" MinWidth="26" MaxWidth="26" IsReadOnly="True" CanUserSort="False">
                    <!-- Zero the default 8,0 cell padding — in a 26px column it left ~10px and clipped
                         the ⚠ glyph the moment a finding appeared. -->
                    <DataGridTemplateColumn.CellStyle>
                      <Style TargetType="DataGridCell" BasedOn="{StaticResource DarkDataGridCell}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                      </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.HeaderStyle>
                      <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridColumnHeader}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                      </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.HeaderTemplate>
                      <DataTemplate>
                        <TextBlock Text="⚠" FontSize="12" FontWeight="SemiBold" Foreground="#F0C04A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   ToolTip="Lint findings — rows with warnings/errors show ⚠ here (hover the row's ⚠ for details)" />
                      </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding LintGlyph}" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#F0C04A" ToolTip="{Binding LintTooltip}" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="130" SortMemberPath="Name" />
                  <!-- Origin pill (matches the mod-source pills on the Mods/Servers pages) -->
                  <DataGridTemplateColumn Header="Source" Width="84" IsReadOnly="True" SortMemberPath="OriginLabel">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Border CornerRadius="9" Padding="7,1" Margin="2,0" VerticalAlignment="Center"
                                HorizontalAlignment="Left" Background="{Binding OriginBg}">
                          <TextBlock Text="{Binding OriginLabel}" FontSize="10" FontWeight="SemiBold"
                                     Foreground="{Binding OriginFg}" />
                        </Border>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="110" IsReadOnly="True" />
                  <DataGridTextColumn Header="Nominal" Binding="{Binding Nominal}" Width="64" />
                  <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="54" />
                  <DataGridTextColumn Header="QMin" Binding="{Binding QuantMin}" Width="54" />
                  <DataGridTextColumn Header="QMax" Binding="{Binding QuantMax}" Width="54" />
                  <DataGridTextColumn Header="Lifetime" Binding="{Binding Lifetime}" Width="80" />
                  <DataGridTextColumn Header="Restock" Binding="{Binding Restock}" Width="70" />
                  <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="54" />
                  <!-- Compact flags: active letters highlighted (C H M P · Cr De) -->
                  <DataGridTemplateColumn Header="Flags" Width="110" IsReadOnly="True" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <TextBlock Text="C"  FontSize="11" FontWeight="SemiBold" Margin="0,0,3,0" ToolTip="CountInCargo"
                                     Foreground="{Binding CountInCargo, Converter={StaticResource FlagBrush}}" />
                          <TextBlock Text="H"  FontSize="11" FontWeight="SemiBold" Margin="0,0,3,0" ToolTip="CountInHoarder"
                                     Foreground="{Binding CountInHoarder, Converter={StaticResource FlagBrush}}" />
                          <TextBlock Text="M"  FontSize="11" FontWeight="SemiBold" Margin="0,0,3,0" ToolTip="CountInMap"
                                     Foreground="{Binding CountInMap, Converter={StaticResource FlagBrush}}" />
                          <TextBlock Text="P"  FontSize="11" FontWeight="SemiBold" Margin="0,0,5,0" ToolTip="CountInPlayer"
                                     Foreground="{Binding CountInPlayer, Converter={StaticResource FlagBrush}}" />
                          <TextBlock Text="Cr" FontSize="11" FontWeight="SemiBold" Margin="0,0,3,0" ToolTip="Crafted"
                                     Foreground="{Binding Crafted, Converter={StaticResource FlagBrush}}" />
                          <TextBlock Text="De" FontSize="11" FontWeight="SemiBold" ToolTip="Deloot"
                                     Foreground="{Binding Deloot, Converter={StaticResource FlagBrush}}" />
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" MinWidth="90" />
                  <DataGridTextColumn Header="Usage" Binding="{Binding UsageText}" Width="*" MinWidth="90" IsReadOnly="True" />
                  <DataGridTextColumn Header="Tiers" Binding="{Binding ValueText}" Width="*" MinWidth="80" IsReadOnly="True" />
                  <DataGridTextColumn Header="Tag" Binding="{Binding TagText}" Width="*" MinWidth="80" IsReadOnly="True" />
                </DataGrid.Columns>
              </DataGrid>

              <!-- Drag to trade grid width for detail-panel width (compact screens) -->
              <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Background="Transparent" ShowsPreview="False" />

              <!-- Right column: contextual panel — single-row edit form OR batch operations -->
              <Grid Grid.Column="2" Margin="4,0,0,0">
                <!-- Single-row edit form — visible when 0 or 1 rows are checked -->
                <!-- DataContext is the selected row, but Vm/suggestions/Visibility must come from the
                     Types-editor VM (not the row) — bind them explicitly via the TypesTabRoot element's
                     DataContext (a TypesEditorVm). -->
                <ctl:TypeDetailPanel x:Name="TypeDetail"
                                     DataContext="{Binding SelectedType}"
                                     Vm="{Binding DataContext, ElementName=TypesTabRoot}"
                                     Categories="{Binding DataContext.LimitsCategory, ElementName=TypesTabRoot}"
                                     UsageSuggestions="{Binding DataContext.LimitsUsage, ElementName=TypesTabRoot}"
                                     ValueSuggestions="{Binding DataContext.LimitsValue, ElementName=TypesTabRoot}"
                                     TagSuggestions="{Binding DataContext.LimitsTag, ElementName=TypesTabRoot}"
                                     Visibility="{Binding DataContext.BatchMode, ElementName=TypesTabRoot, Converter={StaticResource InverseBoolToVis}}" />

                <!-- Batch operations panel — visible when 2+ rows are checked. Styled to match
                     TypeDetailPanel: one rounded card, labels above full-width controls. -->
                <Border Visibility="{Binding BatchMode, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="0">
                  <Border.Resources>
                    <Style x:Key="BatchLabel" TargetType="TextBlock">
                      <Setter Property="FontSize" Value="11" />
                      <Setter Property="FontWeight" Value="SemiBold" />
                      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                      <Setter Property="Margin" Value="0,0,0,2" />
                    </Style>
                  </Border.Resources>
                  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14">
                    <StackPanel>
                      <TextBlock Text="{Binding CheckedTypeCount, StringFormat='Batch — {0} checked rows'}"
                                 FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                      <TextBlock Text="Numeric field" Style="{StaticResource BatchLabel}" />
                      <ComboBox x:Name="BatchFieldBox" SelectedIndex="0" Margin="0,0,0,4">
                        <ComboBoxItem Content="nominal" /><ComboBoxItem Content="min" />
                        <ComboBoxItem Content="quantmin" /><ComboBoxItem Content="quantmax" />
                        <ComboBoxItem Content="lifetime" /><ComboBoxItem Content="restock" /><ComboBoxItem Content="cost" />
                      </ComboBox>
                      <ui:TextBox x:Name="BatchValueBox" PlaceholderText="value" Margin="0,0,0,6" />
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <ui:Button Content="Set" Margin="0,0,4,0" Click="OnBatchSet" ToolTip="Set the field to the value on checked rows" />
                        <ui:Button Content="× Multiply" Margin="0,0,4,0" Click="OnBatchMultiply"
                                   ToolTip="Multiply the field by the value on checked rows" />
                        <ui:Button Content="÷ Divide" Click="OnBatchDivide"
                                   ToolTip="Divide the field by the value on checked rows (0 is rejected)" />
                      </StackPanel>

                      <TextBlock Text="Flag" Style="{StaticResource BatchLabel}" />
                      <ComboBox x:Name="BatchFlagBox" Margin="0,0,0,6" SelectedValuePath="Tag" SelectedIndex="0">
                        <ComboBoxItem Content="CountInCargo" Tag="cargo" />
                        <ComboBoxItem Content="CountInHoarder" Tag="hoarder" />
                        <ComboBoxItem Content="CountInMap" Tag="map" />
                        <ComboBoxItem Content="CountInPlayer" Tag="player" />
                        <ComboBoxItem Content="Crafted" Tag="crafted" />
                        <ComboBoxItem Content="Deloot" Tag="deloot" />
                      </ComboBox>
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <ui:Button Content="Set" Margin="0,0,4,0" Click="OnBatchFlagSet" ToolTip="Set the chosen flag on checked rows" />
                        <ui:Button Content="Clear" Margin="0,0,4,0" Click="OnBatchFlagClear" ToolTip="Clear the chosen flag" />
                        <ui:Button Content="Toggle" Click="OnBatchFlagToggle" ToolTip="Toggle the chosen flag" />
                      </StackPanel>

                      <TextBlock Text="List" Style="{StaticResource BatchLabel}" />
                      <ComboBox x:Name="BatchListBox" SelectedValuePath="Tag" SelectedIndex="0" Margin="0,0,0,4">
                        <ComboBoxItem Content="usage" Tag="usage" />
                        <ComboBoxItem Content="value" Tag="value" />
                        <ComboBoxItem Content="tag" Tag="tag" />
                      </ComboBox>
                      <ui:TextBox x:Name="BatchListValueBox" PlaceholderText="list value" Margin="0,0,0,6" />
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <ui:Button Content="+ Add" Margin="0,0,4,0" Click="OnBatchListAdd" ToolTip="Add this value to the list on checked rows" />
                        <ui:Button Content="− Remove" Click="OnBatchListRemove" ToolTip="Remove this value from the list on checked rows" />
                      </StackPanel>

                      <TextBlock Text="Category" Style="{StaticResource BatchLabel}" />
                      <ComboBox x:Name="BatchCategoryBox" Margin="0,0,0,6" IsEditable="True"
                                ItemsSource="{Binding LimitsCategory}" ToolTip="Category to set" />
                      <ui:Button Content="Set category" Click="OnBatchCategorySet" ToolTip="Set category on checked rows" />
                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </Grid>
            </Grid>

            <!-- Status footer (one slim line, uniform 11px): path left, metrics right.
                 Order: file path (ellipsized) | lint | showing X/N | last-action status.
                 Tinted like a classic status bar so it reads as chrome, not content. -->
            <Border Grid.Row="3" Margin="0,6,0,0" CornerRadius="4" Padding="10,3"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
            <Grid Height="20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding TypesFile}" ToolTip="{Binding TypesFile}"
                         VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,16,0"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding TypesLintSummary}" VerticalAlignment="Center" FontSize="11"
                         Margin="0,0,16,0" Foreground="#F0C04A" Cursor="Hand" MouseLeftButtonUp="OnJumpToLint"
                         ToolTip="Click to jump to the first row with findings"
                         Visibility="{Binding HasLintFindings, Converter={StaticResource BoolToVis}}" />
              <TextBlock Grid.Column="2" Text="{Binding TypesCountLabel}" VerticalAlignment="Center" Margin="0,0,16,0"
                         FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Grid.Column="3" Text="{Binding TypesStatus}" VerticalAlignment="Center"
                         FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Grid>
            </Border>
                </Grid>
              </TabItem>

              <!-- Dictionaries: edit the game-honored CE name lists (cfglimitsdefinition.xml) + named
                   combos (cfglimitsdefinitionuser.xml). Shares the limit names the Types tab suggests +
                   lints against. DataContext = MainViewModel.Dictionaries (a DictionaryManagerVm). -->
              <TabItem Header="Dictionaries">
                <ctl:DictionaryManager Margin="0,12,0,0" DataContext="{Binding Dictionaries}" />
              </TabItem>

              <!-- Random Presets: edit cfgrandompresets.xml — cargo/attachments presets + their items.
                   Referenced by name from cfgspawnabletypes.xml. DataContext = MainViewModel.RandomPresets. -->
              <TabItem Header="Random Presets">
                <ctl:RandomPresetsEditor DataContext="{Binding RandomPresets}" />
              </TabItem>

              <!-- Spawnable Types: edit cfgspawnabletypes.xml — per-type hoarder/damage + cargo/attachments
                   blocks (preset-based, referencing cfgrandompresets.xml, or chance-based with inline items).
                   DataContext = MainViewModel.SpawnableTypes. -->
              <TabItem Header="Spawnable Types">
                <ctl:SpawnableTypesEditor DataContext="{Binding SpawnableTypes}" />
              </TabItem>

              <!-- Globals: edit db/globals.xml — flat list of simulation variables (animal counts, loot
                   damage limits, etc.). DataContext = MainViewModel.Globals. -->
              <TabItem Header="Globals">
                <ctl:GlobalsEditor DataContext="{Binding Globals}" />
              </TabItem>

              <!-- Events: edit db/events.xml — CE spawn events (nominal counts, radii, flags, children).
                   DataContext = MainViewModel.Events (an EventsVm). -->
              <TabItem Header="Events">
                <ctl:EventsEditor DataContext="{Binding Events}" />
              </TabItem>

              <!-- Player Spawns: edit cfgplayerspawnpoints.xml — fresh/hop/travel categories, their param
                   bags (spawn/generator/group) + named position-group bubbles. DataContext = MainViewModel.PlayerSpawns. -->
              <TabItem Header="Player Spawns">
                <ctl:PlayerSpawnsEditor DataContext="{Binding PlayerSpawns}" />
              </TabItem>
            </TabControl>
          </Grid>
</UserControl>
