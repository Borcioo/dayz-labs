<UserControl x:Class="Dzl.Tray.Controls.TypeDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:local="clr-namespace:Dzl.Tray"
             x:Name="Root">
  <!-- Form-based master-detail editor for one TypeRowVm. DataContext is the selected row (set by the host);
       the MainViewModel (for limits suggestions + undo/lint plumbing) is passed via the Vm DP. Numeric
       fields are Slider + validated TextBox pairs; category is a select; usage/value/tag are chip
       multiselects; flags are labeled toggles. Each change is one undo step (snapshot BEFORE change). -->
  <UserControl.Resources>
    <!-- A UserControl does NOT inherit the host window's resources at realize time — StaticResource
         resolves against this control's own scope + App resources. Declare everything used here locally. -->
    <local:NullToVisibilityConverter x:Key="NullToVis" />
    <local:NotNullToVisibilityConverter x:Key="NotNullToVis" />

    <Style x:Key="DetailLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <!-- Numeric TextBox with a red invalid state when the validation rule fails. -->
    <Style x:Key="NumBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
      <Setter Property="Width" Value="72" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Right" />
      <Setter Property="Validation.ErrorTemplate">
        <Setter.Value>
          <ControlTemplate>
            <AdornedElementPlaceholder />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="Validation.HasError" Value="True">
          <Setter Property="BorderBrush" Value="#E06C75" />
          <Setter Property="BorderThickness" Value="1.5" />
          <Setter Property="ToolTip"
                  Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
          CornerRadius="8" Padding="0">
    <Grid>
      <!-- Compact hint when nothing selected (NOT a giant placeholder). -->
      <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="14,14,14,0"
                  Orientation="Horizontal"
                  Visibility="{Binding DataContext, ElementName=Root, Converter={StaticResource NullToVis}}">
        <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="Select a row to edit it here." FontSize="12" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
      </StackPanel>

      <!-- Editor form (only when a row is selected) -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14"
                    Visibility="{Binding DataContext, ElementName=Root, Converter={StaticResource NotNullToVis}}">
        <StackPanel>

          <!-- Header: origin pill + lint -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Border CornerRadius="9" Padding="7,1" VerticalAlignment="Center" Margin="0,0,8,0"
                    Background="{Binding OriginBg}">
              <TextBlock Text="{Binding OriginLabel}" FontSize="10" FontWeight="SemiBold"
                         Foreground="{Binding OriginFg}" />
            </Border>
            <TextBlock Text="{Binding LintGlyph}" FontSize="11" FontWeight="SemiBold"
                       Foreground="#F0C04A" VerticalAlignment="Center"
                       ToolTip="{Binding LintTooltip}" />
          </StackPanel>

          <TextBlock Text="Name" Style="{StaticResource DetailLabel}" />
          <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,4"
                      GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
          <TextBlock Text="{Binding FileName, StringFormat='file: {0}'}" Style="{StaticResource DetailLabel}"
                     FontWeight="Normal" Margin="0,0,0,12" />

          <!-- Numeric fields: Slider + validated TextBox pairs.
               Soft-capped sliders (0-100) for nominal/min/cost; the TextBox accepts higher values.
               lifetime/restock are large → wide slider with a high cap + free TextBox. -->
          <TextBlock Text="Nominal" Style="{StaticResource DetailLabel}" />
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Minimum="0" Maximum="100" VerticalAlignment="Center" Margin="0,0,8,0"
                    SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1"
                    Value="{Binding Nominal, Mode=TwoWay}"
                    PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                    Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
            <TextBox Grid.Column="1" Style="{StaticResource NumBox}"
                     GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
              <TextBox.Text>
                <Binding Path="Nominal" UpdateSourceTrigger="LostFocus">
                  <Binding.ValidationRules><local:NonNegativeIntRule /></Binding.ValidationRules>
                </Binding>
              </TextBox.Text>
            </TextBox>
          </Grid>

          <TextBlock Text="Min" Style="{StaticResource DetailLabel}" />
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Minimum="0" Maximum="100" VerticalAlignment="Center" Margin="0,0,8,0"
                    SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1"
                    Value="{Binding Min, Mode=TwoWay}"
                    PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                    Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
            <TextBox Grid.Column="1" Style="{StaticResource NumBox}"
                     GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
              <TextBox.Text>
                <Binding Path="Min" UpdateSourceTrigger="LostFocus">
                  <Binding.ValidationRules><local:NonNegativeIntRule /></Binding.ValidationRules>
                </Binding>
              </TextBox.Text>
            </TextBox>
          </Grid>

          <!-- QuantMin / QuantMax: -1 means "not set" → allow negative; numeric TextBox (+ slider 0-100). -->
          <UniformGrid Columns="2">
            <StackPanel Margin="0,0,6,10">
              <TextBlock Text="QuantMin" Style="{StaticResource DetailLabel}" />
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="-1" Maximum="100" VerticalAlignment="Center" Margin="0,0,6,0"
                        SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1"
                        Value="{Binding QuantMin, Mode=TwoWay}"
                        PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                        Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
                <TextBox Grid.Column="1" Style="{StaticResource NumBox}" Width="56"
                         GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
                  <TextBox.Text>
                    <Binding Path="QuantMin" UpdateSourceTrigger="LostFocus">
                      <Binding.ValidationRules><local:NonNegativeIntRule AllowNegative="True" /></Binding.ValidationRules>
                    </Binding>
                  </TextBox.Text>
                </TextBox>
              </Grid>
            </StackPanel>
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="QuantMax" Style="{StaticResource DetailLabel}" />
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="-1" Maximum="100" VerticalAlignment="Center" Margin="0,0,6,0"
                        SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1"
                        Value="{Binding QuantMax, Mode=TwoWay}"
                        PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                        Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
                <TextBox Grid.Column="1" Style="{StaticResource NumBox}" Width="56"
                         GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
                  <TextBox.Text>
                    <Binding Path="QuantMax" UpdateSourceTrigger="LostFocus">
                      <Binding.ValidationRules><local:NonNegativeIntRule AllowNegative="True" /></Binding.ValidationRules>
                    </Binding>
                  </TextBox.Text>
                </TextBox>
              </Grid>
            </StackPanel>
          </UniformGrid>

          <!-- Cost: 0-100 soft-cap slider + TextBox -->
          <TextBlock Text="Cost" Style="{StaticResource DetailLabel}" />
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Minimum="0" Maximum="100" VerticalAlignment="Center" Margin="0,0,8,0"
                    SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1"
                    Value="{Binding Cost, Mode=TwoWay}"
                    PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                    Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
            <TextBox Grid.Column="1" Style="{StaticResource NumBox}"
                     GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
              <TextBox.Text>
                <Binding Path="Cost" UpdateSourceTrigger="LostFocus">
                  <Binding.ValidationRules><local:NonNegativeIntRule /></Binding.ValidationRules>
                </Binding>
              </TextBox.Text>
            </TextBox>
          </Grid>

          <!-- Lifetime / Restock: large values → validated TextBox + a wide high-cap slider. -->
          <TextBlock Text="Lifetime (seconds)" Style="{StaticResource DetailLabel}" />
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Minimum="0" Maximum="3888000" VerticalAlignment="Center" Margin="0,0,8,0"
                    SmallChange="3600" LargeChange="86400"
                    Value="{Binding Lifetime, Mode=TwoWay}"
                    PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                    Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
            <TextBox Grid.Column="1" Style="{StaticResource NumBox}" Width="90"
                     GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
              <TextBox.Text>
                <Binding Path="Lifetime" UpdateSourceTrigger="LostFocus">
                  <Binding.ValidationRules><local:NonNegativeIntRule /></Binding.ValidationRules>
                </Binding>
              </TextBox.Text>
            </TextBox>
          </Grid>

          <TextBlock Text="Restock (seconds)" Style="{StaticResource DetailLabel}" />
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Minimum="0" Maximum="3888000" VerticalAlignment="Center" Margin="0,0,8,0"
                    SmallChange="3600" LargeChange="86400"
                    Value="{Binding Restock, Mode=TwoWay}"
                    PreviewMouseLeftButtonDown="OnSliderPreviewMouse"
                    Thumb.DragCompleted="OnSliderCommit" LostMouseCapture="OnSliderCommit" />
            <TextBox Grid.Column="1" Style="{StaticResource NumBox}" Width="90"
                     GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit">
              <TextBox.Text>
                <Binding Path="Restock" UpdateSourceTrigger="LostFocus">
                  <Binding.ValidationRules><local:NonNegativeIntRule /></Binding.ValidationRules>
                </Binding>
              </TextBox.Text>
            </TextBox>
          </Grid>

          <!-- Category (select) -->
          <TextBlock Text="Category" Style="{StaticResource DetailLabel}" />
          <ComboBox IsEditable="True" StaysOpenOnEdit="True" Margin="0,0,0,12"
                    Text="{Binding Category, UpdateSourceTrigger=LostFocus}"
                    ItemsSource="{Binding Categories, ElementName=Root}"
                    GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />

          <!-- Chip multiselects -->
          <TextBlock Text="Usage" Style="{StaticResource DetailLabel}" />
          <ctl:ChipMultiSelect x:Name="UsageChips" Margin="0,0,0,10" AddHint="add usage…"
                               Items="{Binding Usage}"
                               Suggestions="{Binding UsageSuggestions, ElementName=Root}"
                               Changed="OnChipsChanged" />

          <TextBlock Text="Value (tiers)" Style="{StaticResource DetailLabel}" />
          <ctl:ChipMultiSelect x:Name="ValueChips" Margin="0,0,0,10" AddHint="add tier…"
                               Items="{Binding Value}"
                               Suggestions="{Binding ValueSuggestions, ElementName=Root}"
                               Changed="OnChipsChanged" />

          <TextBlock Text="Tag" Style="{StaticResource DetailLabel}" />
          <ctl:ChipMultiSelect x:Name="TagChips" Margin="0,0,0,12" AddHint="add tag…"
                               Items="{Binding Tag}"
                               Suggestions="{Binding TagSuggestions, ElementName=Root}"
                               Changed="OnChipsChanged" />

          <!-- Flags (labeled toggles) -->
          <TextBlock Text="Flags" Style="{StaticResource DetailLabel}" Margin="0,0,0,4" />
          <UniformGrid Columns="2">
            <ui:ToggleSwitch Content="CountInCargo"   IsChecked="{Binding CountInCargo}"   Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="CountInHoarder" IsChecked="{Binding CountInHoarder}" Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="CountInMap"     IsChecked="{Binding CountInMap}"     Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="CountInPlayer"  IsChecked="{Binding CountInPlayer}"  Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="Crafted"        IsChecked="{Binding Crafted}"        Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="Deloot"         IsChecked="{Binding Deloot}"         Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
          </UniformGrid>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
