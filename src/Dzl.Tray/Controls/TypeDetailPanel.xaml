<UserControl x:Class="Dzl.Tray.Controls.TypeDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:local="clr-namespace:Dzl.Tray"
             x:Name="Root">
  <!-- Master-detail editor for one TypeRowVm. DataContext is the selected row (set by the host); the
       MainViewModel (for limits suggestions + edit plumbing) is passed via the Vm DP. All edits are live
       on the shared row instance; numeric +/- and toggles route through Vm so each is an undo step. -->
  <UserControl.Resources>
    <Style x:Key="DetailLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
    <Style x:Key="StepBtn" TargetType="Button">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
  </UserControl.Resources>

  <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
          CornerRadius="8" Padding="0">
    <Grid>
      <!-- Placeholder when nothing selected -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                  Visibility="{Binding DataContext, ElementName=Root, Converter={StaticResource NullToVis}}">
        <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="32" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="Select a type to edit" Margin="0,8,0,0" FontSize="13"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Editor (only when a row is selected) -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14"
                    Visibility="{Binding DataContext, ElementName=Root, Converter={StaticResource NotNullToVis}}">
        <StackPanel>

          <!-- Header: name + origin pill + file + lint -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Border CornerRadius="9" Padding="7,1" VerticalAlignment="Center" Margin="0,0,8,0"
                    Background="{Binding OriginBg}">
              <TextBlock Text="{Binding OriginLabel}" FontSize="10" FontWeight="SemiBold"
                         Foreground="{Binding OriginFg}" />
            </Border>
            <TextBlock Text="{Binding LintGlyph}" FontSize="11" FontWeight="SemiBold"
                       Foreground="#F0C04A" VerticalAlignment="Center"
                       ToolTip="{Binding LintTooltip}" />
          </StackPanel>
          <TextBlock Text="Name" Style="{StaticResource DetailLabel}" />
          <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,4"
                      GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
          <TextBlock Text="{Binding FileName, StringFormat='file: {0}'}" Style="{StaticResource DetailLabel}"
                     Margin="0,0,0,10" />

          <!-- Numeric grid: 2 columns of stepper fields -->
          <UniformGrid Columns="2" Margin="0,0,0,6">
            <StackPanel Margin="0,0,6,8">
              <TextBlock Text="Nominal" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="nominal" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding Nominal, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="nominal" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Min" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="min" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding Min, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="min" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,6,8">
              <TextBlock Text="QuantMin" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="quantmin" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding QuantMin, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="quantmin" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="QuantMax" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="quantmax" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding QuantMax, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="quantmax" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,6,8">
              <TextBlock Text="Lifetime" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="lifetime" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding Lifetime, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="lifetime" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Restock" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="restock" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding Restock, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="restock" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,6,8">
              <TextBlock Text="Cost" Style="{StaticResource DetailLabel}" />
              <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource StepBtn}" Tag="cost" Click="OnStepDown" />
                <ui:TextBox Width="64" Margin="3,0" Text="{Binding Cost, UpdateSourceTrigger=LostFocus}"
                            GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />
                <Button Content="+" Style="{StaticResource StepBtn}" Tag="cost" Click="OnStepUp" />
              </StackPanel>
            </StackPanel>
          </UniformGrid>

          <!-- Category -->
          <TextBlock Text="Category" Style="{StaticResource DetailLabel}" />
          <ComboBox IsEditable="True" StaysOpenOnEdit="True" Margin="0,0,0,10"
                    Text="{Binding Category, UpdateSourceTrigger=LostFocus}"
                    ItemsSource="{Binding Categories, ElementName=Root}"
                    GotKeyboardFocus="OnFieldFocus" LostFocus="OnFieldCommit" />

          <!-- Chip editors -->
          <TextBlock Text="Usage" Style="{StaticResource DetailLabel}" />
          <ctl:ChipMultiSelect x:Name="UsageChips" Margin="0,0,0,10" AddHint="add usage…"
                               Items="{Binding Usage}"
                               Suggestions="{Binding UsageSuggestions, ElementName=Root}"
                               Changed="OnChipsChanged" />

          <TextBlock Text="Value (tiers)" Style="{StaticResource DetailLabel}" />
          <ctl:ChipMultiSelect x:Name="ValueChips" Margin="0,0,0,10" AddHint="add tier…"
                               Items="{Binding Value}"
                               Suggestions="{Binding ValueSuggestions, ElementName=Root}"
                               Changed="OnChipsChanged" />

          <TextBlock Text="Tag" Style="{StaticResource DetailLabel}" />
          <ctl:ChipMultiSelect x:Name="TagChips" Margin="0,0,0,12" AddHint="add tag…"
                               Items="{Binding Tag}"
                               Suggestions="{Binding TagSuggestions, ElementName=Root}"
                               Changed="OnChipsChanged" />

          <!-- Flags -->
          <TextBlock Text="Flags" Style="{StaticResource DetailLabel}" Margin="0,0,0,4" />
          <UniformGrid Columns="2">
            <ui:ToggleSwitch Content="CountInCargo"   IsChecked="{Binding CountInCargo}"   Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="CountInHoarder" IsChecked="{Binding CountInHoarder}" Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="CountInMap"     IsChecked="{Binding CountInMap}"     Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="CountInPlayer"  IsChecked="{Binding CountInPlayer}"  Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="Crafted"        IsChecked="{Binding Crafted}"        Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
            <ui:ToggleSwitch Content="Deloot"         IsChecked="{Binding Deloot}"         Click="OnFlagToggled"
                             PreviewMouseLeftButtonDown="OnFlagPreviewMouse" PreviewKeyDown="OnFlagPreviewKey" Margin="0,0,0,4" />
          </UniformGrid>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
