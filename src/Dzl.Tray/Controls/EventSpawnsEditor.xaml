<UserControl x:Class="Dzl.Tray.Controls.EventSpawnsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = EventSpawnsVm. Edits cfgeventspawns.xml: per-event spawn positions. Master (events) +
       detail (X/Z/A positions). Routes through the VM → EventSpawnsService (snapshot + write). Local styles
       only; app-scope DarkDataGrid* + DynamicResource theme brushes are safe. -->
  <UserControl.Resources>
    <Style x:Key="EsNum" TargetType="ui:NumberBox" BasedOn="{StaticResource {x:Type ui:NumberBox}}">
      <Setter Property="ClearButtonEnabled" Value="False" />
      <Setter Property="SpinButtonPlacementMode" Value="Hidden" />
      <Setter Property="MaxDecimalPlaces" Value="6" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="440" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ctl:GlossaryButton Title="Event Spawns" Entries="{x:Static help:Glossary.EventSpawns}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick" ToolTip="Re-read cfgeventspawns.xml (discards undo)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo"><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo"><ui:SymbolIcon Symbol="ArrowRedo24" /></ui:Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" MinWidth="260" />
      </Grid.ColumnDefinitions>

      <!-- Master: events -->
      <Border Grid.Column="0" CornerRadius="8" Padding="8"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <DockPanel>
          <ui:TextBox DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="12" PlaceholderText="filter events…"
                      Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
          <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new event name"
                        Text="{Binding NewEventName, UpdateSourceTrigger=PropertyChanged}" KeyDown="OnAddEventKeyDown" />
            <ui:Button Grid.Column="1" Click="OnAddEventClick" ToolTip="Add event"><ui:SymbolIcon Symbol="Add24" /></ui:Button>
          </Grid>
          <DataGrid x:Name="EventGrid" ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                    Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" SelectionMode="Single" IsReadOnly="True"
                    Background="Transparent" BorderThickness="0" EnableRowVirtualization="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Event" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="#pos" Binding="{Binding PosCount}" Width="Auto" />
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                               ToolTip="Remove this event + positions" Click="OnRemoveEventClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- Detail: positions of selected event -->
      <Border Grid.Column="2" CornerRadius="8" Padding="8,10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="2,0,0,6">
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding SelectedEvent.Name, StringFormat='Positions for {0}', FallbackValue='Positions'}" />
            <TextBlock Text="world X / Z · angle" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
          </StackPanel>
          <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:NumberBox x:Name="NewPosX" Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource EsNum}" PlaceholderText="X" />
            <ui:NumberBox x:Name="NewPosZ" Grid.Column="1" Margin="0,0,4,0" Style="{StaticResource EsNum}" PlaceholderText="Z" />
            <ui:NumberBox x:Name="NewPosA" Grid.Column="2" Margin="0,0,4,0" Style="{StaticResource EsNum}" PlaceholderText="angle" />
            <ui:Button Grid.Column="3" Click="OnAddPosClick" ToolTip="Add position"><ui:SymbolIcon Symbol="Add24" /></ui:Button>
          </Grid>
          <DataGrid x:Name="PosGrid" ItemsSource="{Binding Positions}"
                    Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" SelectionMode="Single" IsReadOnly="False"
                    Background="Transparent" BorderThickness="0" EnableRowVirtualization="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled" CellEditEnding="OnPosCellEditEnding">
            <DataGrid.Columns>
              <DataGridTextColumn Header="X" Binding="{Binding XText, UpdateSourceTrigger=LostFocus}" Width="*" />
              <DataGridTextColumn Header="Z" Binding="{Binding ZText, UpdateSourceTrigger=LostFocus}" Width="*" />
              <DataGridTextColumn Header="Angle" Binding="{Binding AText, UpdateSourceTrigger=LostFocus}" Width="*" />
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                               ToolTip="Remove this position" Click="OnRemovePosClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,8,0,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
