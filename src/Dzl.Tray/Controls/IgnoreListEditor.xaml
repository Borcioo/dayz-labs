<UserControl x:Class="Dzl.Tray.Controls.IgnoreListEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = IgnoreListVm. Edits cfgignorelist.xml: a flat list of item classnames the CE ignores.
       Routes through the VM → IgnoreListService (snapshot + write). Local styles only; app-scope InverseBoolToVis
       + DynamicResource theme brushes are safe. -->
  <UserControl.Resources>
    <Style x:Key="IlHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + filter + Reload/Undo/Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="440" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ui:TextBox Width="180" Margin="0,0,8,0" FontSize="12" PlaceholderText="filter…"
                    Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
        <ctl:GlossaryButton Title="Ignore list" Entries="{x:Static help:Glossary.IgnoreList}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read cfgignorelist.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo"><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo"><ui:SymbolIcon Symbol="ArrowRedo24" /></ui:Button>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" CornerRadius="8" Padding="10"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
          <ui:SymbolIcon Symbol="Prohibited24" FontSize="16" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <TextBlock Text="Ignored classnames" Margin="6,0,0,0" FontSize="14" FontWeight="SemiBold"
                     VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          <TextBlock Text="items the Central Economy will not manage or clean up" Margin="10,0,0,0"
                     VerticalAlignment="Center" Style="{StaticResource IlHint}" />
        </StackPanel>

        <!-- Add classname -->
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <ui:TextBox Grid.Column="0" Margin="0,0,6,0" FontSize="12" PlaceholderText="classname (e.g. Bandage)"
                      Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" KeyDown="OnAddKeyDown" />
          <ui:Button Grid.Column="1" Content="Add" Icon="{ui:SymbolIcon Add24}" Click="OnAddClick" />
        </Grid>

        <TextBlock DockPanel.Dock="Top" Style="{StaticResource IlHint}" Margin="2,0,0,0"
                   Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVis}}"
                   Text="No ignored classnames." />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding}" FontSize="13" VerticalAlignment="Center" Margin="2,3"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                  <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                             ToolTip="Remove from the ignore list" Click="OnRemoveClick" Tag="{Binding}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,8,0,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
