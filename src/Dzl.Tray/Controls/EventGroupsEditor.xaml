<UserControl x:Class="Dzl.Tray.Controls.EventGroupsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = EventGroupsVm. Edits cfgeventgroups.xml: named object groups. Master (groups) + detail
       (children: type + x/y/z/a + loot + deloot). Routes through the VM → EventGroupsService. Local styles only;
       app-scope DarkDataGrid* + DynamicResource theme brushes are safe. -->
  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="440" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ctl:GlossaryButton Title="Event Groups" Entries="{x:Static help:Glossary.EventGroups}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick" ToolTip="Re-read cfgeventgroups.xml (discards undo)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo"><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo"><ui:SymbolIcon Symbol="ArrowRedo24" /></ui:Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" MinWidth="320" />
      </Grid.ColumnDefinitions>

      <!-- Master: groups -->
      <Border Grid.Column="0" CornerRadius="8" Padding="8"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <DockPanel>
          <ui:TextBox DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="12" PlaceholderText="filter groups…"
                      Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
          <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new group name"
                        Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}" KeyDown="OnAddGroupKeyDown" />
            <ui:Button Grid.Column="1" Click="OnAddGroupClick" ToolTip="Add group"><ui:SymbolIcon Symbol="Add24" /></ui:Button>
          </Grid>
          <DataGrid x:Name="GroupGrid" ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                    Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" SelectionMode="Single" IsReadOnly="True"
                    Background="Transparent" BorderThickness="0" EnableRowVirtualization="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Group" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="#obj" Binding="{Binding ChildCount}" Width="Auto" />
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                               ToolTip="Remove this group + children" Click="OnRemoveGroupClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- Detail: children of the selected group -->
      <Border Grid.Column="2" CornerRadius="8" Padding="8,10"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Margin="2,0,0,6" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Text="{Binding SelectedGroup.Name, StringFormat='Objects in {0}', FallbackValue='Objects'}" />
          <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="object classname (e.g. Land_Wreck_…)"
                        Text="{Binding NewChildType, UpdateSourceTrigger=PropertyChanged}" KeyDown="OnAddChildKeyDown" />
            <ui:Button Grid.Column="1" Click="OnAddChildClick" ToolTip="Add object (tune offsets inline)"><ui:SymbolIcon Symbol="Add24" /></ui:Button>
          </Grid>
          <DataGrid x:Name="ChildGrid" ItemsSource="{Binding Children}"
                    Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                    RowStyle="{StaticResource DarkDataGridRow}" CellStyle="{StaticResource DarkDataGridCell}"
                    AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                    HeadersVisibility="Column" SelectionMode="Single" IsReadOnly="False"
                    Background="Transparent" BorderThickness="0" EnableRowVirtualization="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto" CellEditEnding="OnChildCellEditEnding">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Type" Binding="{Binding Type, UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="140" />
              <DataGridTextColumn Header="X" Binding="{Binding XText, UpdateSourceTrigger=LostFocus}" Width="60" />
              <DataGridTextColumn Header="Y" Binding="{Binding YText, UpdateSourceTrigger=LostFocus}" Width="60" />
              <DataGridTextColumn Header="Z" Binding="{Binding ZText, UpdateSourceTrigger=LostFocus}" Width="60" />
              <DataGridTextColumn Header="Angle" Binding="{Binding AText, UpdateSourceTrigger=LostFocus}" Width="60" />
              <DataGridTextColumn Header="Loot min" Binding="{Binding LootMinText, UpdateSourceTrigger=LostFocus}" Width="60" />
              <DataGridTextColumn Header="Loot max" Binding="{Binding LootMaxText, UpdateSourceTrigger=LostFocus}" Width="60" />
              <DataGridCheckBoxColumn Header="Deloot" Binding="{Binding Deloot, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
              <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                               ToolTip="Remove this object" Click="OnRemoveChildClick" Tag="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,8,0,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
