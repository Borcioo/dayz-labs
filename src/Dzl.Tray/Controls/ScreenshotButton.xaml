<UserControl x:Class="Dzl.Tray.Controls.ScreenshotButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <!-- Flat, chrome-style: transparent, square, full-height — so it sits flush with the window's
       minimize/maximize/close buttons when hosted in a TitleBar's TrailingContent. -->
  <StackPanel Orientation="Horizontal">
    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
               Cursor="Hand" MouseLeftButtonUp="OnRevealScreenshot" />
    <ui:Button x:Name="ShotButton" Icon="{ui:SymbolIcon Camera20}" FontSize="14"
               Appearance="Transparent" Background="Transparent" BorderThickness="0"
               CornerRadius="0" Padding="0" Width="46" VerticalAlignment="Stretch"
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
               ToolTip="Screenshot the app (includes open windows) → saved to the screenshots folder"
               Click="OnScreenshot" />
  </StackPanel>
</UserControl>
