<UserControl x:Class="Dzl.Tray.Controls.ScreenshotButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <StackPanel Orientation="Horizontal">
    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
               Cursor="Hand" MouseLeftButtonUp="OnRevealScreenshot" />
    <ui:Button x:Name="ShotButton" Icon="{ui:SymbolIcon Camera24}" Padding="6,2" FontSize="12"
               ToolTip="Screenshot the app (includes open windows) → saved to the screenshots folder"
               Click="OnScreenshot" />
  </StackPanel>
</UserControl>
