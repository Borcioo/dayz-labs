<UserControl x:Class="Dzl.Tray.Controls.ChanceField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
  <!-- Inline slider + numeric entry, NO popup. A Popup hosting a TextBox inside a DataGrid fights the grid
       for keyboard focus (the grid yanks focus back to the row right after the click) and is unusable, so the
       editor lives directly in the cell. Children bind to Root's DPs via ElementName. -->
  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
    <Slider x:Name="Sld" Width="110" MinWidth="50" VerticalAlignment="Center"
            Minimum="{Binding Minimum, ElementName=Root}"
            Maximum="{Binding Maximum, ElementName=Root}"
            SmallChange="{Binding SmallChange, ElementName=Root}"
            LargeChange="{Binding SmallChange, ElementName=Root}"
            TickFrequency="{Binding SmallChange, ElementName=Root}" IsSnapToTickEnabled="True"
            Value="{Binding Value, ElementName=Root, Mode=TwoWay}" />
    <ui:TextBox x:Name="Num" MinWidth="48" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12"
                TextAlignment="Center" ToolTip="0..1"
                TextChanged="OnEntryTextChanged" PreviewTextInput="OnEntryPreviewInput"
                LostFocus="OnEntryLostFocus" KeyDown="OnEntryKeyDown" />
  </StackPanel>
</UserControl>
