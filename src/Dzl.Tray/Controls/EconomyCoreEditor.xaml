<UserControl x:Class="Dzl.Tray.Controls.EconomyCoreEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             xmlns:help="clr-namespace:Dzl.Tray.Help"
             x:Name="Root">
  <!-- DataContext = EconomyCoreVm. Edits db/economy.xml: a per-entity-group board of init/load/respawn/save
       toggles. Closed engine vocabulary — standard groups aren't removable (reset instead); "Add" offers only
       known-missing groups. Every edit routes through the VM → EconomyService (snapshot + write, never throws);
       per-tab undo/redo snapshots the whole file. A UserControl does NOT inherit the host window's resources —
       declare local styles here; DynamicResource theme brushes resolve late and are safe. -->
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="EcBoolToVis" />
    <Style x:Key="EcHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
    <Style x:Key="EcColHead" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style x:Key="EcInfo" TargetType="ui:SymbolIcon">
      <Setter Property="Symbol" Value="Info24" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- toolbar -->
      <RowDefinition Height="*" />     <!-- board -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Toolbar: file label + Reload / Undo / Redo -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        <TextBlock Text="{Binding FileLabel}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   TextTrimming="CharacterEllipsis" MaxWidth="560" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ctl:GlossaryButton Title="Economy core" Entries="{x:Static help:Glossary.EconomyCore}" Margin="0,0,12,0" />
        <ui:Button Content="Reload" Margin="0,0,6,0" Click="OnReloadClick"
                   ToolTip="Re-read db/economy.xml from disk (discards the undo history)" />
        <ui:Button Margin="0,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo the last edit">
          <ui:SymbolIcon Symbol="ArrowUndo24" />
        </ui:Button>
        <ui:Button Command="{Binding RedoCommand}" ToolTip="Redo">
          <ui:SymbolIcon Symbol="ArrowRedo24" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="2,0,0,8">
          <TextBlock Text="Economy processing per group" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
          <ui:SymbolIcon Style="{StaticResource EcInfo}"
                         ToolTip="db/economy.xml — for each entity group, toggle whether the Central Economy creates it on startup (init), restores it from persistence (load), respawns it at runtime (respawn) and saves it to storage (save)." />
        </StackPanel>

        <Border CornerRadius="8" Padding="12,8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
          <StackPanel>
            <!-- Column headers (widths must match the row template below) -->
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="86" /><ColumnDefinition Width="86" />
                <ColumnDefinition Width="86" /><ColumnDefinition Width="86" />
                <ColumnDefinition Width="64" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Group" FontSize="12" FontWeight="SemiBold" Margin="2,0,0,0"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Grid.Column="1" Text="Init" Style="{StaticResource EcColHead}"
                         ToolTip="Create this group on server startup" />
              <TextBlock Grid.Column="2" Text="Load" Style="{StaticResource EcColHead}"
                         ToolTip="Restore this group from persistence storage" />
              <TextBlock Grid.Column="3" Text="Respawn" Style="{StaticResource EcColHead}"
                         ToolTip="Respawn this group at runtime" />
              <TextBlock Grid.Column="4" Text="Save" Style="{StaticResource EcColHead}"
                         ToolTip="Persist this group to storage" />
              <TextBlock Grid.Column="5" Text="" />
            </Grid>

            <ItemsControl ItemsSource="{Binding Groups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Padding="0,4">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="86" /><ColumnDefinition Width="86" />
                        <ColumnDefinition Width="86" /><ColumnDefinition Width="86" />
                        <ColumnDefinition Width="64" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Display}" FontSize="13" Margin="2,0,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <ui:SymbolIcon Style="{StaticResource EcInfo}" ToolTip="{Binding Description}" />
                      </StackPanel>
                      <ui:ToggleSwitch Grid.Column="1" HorizontalAlignment="Center" IsChecked="{Binding Init, Mode=TwoWay}" />
                      <ui:ToggleSwitch Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding Load, Mode=TwoWay}" />
                      <ui:ToggleSwitch Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding Respawn, Mode=TwoWay}" />
                      <ui:ToggleSwitch Grid.Column="4" HorizontalAlignment="Center" IsChecked="{Binding Save, Mode=TwoWay}" />
                      <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon ArrowReset24}" Padding="5" FontSize="12"
                                   Visibility="{Binding IsKnown, Converter={StaticResource EcBoolToVis}}"
                                   ToolTip="Reset this group to its engine defaults" Click="OnResetRowClick" Tag="{Binding}" />
                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Padding="5" FontSize="12" Appearance="Danger"
                                   Visibility="{Binding IsCustom, Converter={StaticResource EcBoolToVis}}"
                                   ToolTip="Remove this custom group" Click="OnRemoveRowClick" Tag="{Binding}" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add a known-but-missing group. Closed vocabulary — disabled when every standard group is present. -->
            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Add standard group" VerticalAlignment="Center" Margin="2,0,8,0"
                         Style="{StaticResource EcHint}" />
              <ComboBox Grid.Column="1" Margin="0,0,6,0" FontSize="12"
                        ItemsSource="{Binding MissingKnown}" SelectedItem="{Binding SelectedMissing, Mode=TwoWay}"
                        IsEnabled="{Binding HasMissingKnown}"
                        ToolTip="A standard economy group not present in the file — added with its default flags." />
              <ui:Button Grid.Column="2" Content="Add" Icon="{ui:SymbolIcon Add24}"
                         IsEnabled="{Binding HasMissingKnown}" Click="OnAddKnownClick" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,8,0,0" FontSize="12"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
