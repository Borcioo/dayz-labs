<UserControl x:Class="Dzl.Tray.Controls.DictionaryManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
             x:Name="Root">
  <!-- DataContext = DictionaryManagerVm. Edits the game-honored dictionaries: the four base lists come
       from cfglimitsdefinition.xml; the Combos section edits cfglimitsdefinitionuser.xml. Every edit routes
       through the VM → DictionaryService → refreshes the Types editor suggestions + re-lints.
       A UserControl does NOT inherit the host window's resources at realize time — declare local styles
       here; only DynamicResource theme brushes (resolved late) are safe to reference. -->
  <UserControl.Resources>
    <Style x:Key="DictColHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="DictColCount" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- One reusable editable-list column (DataContext = a DictionaryListVm). -->
    <DataTemplate x:Key="DictColumnTemplate">
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
              CornerRadius="8" Padding="10" Margin="0,0,8,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title -->
            <RowDefinition Height="Auto" />  <!-- count -->
            <RowDefinition Height="*" />     <!-- list -->
            <RowDefinition Height="Auto" />  <!-- add row -->
            <RowDefinition Height="Auto" />  <!-- actions -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource DictColHeader}" />
          <TextBlock Grid.Row="1" Text="{Binding CountLabel}" Style="{StaticResource DictColCount}" />

          <ListBox Grid.Row="2" MinHeight="160"
                   ItemsSource="{Binding Names}"
                   SelectedItem="{Binding Selected, Mode=TwoWay}"
                   Background="Transparent" BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" FontSize="12" Padding="0,1"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12"
                        PlaceholderText="{Binding Hint}"
                        Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                        KeyDown="OnAddKeyDown" Tag="{Binding}" />
            <ui:Button Grid.Column="1" Content="Add" Click="OnAddClick" Tag="{Binding}"
                       ToolTip="Add to the dictionary (cfglimitsdefinition.xml)" />
          </Grid>

          <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
            <ui:Button Content="Rename" Margin="0,0,4,0" FontSize="12" Click="OnRenameClick" Tag="{Binding}"
                       ToolTip="Rename the selected entry" />
            <ui:Button Content="Remove" FontSize="12" Click="OnRemoveClick" Tag="{Binding}"
                       ToolTip="Remove the selected entry (warns if any loaded type uses it)" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />     <!-- four base lists -->
      <RowDefinition Height="Auto" />  <!-- combos -->
      <RowDefinition Height="Auto" />  <!-- status -->
    </Grid.RowDefinitions>

    <!-- Four editable base lists side by side -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <ContentControl Grid.Column="0" Content="{Binding Categories}" ContentTemplate="{StaticResource DictColumnTemplate}" />
      <ContentControl Grid.Column="1" Content="{Binding Tags}"       ContentTemplate="{StaticResource DictColumnTemplate}" />
      <ContentControl Grid.Column="2" Content="{Binding Usage}"      ContentTemplate="{StaticResource DictColumnTemplate}" />
      <ContentControl Grid.Column="3" Content="{Binding Value}"      ContentTemplate="{StaticResource DictColumnTemplate}" />
    </Grid>

    <!-- Combos (cfglimitsdefinitionuser.xml) — secondary, compact -->
    <Border Grid.Row="1" Margin="0,10,8,0" Padding="10" CornerRadius="8"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" /><ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8"
                   Text="Named combos (cfglimitsdefinitionuser.xml)"
                   Style="{StaticResource DictColHeader}" />

        <!-- Left: combo list + add/remove -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="140" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <ListBox Grid.Row="0" ItemsSource="{Binding Combos}"
                   SelectedItem="{Binding SelectedCombo, Mode=TwoWay}"
                   DisplayMemberPath="Display"
                   Background="Transparent" BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" />
          <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" Margin="0,0,4,0" FontSize="12" PlaceholderText="new combo name"
                        Text="{Binding NewComboName, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="1" Width="76" Margin="0,0,4,0" VerticalAlignment="Center"
                      SelectedValuePath="Tag" SelectedValue="{Binding NewComboIsUsage, Mode=TwoWay, Converter={x:Static ctl:DictionaryManager.UsageBoolConv}}"
                      ToolTip="combo kind">
              <ComboBoxItem Content="usage" Tag="usage" />
              <ComboBoxItem Content="value" Tag="value" />
            </ComboBox>
            <ui:Button Grid.Column="2" Content="Add" Click="OnAddComboClick" />
          </Grid>
          <ui:Button Grid.Row="2" Content="Remove combo" Margin="0,6,0,0" FontSize="12"
                     Click="OnRemoveComboClick" HorizontalAlignment="Left" />
        </Grid>

        <!-- Right: member editor for the selected combo -->
        <StackPanel Grid.Row="1" Grid.Column="1">
          <TextBlock FontSize="11" Margin="0,0,0,4"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                     Text="Members of the selected combo (sourced from the base dictionary):" />
          <ctl:ChipMultiSelect x:Name="MemberChips"
                               Items="{Binding SelectedCombo.Members, Mode=OneWay}"
                               Suggestions="{Binding SelectedComboMemberSource}"
                               AddHint="add member…"
                               Changed="OnComboMembersChanged" />
          <TextBlock FontSize="11" Margin="0,4,0,0"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                     Text="Select a combo on the left to edit its members."
                     Visibility="{Binding SelectedCombo, Converter={x:Static ctl:DictionaryManager.NullToVisConv}}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Status -->
    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12"
               Text="{Binding Status}"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</UserControl>
