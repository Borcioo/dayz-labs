<ui:FluentWindow x:Class="Dzl.Tray.GitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Git" Width="720" Height="640" MinWidth="560" MinHeight="480"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16,8,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- title -->
      <RowDefinition Height="Auto" />  <!-- branch bar -->
      <RowDefinition Height="Auto" />  <!-- changes header -->
      <RowDefinition Height="*" />     <!-- files -->
      <RowDefinition Height="Auto" />  <!-- commit -->
      <RowDefinition Height="Auto" />  <!-- footer -->
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" x:Name="TitleBarCtl" Title="Git" ShowMaximize="False" ShowMinimize="False" Margin="0,0,0,8" />

    <!-- Branch bar -->
    <Grid Grid.Row="1" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Branch" VerticalAlignment="Center" Margin="0,0,8,0"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
      <ComboBox Grid.Column="1" x:Name="BranchCombo" VerticalAlignment="Center" Margin="0,0,8,0" />
      <ui:Button Grid.Column="2" Content="Checkout" Margin="0,0,8,0" Click="OnCheckout" />
      <ui:Button Grid.Column="3" Content="New" Icon="{ui:SymbolIcon BranchFork24}" Margin="0,0,16,0" Click="OnNewBranch" />
      <ui:Button Grid.Column="4" Content="Pull" Icon="{ui:SymbolIcon ArrowDownload24}" Margin="0,0,8,0" Click="OnPull" />
      <ui:Button Grid.Column="5" x:Name="PushBtn" Content="Push" Icon="{ui:SymbolIcon ArrowUpload24}" Appearance="Primary" Click="OnPush" />
    </Grid>

    <!-- Changes header -->
    <Grid Grid.Row="2" Margin="0,0,0,6">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold">
        <Run Text="Changes" /><Run Text=" " /><Run x:Name="AheadBehind" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontWeight="Normal" />
      </TextBlock>
      <ui:Button Grid.Column="1" Content="Stage all" Margin="0,0,8,0" Click="OnStageAll" />
      <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon ArrowSync24}" ToolTip="Refresh" Click="OnRefreshClick" />
    </Grid>

    <!-- Files -->
    <Border Grid.Row="3" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
      <Grid>
        <TextBlock x:Name="EmptyHint" Text="No changes — working tree clean." Margin="12" FontSize="12"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
        <ListBox x:Name="FilesList" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" IsChecked="{Binding IsStaged}" Click="OnToggleStage" Margin="2,0,8,0" VerticalAlignment="Center" />
                <Border Grid.Column="1" CornerRadius="4" Padding="6,1" Margin="0,0,8,0" VerticalAlignment="Center"
                        Background="{Binding StatusBg}">
                  <TextBlock Text="{Binding Status}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" Foreground="{Binding StatusFg}" />
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding Path}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <!-- Commit -->
    <Grid Grid.Row="4" Margin="0,12,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <ui:TextBox Grid.Column="0" x:Name="CommitMsg" PlaceholderText="commit message…" Margin="0,0,8,0"
                  AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56" VerticalScrollBarVisibility="Auto" />
      <ui:Button Grid.Column="1" Content="Commit staged" Icon="{ui:SymbolIcon Checkmark24}" Appearance="Primary"
                 VerticalAlignment="Stretch" Click="OnCommit" />
    </Grid>

    <!-- Footer -->
    <Grid Grid.Row="5" Margin="0,10,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <ui:Button Grid.Column="0" x:Name="InitBtn" Content="Init repo" Icon="{ui:SymbolIcon Add24}" Margin="0,0,8,0"
                 Visibility="Collapsed" Click="OnInit" />
      <TextBlock Grid.Column="1" x:Name="StatusText" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
      <ui:Button Grid.Column="2" Content="Open terminal" Icon="{ui:SymbolIcon WindowConsole20}" Click="OnOpenTerminal" />
    </Grid>
  </Grid>
</ui:FluentWindow>
