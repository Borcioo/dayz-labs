<UserControl x:Class="Dzl.Tray.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="640" HorizontalAlignment="Left">

      <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
        <ui:SymbolIcon Symbol="Gauge24" FontSize="30" VerticalAlignment="Center" Margin="0,0,12,0" />
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="DayZ Labs" FontSize="24" FontWeight="SemiBold" />
          <TextBlock x:Name="VersionText" FontSize="13"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>
      </StackPanel>

      <TextBlock TextWrapping="Wrap" Margin="0,12,0,16"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                 Text="dzl — a DayZ mod-development launcher for Windows. Server &amp; client lifecycle, ordered mods, log diagnosis, a validating build pipeline, and Central Economy editors, behind a CLI, an MCP server, and this tray app." />

      <!-- Updates -->
      <Border CornerRadius="8" BorderThickness="1" Padding="14" Margin="0,0,0,14"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}"
              Background="{DynamicResource ControlFillColorDefaultBrush}">
        <StackPanel>
          <TextBlock Text="Updates" FontWeight="SemiBold" Margin="0,0,0,6" />
          <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                     Text="The app auto-checks on launch and updates itself from GitHub Releases. You can also check now." />
          <StackPanel Orientation="Horizontal">
            <ui:Button x:Name="CheckUpdatesBtn" Content="Check for updates"
                       Icon="{ui:SymbolIcon ArrowClockwise24}" Click="OnCheckUpdates" />
            <TextBlock x:Name="UpdateStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                       FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Links -->
      <TextBlock Text="Links" FontWeight="SemiBold" Margin="0,0,0,8" />
      <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
        <ui:Button Content="GitHub repo" Icon="{ui:SymbolIcon Code24}" Margin="0,0,8,0"
                   Tag="https://github.com/Borcioo/dayz-labs" Click="OnOpenLink" />
        <ui:Button Content="Website" Icon="{ui:SymbolIcon Globe24}" Margin="0,0,8,0"
                   Tag="https://borcioo.github.io/dayz-labs/" Click="OnOpenLink" />
        <ui:Button Content="Releases" Icon="{ui:SymbolIcon Tag24}" Margin="0,0,8,0"
                   Tag="https://github.com/Borcioo/dayz-labs/releases" Click="OnOpenLink" />
      </StackPanel>

      <!-- License -->
      <TextBlock Text="License" FontWeight="SemiBold" Margin="0,0,0,6" />
      <TextBlock TextWrapping="Wrap" FontSize="13"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}">
        <Run Text="Licensed under the GNU General Public License v3.0." />
        <Hyperlink Tag="https://github.com/Borcioo/dayz-labs/blob/main/LICENSE" Click="OnOpenHyperlink">
          <Run Text="View the license" />
        </Hyperlink><Run Text="." />
      </TextBlock>
      <TextBlock Text="© 2026 Borcioo (DayZ Labs)" FontSize="12" Margin="0,4,0,0"
                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

      <!-- Disclaimer -->
      <TextBlock Text="Disclaimer" FontWeight="SemiBold" Margin="0,16,0,6" />
      <TextBlock TextWrapping="Wrap" FontSize="12"
                 Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                 Text="DayZ Labs (dzl) is an unofficial, community-made tool, not affiliated with or authorized by Bohemia Interactive a.s. Bohemia Interactive, ARMA, DAYZ, ENFUSION and all associated logos and designs are trademarks or registered trademarks of Bohemia Interactive a.s." />

    </StackPanel>
  </ScrollViewer>
</UserControl>
