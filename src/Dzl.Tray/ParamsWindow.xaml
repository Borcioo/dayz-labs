<Window x:Class="Dzl.Tray.ParamsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Params" Height="420" Width="520"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6"
                   Text="One flag per line. Blank lines are ignored." Foreground="#555" />
        <WrapPanel DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Reset to defaults" Click="OnReset" Padding="8,3" Margin="0,0,8,0" />
            <Button Content="OK" Click="OnOk" IsDefault="True" Padding="14,3" Margin="0,0,8,0" />
            <Button Content="Cancel" Click="OnCancel" IsCancel="True" Padding="14,3" />
        </WrapPanel>
        <TextBox x:Name="ParamsBox"
                 AcceptsReturn="True" TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
