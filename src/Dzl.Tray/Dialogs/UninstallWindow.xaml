<ui:FluentWindow x:Class="Dzl.Tray.Dialogs.UninstallWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Uninstall dzl"
    Width="470" SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="Uninstall dzl" ShowMaximize="False" ShowMinimize="False" />

    <StackPanel Grid.Row="1" Margin="20,8,20,20">
      <TextBlock Text="Remove dzl from your computer?"
                 FontSize="16" FontWeight="Medium" Margin="0,0,0,8" />
      <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,0,0,16"
                 Text="The app, its PATH entry and Start-menu shortcuts are removed. Your mod project folders and signing keys are never touched." />
      <CheckBox x:Name="WipeData" Content="Also delete settings &amp; cache" />
      <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.6" Margin="28,2,0,0"
                 Text="Removes everything under %LocalAppData%\dzl — config, presets, logs, Steam login." />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
        <ui:Button Content="Cancel" MinWidth="90" Margin="0,0,8,0" Click="OnCancel" />
        <ui:Button Content="Uninstall" Appearance="Danger" MinWidth="90" Click="OnUninstall" />
      </StackPanel>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
