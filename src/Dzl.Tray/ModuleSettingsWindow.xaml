<ui:FluentWindow x:Class="Dzl.Tray.ModuleSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Mods settings" Width="640" Height="560"
        MinWidth="520" MinHeight="460"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16,8,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="Mods settings" ShowMaximize="False" ShowMinimize="False" Margin="0,0,0,8" />

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="0,0,8,0">
        <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="Settings that affect the Mods page. These are the same values as the global Settings — saving here applies immediately." />

        <TextBlock Text="Projects root" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock FontSize="11" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="Where dzl creates and manages your mod source folders (mods\, build\, keys\)." />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <ui:TextBox x:Name="CfgProjectsRoot" Grid.Column="0" PlaceholderText="e.g. D:\DayzProjects" />
          <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}" Margin="8,0,0,0"
                     Tag="CfgProjectsRoot" Click="OnBrowse" />
        </Grid>

        <TextBlock Text="Work-drive source (P:)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock FontSize="11" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="The real folder P: is mounted from (junctions are anchored here so they survive unmounts). Blank = auto-detect from DayZ Tools." />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <ui:TextBox x:Name="CfgWorkDriveSource" Grid.Column="0" PlaceholderText="blank = auto-detect" />
          <ui:Button Grid.Column="1" Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}" Margin="8,0,0,0"
                     Tag="CfgWorkDriveSource" Click="OnBrowse" />
        </Grid>

        <CheckBox x:Name="CfgAutomountWorkDrive" Content="Auto-mount P: when the app starts" Margin="0,0,0,14" />

        <TextBlock Text="Scan roots" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock FontSize="11" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="Folders scanned to discover existing mods (one per line)." />
        <ui:TextBox x:Name="CfgScanRoots" MinHeight="92" AcceptsReturn="True" TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" Margin="0,0,0,4" />
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"
                 Foreground="#FF6B6B" />
      <ui:Button Content="Save" Appearance="Primary" Icon="{ui:SymbolIcon Save24}" Click="OnSave" Margin="0,0,8,0" />
      <ui:Button Content="Cancel" Click="OnCancel" />
    </StackPanel>
  </Grid>
</ui:FluentWindow>
