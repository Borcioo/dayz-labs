<ui:FluentWindow x:Class="Dzl.Tray.SteamLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sign in to Steam" Width="440" Height="600"
        ResizeMode="NoResize" WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16,8,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ui:TitleBar Grid.Row="0" Title="Sign in to Steam" ShowMaximize="False" ShowMinimize="False" Margin="0,0,0,8" />

    <TabControl Grid.Row="1">
      <TabItem Header="Scan QR">
        <StackPanel Margin="12">
          <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                     Text="Open the Steam mobile app → Steam Guard → scan the code. Sign-in completes when you approve on your phone." />
          <Border Width="280" Height="280" HorizontalAlignment="Center" CornerRadius="6"
                  Background="White" Padding="8">
            <Image x:Name="QrImage" Stretch="Uniform" />
          </Border>
          <TextBlock x:Name="QrStatus" Margin="0,12,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>
      </TabItem>

      <TabItem Header="Password">
        <StackPanel Margin="12">
          <TextBlock Text="Steam username" Margin="0,0,0,4" />
          <ui:TextBox x:Name="UserBox" Margin="0,0,0,10" />
          <TextBlock Text="Password" Margin="0,0,0,4" />
          <PasswordBox x:Name="PassBox" Margin="0,0,0,10" Height="34" />
          <StackPanel x:Name="GuardPanel" Visibility="Collapsed" Margin="0,0,0,10">
            <TextBlock x:Name="GuardPrompt" TextWrapping="Wrap" Margin="0,0,0,4" />
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <ui:TextBox x:Name="GuardBox" Grid.Column="0" Margin="0,0,8,0" />
              <ui:Button x:Name="GuardOk" Grid.Column="1" Content="OK" Click="OnGuardOk" />
            </Grid>
          </StackPanel>
          <ui:Button x:Name="SignInBtn" Content="Sign in" Appearance="Primary" Icon="{ui:SymbolIcon Person24}" Click="OnSignIn" />
          <TextBlock x:Name="PassStatus" Margin="0,12,0,0" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>
      </TabItem>
    </TabControl>

    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
               Text="dzl signs in via SteamKit2; your refresh token is stored encrypted (DPAPI) locally and used only to subscribe to Workshop items. Password is sent encrypted to Steam, never stored." />
  </Grid>
</ui:FluentWindow>
