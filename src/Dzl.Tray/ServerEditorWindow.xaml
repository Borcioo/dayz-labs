<ui:FluentWindow x:Class="Dzl.Tray.ServerEditorWindow"
        xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dzl.Tray"
        xmlns:vm="clr-namespace:Dzl.Tray.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        Title="Server" Width="900" Height="720"
        MinWidth="720" MinHeight="540"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="DarkDataGrid" TargetType="DataGrid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="RowBackground" Value="Transparent" />
      <Setter Property="AlternatingRowBackground" Value="Transparent" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
      <Setter Property="RowHeight" Value="32" />
      <Setter Property="ColumnHeaderHeight" Value="34" />
      <Setter Property="CanUserResizeRows" Value="False" />
    </Style>
    <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
    </Style>
    <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridCell">
            <Border Background="{TemplateBinding Background}" Padding="8,0">
              <ContentPresenter VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="{Binding ActivePreset, StringFormat='Server: {0}'}">
      <ui:TitleBar.TrailingContent>
        <ctl:ScreenshotButton VerticalAlignment="Center" Margin="0,0,8,0" />
      </ui:TitleBar.TrailingContent>
      <ui:TitleBar.Icon>
        <ui:SymbolIcon Symbol="Server24" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>

    <TabControl x:Name="Tabs" Grid.Row="1" Margin="12,4,12,0" Background="Transparent" BorderThickness="0">

      <!-- ===== Settings ===== -->
      <TabItem Header="Settings">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="4,12,4,4">

            <!-- where the files come from -->
            <ui:Card Margin="0,0,0,16" Padding="14">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <ui:SymbolIcon Symbol="Info24" FontSize="16" Margin="0,0,8,0"
                                 Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" />
                  <TextBlock Text="Where this server's files live" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <Border Grid.Column="0" CornerRadius="4" Padding="8,5" VerticalAlignment="Center"
                          Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <TextBlock Text="{Binding ActiveServerDir, Mode=OneWay}" FontFamily="Cascadia Mono, Consolas"
                               FontSize="12" TextTrimming="CharacterEllipsis" />
                  </Border>
                  <ui:Button Grid.Column="1" Content="Open folder" Icon="{ui:SymbolIcon FolderOpen24}"
                             Margin="8,0,0,0" Click="OnOpenInstanceFolder" />
                </Grid>
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Opacity="0.75"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="serverDZ.cfg, mpmissions and profiles (logs) all live in this folder. The mission is copied from your DayZ install when the server is created. Central Economy persistence (the mission's storage_* folders) is generated fresh on first run — wipe it to reset the world/persistence." />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                  <ui:Button Content="Wipe persistence" Icon="{ui:SymbolIcon Delete24}" Click="OnWipePersistence" />
                  <TextBlock x:Name="WipeStatus" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
              </StackPanel>
            </ui:Card>

            <!-- rename / clone -->
            <Grid Margin="0,0,0,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox x:Name="SrvRenameBox" Grid.Column="0" Margin="0,0,8,0" PlaceholderText="rename to…" />
              <ui:Button Grid.Column="1" Content="Rename" Icon="{ui:SymbolIcon Rename24}" Click="OnRenameServer" />
              <ui:TextBox x:Name="SrvCloneBox" Grid.Column="3" Margin="0,0,8,0" PlaceholderText="clone as…" />
              <ui:Button Grid.Column="4" Content="Clone" Icon="{ui:SymbolIcon Copy24}" Click="OnCloneServer" />
            </Grid>

            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Port" Style="{StaticResource FieldLabel}" />
                  <local:InfoTip Text="{x:Static local:HelpText.Port}" />
                </StackPanel>
                <ui:TextBox x:Name="CfgPort" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Mission" Style="{StaticResource FieldLabel}" />
                  <local:InfoTip Text="{x:Static local:HelpText.Mission}" />
                </StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <ui:TextBox x:Name="CfgMission" Grid.Column="0" />
                  <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Click="OnBrowseMission" />
                </Grid>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Config name (serverDZ.cfg)" Style="{StaticResource FieldLabel}" />
                  <local:InfoTip Text="{x:Static local:HelpText.ConfigName}" />
                </StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <ui:TextBox x:Name="CfgConfigName" Grid.Column="0" />
                  <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Click="OnBrowseConfigName" />
                </Grid>
                <TextBlock Text="Mode" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="SrvMode" SelectedIndex="0">
                  <ComboBoxItem Content="debug" />
                  <ComboBoxItem Content="normal" />
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Player name" Style="{StaticResource FieldLabel}" />
                  <local:InfoTip Text="{x:Static local:HelpText.PlayerName}" />
                </StackPanel>
                <ui:TextBox x:Name="CfgPlayerName" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Connect IP" Style="{StaticResource FieldLabel}" />
                  <local:InfoTip Text="{x:Static local:HelpText.ConnectIp}" />
                </StackPanel>
                <ui:TextBox x:Name="CfgConnectIp" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Server profiles" Style="{StaticResource FieldLabel}" />
                  <local:InfoTip Text="{x:Static local:HelpText.ProfilesDir}" />
                </StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <ui:TextBox x:Name="CfgProfilesPath" Grid.Column="0" />
                  <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="CfgProfilesPath" Click="OnBrowseInto" />
                </Grid>
                <TextBlock Text="Client profiles" Style="{StaticResource FieldLabel}" />
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <ui:TextBox x:Name="CfgClientProfilesPath" Grid.Column="0" />
                  <ui:Button Grid.Column="1" Content="📁" Margin="8,0,0,0" Tag="CfgClientProfilesPath" Click="OnBrowseInto" />
                </Grid>
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
              <ui:Button Content="Save settings" Appearance="Primary" Icon="{ui:SymbolIcon Save24}" Click="OnSaveServer" />
              <ui:Button Content="Revert" Icon="{ui:SymbolIcon ArrowUndo24}" Margin="8,0,0,0" Click="OnRevertServer" />
              <TextBlock x:Name="SrvError" VerticalAlignment="Center" Margin="12,0,0,0"
                         Foreground="#FF6B6B" Visibility="Collapsed" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ===== Mods (loadout) ===== -->
      <TabItem Header="Mods">
        <Grid Margin="4,12,4,4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{Binding ModsSummary}" FontSize="12" Margin="0,0,0,8"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ui:Button Content="Rescan" Icon="{ui:SymbolIcon ArrowSync24}" Margin="0,0,8,0" Command="{Binding RescanCommand}" />
            <Border Width="1" Margin="4,2,12,2" Background="{DynamicResource ControlElevationBorderBrush}" />
            <ui:Button Icon="{ui:SymbolIcon ArrowUpload24}" ToolTip="Move to top" Margin="0,0,8,0" Command="{Binding ToTopCommand}" />
            <ui:Button Icon="{ui:SymbolIcon ArrowUp24}" ToolTip="Move up" Margin="0,0,8,0" Command="{Binding MoveUpCommand}" />
            <ui:Button Icon="{ui:SymbolIcon ArrowDown24}" ToolTip="Move down" Margin="0,0,8,0" Command="{Binding MoveDownCommand}" />
            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" ToolTip="Move to bottom" Command="{Binding ToBottomCommand}" />
          </StackPanel>
          <Border Grid.Row="2" CornerRadius="6" BorderThickness="1"
                  BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                  Background="{DynamicResource ControlFillColorDefaultBrush}">
            <DataGrid x:Name="ModsGrid"
                      Style="{StaticResource DarkDataGrid}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                      RowStyle="{StaticResource DarkDataGridRow}"
                      CellStyle="{StaticResource DarkDataGridCell}"
                      ItemsSource="{Binding ModsView}"
                      SelectedItem="{Binding SelectedMod, Mode=TwoWay}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="False"
                      dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True"
                      dd:DragDrop.DropHandler="{Binding ModsDropHandler}">
              <DataGrid.Columns>
                <DataGridTemplateColumn Width="44" Header="On">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="0" Padding="0"
                                IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="40" Header="#" IsReadOnly="True" Binding="{Binding Order}" />
                <DataGridTextColumn Header="Name" Width="*" IsReadOnly="True" Binding="{Binding Name}">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                      <Setter Property="VerticalAlignment" Value="Center" />
                      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                      <Setter Property="FontWeight" Value="Medium" />
                    </Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="92" Header="Type">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border CornerRadius="9" Padding="7,1" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{Binding KindBg}">
                        <TextBlock Text="{Binding KindLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding KindFg}" />
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="110" Header="Side">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{x:Static vm:MainViewModel.Sides}"
                                SelectedItem="{Binding Side, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderThickness="0" Background="Transparent" VerticalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Path" Width="2*" IsReadOnly="True" Binding="{Binding Path}">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                      <Setter Property="VerticalAlignment" Value="Center" />
                      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                      <Setter Property="FontSize" Value="12" />
                    </Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="80">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border CornerRadius="9" Padding="8,2" Background="#5A1F1F"
                              HorizontalAlignment="Left" VerticalAlignment="Center"
                              Visibility="{Binding Missing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="missing" FontSize="11" FontWeight="SemiBold" Foreground="#FF6B6B" />
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>
      </TabItem>

      <!-- ===== Params ===== -->
      <TabItem Header="Params">
        <StackPanel Margin="4,12,4,4">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Target" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="ParamTarget" Width="120" SelectedIndex="0" SelectionChanged="OnParamSlotChanged">
              <ComboBoxItem Content="server" />
              <ComboBoxItem Content="client" />
            </ComboBox>
            <TextBlock Text="Mode" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="16,0,8,0" />
            <ComboBox x:Name="ParamMode" Width="120" SelectedIndex="0" SelectionChanged="OnParamSlotChanged">
              <ComboBoxItem Content="debug" />
              <ComboBoxItem Content="normal" />
            </ComboBox>
          </StackPanel>
          <TextBlock Text="One flag per line" Style="{StaticResource FieldLabel}" />
          <TextBox x:Name="ParamsEditor" Height="240" AcceptsReturn="True"
                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                   VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />
          <StackPanel Orientation="Horizontal">
            <ui:Button Content="Save params" Appearance="Primary" Icon="{ui:SymbolIcon Save24}" Click="OnSaveParams" />
            <ui:Button Content="Reset to defaults" Icon="{ui:SymbolIcon ArrowReset24}" Margin="8,0,0,0" Click="OnResetParams" />
          </StackPanel>
        </StackPanel>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
      <ui:Button Content="Close" Icon="{ui:SymbolIcon Dismiss24}" Click="OnClose" />
    </StackPanel>
  </Grid>
</ui:FluentWindow>
