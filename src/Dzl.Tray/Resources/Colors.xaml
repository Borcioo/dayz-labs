<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App-defined brushes beyond the WPF-UI theme palette. These are the literal colors
         that used to be inlined in the BoolToBrushConverter instances in App.xaml; naming
         them here keeps the hex in one place and lets the converter config read by key.
         (WPF-UI theme brushes like TextFillColorPrimaryBrush are NOT redefined here.) -->

    <!-- "On" / active accents -->
    <SolidColorBrush x:Key="FlagActiveBrush" Color="#7CE3A1" />   <!-- CE flag glyph: active -->
    <SolidColorBrush x:Key="StatusUpBrush" Color="#4CAF50" />     <!-- status dot: up / online -->

    <!-- "Off" / muted greys -->
    <SolidColorBrush x:Key="FlagMutedBrush" Color="#555B63" />    <!-- CE flag glyph: inactive -->
    <SolidColorBrush x:Key="StatusDownBrush" Color="#6E6E6E" />   <!-- status dot: down / offline -->

    <!-- Mission-source health dot (dashboard "Mission source" card) -->
    <SolidColorBrush x:Key="MissionOkBrush" Color="#4CAF50" />    <!-- loads the instance's mission -->
    <SolidColorBrush x:Key="MissionWarnBrush" Color="#E0A030" /> <!-- loads the install's mission -->
    <SolidColorBrush x:Key="MissionErrorBrush" Color="#E24B4A" /> <!-- mission folder missing -->

    <!-- CE "active row" highlight — the single source of truth for the selected/hover look shared by the
         Dictionaries ListBox rows AND every Central-Economy DataGrid row, so the active row is identical on
         every CE tab. Change the colour here, not per-tab. -->
    <SolidColorBrush x:Key="CeRowSelectedBrush" Color="#1F2A3A" />   <!-- selected: muted navy -->
    <SolidColorBrush x:Key="CeRowHoverBrush" Color="#14FFFFFF" />    <!-- hover: faint white wash (~8% white) -->
    <SolidColorBrush x:Key="CeAccentBarBrush" Color="#4FA3FF" />     <!-- left accent bar on the nav-rail selection -->

</ResourceDictionary>
