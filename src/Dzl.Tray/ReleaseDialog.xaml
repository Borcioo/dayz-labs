<ui:FluentWindow x:Class="Dzl.Tray.ReleaseDialog"
        xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Create release" Width="560" Height="600" MinWidth="480" MinHeight="520"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16,8,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" x:Name="TitleBarCtl" Title="Create release" ShowMaximize="False" ShowMinimize="False" Margin="0,0,0,8">
      <ui:TitleBar.TrailingContent>
        <ctl:ScreenshotButton VerticalAlignment="Stretch" />
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="0,0,8,0">
        <TextBlock Text="Tag" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ui:TextBox x:Name="TagBox" PlaceholderText="e.g. v1.0.0" Margin="0,0,0,12" />

        <TextBlock Text="Title (optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ui:TextBox x:Name="TitleBox" PlaceholderText="defaults to &quot;&lt;mod&gt; &lt;tag&gt;&quot;" Margin="0,0,0,12" />

        <TextBlock Text="Target branch (optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ui:TextBox x:Name="TargetBox" PlaceholderText="defaults to the current branch" Margin="0,0,0,12" />

        <CheckBox x:Name="GenerateNotes" Content="Auto-generate release notes from commits" IsChecked="True"
                  Checked="OnGenerateToggled" Unchecked="OnGenerateToggled" Margin="0,0,0,8" />
        <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ui:TextBox x:Name="NotesBox" PlaceholderText="release notes (Markdown)…" AcceptsReturn="True" TextWrapping="Wrap"
                    MinHeight="120" VerticalScrollBarVisibility="Auto" IsEnabled="False" Margin="0,0,0,12" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <CheckBox x:Name="Prerelease" Content="Pre-release" Margin="0,0,20,0" />
          <CheckBox x:Name="Draft" Content="Draft" />
        </StackPanel>

        <CheckBox x:Name="AttachBuilt" Content="Attach the built @mod PBO(s) as assets" Margin="0,0,0,4" />
        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap"
                   Text="Uploads the .pbo files from the mod's build\@&lt;Mod&gt;\Addons folder (build it first)." />
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12" Foreground="#FF6B6B" />
      <ui:Button Content="Create release" Appearance="Primary" Icon="{ui:SymbolIcon Tag24}" Click="OnCreate" Margin="0,0,8,0" />
      <ui:Button Content="Cancel" Click="OnCancel" />
    </StackPanel>
  </Grid>
</ui:FluentWindow>
