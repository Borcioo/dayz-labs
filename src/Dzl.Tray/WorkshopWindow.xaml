<ui:FluentWindow x:Class="Dzl.Tray.WorkshopWindow"
        xmlns:ctl="clr-namespace:Dzl.Tray.Controls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dzl.Tray"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Steam Workshop" Width="1180" Height="800"
        MinWidth="900" MinHeight="600"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
  </Window.Resources>

  <Grid Margin="16,8,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- title -->
      <RowDefinition Height="Auto" />  <!-- sort/search toolbar -->
      <RowDefinition Height="*" />     <!-- filters | results | details -->
      <RowDefinition Height="Auto" />  <!-- subscribed -->
      <RowDefinition Height="Auto" />  <!-- load more + status -->
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="Steam Workshop" ShowMaximize="True" ShowMinimize="False" Margin="0,0,0,8">
      <ui:TitleBar.TrailingContent>
        <ctl:ScreenshotButton VerticalAlignment="Center" Margin="0,0,8,0" />
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <!-- Toolbar + gating banners -->
    <StackPanel Grid.Row="1">
      <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ComboBox Grid.Column="0" Width="170" Margin="0,0,8,0" VerticalAlignment="Center"
                  ItemsSource="{Binding WorkshopSorts}" SelectedItem="{Binding SelectedSort}" DisplayMemberPath="Label"
                  ToolTip="Sort order" />
        <ComboBox Grid.Column="1" Width="130" Margin="0,0,12,0" VerticalAlignment="Center"
                  ItemsSource="{Binding WorkshopTimeFrames}" SelectedItem="{Binding SelectedTimeFrame}" DisplayMemberPath="Label"
                  Visibility="{Binding ShowTimeFrame, Converter={StaticResource BoolToVis}}" ToolTip="Time frame" />
        <ui:TextBox Grid.Column="2" PlaceholderText="search the DayZ Workshop…" Margin="0,0,8,0"
                    Text="{Binding WorkshopQuery, UpdateSourceTrigger=PropertyChanged}" />
        <ui:Button Grid.Column="3" Content="Search" Icon="{ui:SymbolIcon Search24}" Appearance="Primary" Margin="0,0,8,0" Click="OnSearch" />
        <ui:Button Grid.Column="4" Content="Add by ID" Icon="{ui:SymbolIcon ArrowDownload24}" Click="OnAddById" />
        <ui:Button Grid.Column="5" Icon="{ui:SymbolIcon Settings24}" ToolTip="Workshop settings (Steam / steamcmd)"
                   Margin="8,0,0,0" Appearance="Secondary" Click="OnWorkshopSettings" />
      </Grid>

      <!-- Warning: not signed in → Subscribe falls back to the Steam page -->
      <Border Margin="0,0,0,8" Padding="10" CornerRadius="6" Background="#3A2A0F" BorderBrush="#7A5A1F" BorderThickness="1"
              Visibility="{Binding SteamSignedIn, Converter={StaticResource InverseBoolToVis}}">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#F0C04A" />
          <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#F0D9A8"
                     Text="Not signed in to Steam — in-app Subscribe / Unsubscribe is disabled (Subscribe opens the Steam page instead)." />
          <ui:Button Grid.Column="2" Content="Sign in" Appearance="Primary" VerticalAlignment="Center" Margin="10,0,0,0" Click="OnSignInBanner" />
        </Grid>
      </Border>

      <!-- Warning: no steamcmd → Download disabled -->
      <Border Margin="0,0,0,8" Padding="10" CornerRadius="6" Background="#3A2A0F" BorderBrush="#7A5A1F" BorderThickness="1"
              Visibility="{Binding SteamCmdConfigured, Converter={StaticResource InverseBoolToVis}}">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#F0C04A" />
          <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#F0D9A8"
                     Text="steamcmd not configured — Download is disabled. Subscribe (Steam client) still works." />
          <ui:Button Grid.Column="2" Content="Configure" Appearance="Primary" VerticalAlignment="Center" Margin="10,0,0,0" Click="OnWorkshopSettings" />
        </Grid>
      </Border>
    </StackPanel>

    <!-- Filters | results | details -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="190" /><ColumnDefinition Width="*" /><ColumnDefinition Width="370" />
      </Grid.ColumnDefinitions>

      <!-- Filter rail -->
      <Border Grid.Column="0" CornerRadius="6" BorderThickness="1" Padding="10" Margin="0,0,12,0"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <TextBlock Text="FILTERS" FontSize="11" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding WorkshopFilters}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox Content="{Binding Name}" IsChecked="{Binding Selected, Mode=TwoWay}" Margin="0,2,0,2" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Results -->
      <Border Grid.Column="1" CornerRadius="6" BorderThickness="1" Margin="0,0,12,0"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}">
        <ListBox x:Name="ResultsList" ItemsSource="{Binding WorkshopResults}"
                 SelectedItem="{Binding SelectedWorkshopItem}" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch"
                 ScrollViewer.ScrollChanged="OnResultsScroll">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="6,8" />
              <Setter Property="Margin" Value="0" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <!-- Delicate bottom divider; subtle (not bright) selected/hover fill -->
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                            BorderThickness="0,0,0,1" BorderBrush="#18FFFFFF"
                            Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="#12FFFFFF" />
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="#1F2A3A" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="72" Height="72" CornerRadius="4" Margin="0,0,10,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                  <Image Source="{Binding PreviewUrl}" Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Title}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Id}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <!-- Details (enriched) -->
      <Border Grid.Column="2" CornerRadius="6" BorderThickness="1" Padding="12"
              BorderBrush="{DynamicResource ControlElevationBorderBrush}"
              DataContext="{Binding WorkshopDetail}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Height="190" CornerRadius="6" Margin="0,0,0,10"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
              <Image Source="{Binding PreviewUrl}" Stretch="Uniform" />
            </Border>
            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
            <TextBlock FontSize="11" Margin="0,2,0,8" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
              <Run Text="id " /><Run Text="{Binding Id, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding Subscriptions, Mode=OneWay}" /><Run Text=" subscribers" />
            </TextBlock>

            <!-- Meta block (size / dates / tags) -->
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Size" FontSize="11" Margin="0,0,12,2" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SizeText}" FontSize="11" Margin="0,0,0,2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Posted" FontSize="11" Margin="0,0,12,2" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CreatedText}" FontSize="11" Margin="0,0,0,2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Updated" FontSize="11" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UpdatedText}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Grid>

            <TextBlock FontSize="11" FontWeight="SemiBold" Margin="0,0,0,2" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Tags" />
            <TextBlock Text="{Binding Tags}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <ui:Button Content="Subscribe" Icon="{ui:SymbolIcon Star24}" Appearance="Primary"
                         Tag="{Binding Id}" Click="OnSubscribe" Margin="0,0,8,0"
                         Visibility="{Binding DataContext.DetailSubscribed, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Converter={StaticResource InverseBoolToVis}}" />
              <ui:Button Content="Unsubscribe" Icon="{ui:SymbolIcon Checkmark24}" Appearance="Secondary"
                         Tag="{Binding Id}" Click="OnUnsubscribe" Margin="0,0,8,0"
                         ToolTip="Subscribed — click to unsubscribe"
                         Visibility="{Binding DataContext.DetailSubscribed, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Converter={StaticResource BoolToVis}}" />
              <ui:Button Content="Download" Icon="{ui:SymbolIcon ArrowDownload24}" Tag="{Binding Id}" Click="OnDownload" Margin="0,0,8,0"
                         ToolTip="Download via steamcmd (configure steamcmd to enable)"
                         IsEnabled="{Binding DataContext.SteamCmdConfigured, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" />
              <ui:DropDownButton Content="Open" Icon="{ui:SymbolIcon Open24}" ToolTip="Open…">
                <ui:DropDownButton.Flyout>
                  <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Open in Steam (client)" Tag="{Binding Id}" Click="OnOpenInSteam">
                      <MenuItem.Icon><ui:SymbolIcon Symbol="Open24" /></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Steam page (web)" Tag="{Binding Id}" Click="OnOpenSteamWeb">
                      <MenuItem.Icon><ui:SymbolIcon Symbol="Globe24" /></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Show details in dzl" Tag="{Binding Id}" Click="OnShowInDzl">
                      <MenuItem.Icon><ui:SymbolIcon Symbol="Info24" /></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open folder (Explorer)" Tag="{Binding Id}" Click="OnOpenSubscribedFolder">
                      <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
                    </MenuItem>
                  </ContextMenu>
                </ui:DropDownButton.Flyout>
              </ui:DropDownButton>
            </StackPanel>
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Subscribed (Steam client) + Downloaded (steamcmd) -->
    <StackPanel Grid.Row="3">
      <Expander Header="Subscribed (Steam client)" Margin="0,12,0,0" IsExpanded="False">
        <Border CornerRadius="6" BorderThickness="1" MaxHeight="200" Margin="0,8,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding WorkshopSubscribed}" Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Id}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <ui:DropDownButton Icon="{ui:SymbolIcon Open24}" ToolTip="Open…" Margin="0,0,8,0">
                        <ui:DropDownButton.Flyout>
                          <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open in Steam (client)" Tag="{Binding Id}" Click="OnOpenInSteam">
                              <MenuItem.Icon><ui:SymbolIcon Symbol="Open24" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Steam page (web)" Tag="{Binding Id}" Click="OnOpenSteamWeb">
                              <MenuItem.Icon><ui:SymbolIcon Symbol="Globe24" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Show details in dzl" Tag="{Binding Id}" Click="OnShowInDzl">
                              <MenuItem.Icon><ui:SymbolIcon Symbol="Info24" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Open folder (Explorer)" Tag="{Binding Id}" Click="OnOpenSubscribedFolder">
                              <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
                            </MenuItem>
                          </ContextMenu>
                        </ui:DropDownButton.Flyout>
                      </ui:DropDownButton>
                      <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" ToolTip="Update via steamcmd" Tag="{Binding Id}" Click="OnDownload" Margin="0,0,8,0"
                                 IsEnabled="{Binding DataContext.SteamCmdConfigured, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" />
                      <ui:Button Icon="{ui:SymbolIcon LinkDismiss24}" Appearance="Danger" ToolTip="Unsubscribe" Tag="{Binding Id}" Click="OnUnsubscribe" />
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Expander>

      <Expander Header="Downloaded (steamcmd)" Margin="0,8,0,0" IsExpanded="False">
        <Border CornerRadius="6" BorderThickness="1" MaxHeight="200" Margin="0,8,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
              <TextBlock Text="Nothing downloaded via steamcmd yet — use Download on an item above."
                         Margin="10" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding WorkshopDownloaded.Count}" Value="0">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <ItemsControl ItemsSource="{Binding WorkshopDownloaded}" Margin="6">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,4">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Id}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:DropDownButton Icon="{ui:SymbolIcon Open24}" ToolTip="Open…" Margin="0,0,8,0">
                          <ui:DropDownButton.Flyout>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                              <MenuItem Header="Open in Steam (client)" Tag="{Binding Id}" Click="OnOpenInSteam">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="Open24" /></MenuItem.Icon>
                              </MenuItem>
                              <MenuItem Header="Steam page (web)" Tag="{Binding Id}" Click="OnOpenSteamWeb">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="Globe24" /></MenuItem.Icon>
                              </MenuItem>
                              <MenuItem Header="Show details in dzl" Tag="{Binding Id}" Click="OnShowInDzl">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="Info24" /></MenuItem.Icon>
                              </MenuItem>
                              <MenuItem Header="Open folder (Explorer)" Tag="{Binding Dir}" Click="OnOpenFolderDirect">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></MenuItem.Icon>
                              </MenuItem>
                            </ContextMenu>
                          </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                        <ui:Button Icon="{ui:SymbolIcon ArrowSync24}" ToolTip="Update (re-download via steamcmd)" Tag="{Binding Id}" Click="OnDownload" Margin="0,0,8,0"
                                   IsEnabled="{Binding DataContext.SteamCmdConfigured, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}" />
                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Danger" ToolTip="Delete (remove the downloaded files)" Tag="{Binding Id}" Click="OnDeleteDownloaded" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </ScrollViewer>
        </Border>
      </Expander>
    </StackPanel>

    <TextBlock Grid.Row="4" Text="{Binding WorkshopStatus}" Margin="0,8,0,0" VerticalAlignment="Center" FontSize="12"
               HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
  </Grid>
</ui:FluentWindow>
